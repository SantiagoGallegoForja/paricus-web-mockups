---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const benefits = [
  { icon: 'rocket', title: 'Career Growth', description: 'Clear advancement paths and leadership opportunities for every team member.' },
  { icon: 'heart', title: 'Inclusive Culture', description: 'A diverse, welcoming workplace where every voice is valued and heard.' },
  { icon: 'gift', title: 'Great Benefits', description: 'Competitive compensation, health coverage, and performance-based bonuses.' },
  { icon: 'book-open', title: 'Continuous Training', description: 'Ongoing professional development and skill-building programs.' },
];

const jobs = [
  { title: 'Senior Customer Service Representative', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: true, slug: 'senior-customer-service', summary: 'Lead our customer service team and deliver exceptional multilingual support experiences.' },
  { title: 'Back Office Analyst', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'back-office-analyst', summary: 'Process and manage critical business documents with precision and efficiency.' },
  { title: 'Sales Development Representative', department: 'Sales', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'sales-development-rep', summary: 'Drive revenue growth through strategic outbound campaigns and lead qualification.' },
  { title: 'Technical Support Engineer', department: 'Technology', location: 'Bogota, Colombia', type: 'Full-time', featured: true, slug: 'technical-support-engineer', summary: 'Provide expert-level technical assistance for complex software and hardware issues.' },
  { title: 'Quality Assurance Specialist', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'qa-specialist', summary: 'Monitor and improve service quality across all customer interaction channels.' },
];
---

<!-- ============================================================
     SECTION 1: HERO (SPLIT SCREEN)
     ============================================================ -->
<section class="bg-[#1a2e1a]">
  <div class="grid grid-cols-1 lg:grid-cols-2 min-h-[600px]">
    <!-- Left: Text -->
    <div class="flex items-center px-6 md:px-12 lg:px-16 py-24 md:py-32">
      <div class="max-w-xl" data-sa="slide-left">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] mb-4 block">
          // CAREERS
        </span>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold text-white mb-6 uppercase">
          Join Our Growing Team
        </h1>
        <p class="text-lg text-gray-300 leading-relaxed mb-10">
          Build your career with a company that values growth, innovation, and people. We're looking for talented individuals ready to make an impact.
        </p>
        <div class="flex flex-wrap gap-4">
          <a
            href="#positions"
            class="inline-block bg-[#52C17A] text-[#1a2e1a] font-mono text-[10px] uppercase tracking-[0.2em] px-8 py-4 hover:bg-[#3da862] transition-colors"
          >
            View Positions
          </a>
          <a
            href={getLocalizedPath('/about', lang)}
            class="inline-block border border-white text-white font-mono text-[10px] uppercase tracking-[0.2em] px-8 py-4 hover:bg-white hover:text-[#1a2e1a] transition-colors"
          >
            About Us
          </a>
        </div>
      </div>
    </div>

    <!-- Right: Image -->
    <div class="relative" data-sa="slide-right">
      <img
        src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=500&fit=crop"
        alt="Our team collaborating"
        class="w-full h-full object-cover min-h-[400px]"
        loading="lazy"
      />
      <!-- Floating card -->
      <div class="absolute bottom-8 left-8 bg-white p-6" data-sa="scale-in" data-sa-delay="300ms">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] block mb-1">
          // Team
        </span>
        <span class="text-3xl font-bold text-[#1a2e1a] block">100+</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E]">
          Professionals
        </span>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 2: BENEFITS
     ============================================================ -->
<section class="bg-[#FAFAF8] py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="text-center mb-16" data-sa="fade-up">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-4 block">
        // WHY JOIN US
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#2C3E50]">
        Built for Your Growth
      </h2>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {benefits.map((benefit, index) => (
        <div
          class="bg-white border-t-4 border-[#52C17A] p-8"
          data-sa="fade-up"
          data-sa-delay={`${index * 100}ms`}
        >
          <div class="mb-4">
            <Icon name={benefit.icon} class="w-8 h-8 text-[#52C17A]" />
          </div>
          <h3 class="text-lg font-bold text-[#2C3E50] mb-3">
            {benefit.title}
          </h3>
          <p class="text-[#5D6D7E] text-sm leading-relaxed">
            {benefit.description}
          </p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 3: OPEN POSITIONS
     ============================================================ -->
<section id="positions" class="bg-white py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="mb-16" data-sa="fade-up">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-4 block">
        // OPEN POSITIONS
      </span>
      <h2 class="text-3xl md:text-4xl font-bold text-[#2C3E50]">
        Current Openings
      </h2>
    </div>

    <div class="divide-y divide-[#D5E8D4]">
      {jobs.map((job, index) => (
        <a
          href={getLocalizedPath(`/careers/${job.slug}`, lang)}
          class:list={[
            'block py-8 group transition-colors hover:bg-[#FAFAF8] px-6 -mx-6',
            job.featured && 'border-l-4 border-[#52C17A] pl-6',
          ]}
          data-sa="fade-up"
          data-sa-delay={`${index * 80}ms`}
        >
          <div class="flex flex-col lg:flex-row lg:items-center lg:justify-between gap-4">
            <div class="flex-1">
              <div class="flex flex-wrap items-center gap-3 mb-2">
                <h3 class="text-xl font-bold text-[#2C3E50] group-hover:text-[#52C17A] transition-colors">
                  {job.title}
                </h3>
                <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] bg-[#D5E8D4] px-2 py-0.5">
                  {job.department}
                </span>
              </div>
              <p class="text-[#5D6D7E] text-sm mb-2">
                {job.summary}
              </p>
              <div class="flex flex-wrap items-center gap-4 text-sm text-[#5D6D7E]">
                <span class="flex items-center gap-1">
                  <Icon name="map-pin" class="w-3 h-3" />
                  {job.location}
                </span>
                <span class="flex items-center gap-1">
                  <Icon name="clock" class="w-3 h-3" />
                  {job.type}
                </span>
              </div>
            </div>
            <div class="flex-shrink-0">
              <span class="text-[#52C17A] group-hover:translate-x-1 transition-transform inline-block">
                &rarr;
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 4: CTA
     ============================================================ -->
<section class="bg-[#1a2e1a] py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 text-center">
    <div data-sa="fade-up">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        Don't see your role?
      </h2>
      <p class="text-lg text-gray-300 mb-10 max-w-2xl mx-auto">
        We're always looking for exceptional talent. Reach out and let's explore possibilities together.
      </p>
      <a
        href={getLocalizedPath('/contact', lang)}
        class="inline-block bg-[#52C17A] text-[#1a2e1a] font-mono text-[10px] uppercase tracking-[0.2em] px-10 py-4 hover:bg-[#3da862] transition-colors"
      >
        Contact Us
      </a>
    </div>
  </div>
</section>

---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const industries = [
  {
    icon: 'heart',
    title: 'Healthcare',
    description: 'Supporting patient care with compassionate, HIPAA-compliant support services that maintain the highest standards of data security.',
  },
  {
    icon: 'package',
    title: 'E-Commerce',
    description: 'Scaling your online business with seamless customer experiences across every channel and touchpoint.',
  },
  {
    icon: 'cpu',
    title: 'Technology',
    description: 'Technical support that speaks your customers\' language, from troubleshooting to advanced product guidance.',
  },
  {
    icon: 'landmark',
    title: 'Finance',
    description: 'Secure, compliant support for financial services with rigorous attention to regulatory requirements.',
  },
  {
    icon: 'shopping-bag',
    title: 'Travel & Hospitality',
    description: 'Creating memorable experiences from first contact, with multilingual support that delights guests worldwide.',
  },
];
---

<!-- ============================================================
     DESIGN V4 — PREMIUM CORPORATE / INDUSTRIES PAGE
     Sharp corners, monospace labels, split-screen layouts,
     structured corporate feel with V2 color palette
     ============================================================ -->

<!-- ==================== SECTION 1: HERO (Split-Screen) ==================== -->
<section class="relative bg-[#FAFAF8] py-28 lg:py-0 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center lg:min-h-[90vh] py-12 lg:py-24">

      <!-- Left: Text content -->
      <div data-sa="slide-right">
        <!-- Monospace label -->
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-8">
          // INDUSTRIES
        </p>

        <!-- Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-black leading-[0.95] tracking-[-0.03em] text-[#1a2e1a] mb-6" data-sa="fade-up" data-sa-delay="100">
          Industries We <span class="text-[#52C17A]">Serve</span>
        </h1>

        <!-- Accent line -->
        <div class="w-16 h-[2px] bg-[#52C17A] mb-8" data-sa="fade-up" data-sa-delay="150"></div>

        <!-- Description -->
        <p class="text-lg text-[#2C3E50] leading-relaxed max-w-xl" data-sa="fade-up" data-sa-delay="200">
          Specialized expertise across diverse sectors, delivering tailored outsourcing solutions that understand your unique challenges.
        </p>
      </div>

      <!-- Right: Image with offset border -->
      <div class="relative" data-sa="slide-left">
        <div class="relative">
          <!-- Offset green border -->
          <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-[#52C17A]"></div>
          <!-- Image -->
          <img
            src="https://images.unsplash.com/photo-1553877522-43269d4ea984?w=550&h=380&fit=crop"
            alt="Industries we serve"
            class="relative w-full h-[380px] object-cover z-10"
            loading="eager"
          />
        </div>

        <!-- Floating stat card -->
        <div class="absolute -bottom-8 -left-6 bg-white border-2 border-[#D5E8D4] p-5 z-20 shadow-lg" data-sa="fade-up" data-sa-delay="300">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-1">// Industries</p>
          <p class="text-3xl font-black text-[#1a2e1a]">5+</p>
          <p class="text-sm text-[#5D6D7E]">Sectors Served</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ==================== SECTION 2: INDUSTRIES DETAIL GRID ==================== -->
<section class="relative bg-white py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <!-- Section header -->
    <div class="text-center mb-20" data-sa="fade-up">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-6">
        // OUR EXPERTISE
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-[-0.03em] text-[#1a2e1a]">
        Sector <span class="text-[#52C17A]">Specializations</span>
      </h2>
    </div>

    <!-- Industry cards -->
    <div class="space-y-8">
      {industries.map((industry, index) => (
        <div
          class={`grid grid-cols-1 lg:grid-cols-12 gap-8 items-center ${index % 2 === 1 ? 'lg:direction-rtl' : ''}`}
          data-sa="fade-up"
          data-sa-delay={String(index * 100)}
        >
          <!-- Card content -->
          <div class={`lg:col-span-12 border-t-[3px] border-[#52C17A] bg-[#FAFAF8] p-8 lg:p-10 hover:-translate-y-1 transition-all duration-300 group`}>
            <div class="flex flex-col sm:flex-row items-start gap-6">
              <!-- Icon -->
              <div class="w-16 h-16 flex items-center justify-center bg-[#1a2e1a] text-[#52C17A] flex-shrink-0 group-hover:bg-[#52C17A] group-hover:text-white transition-all duration-300">
                <Icon name={industry.icon} size={28} />
              </div>

              <!-- Text -->
              <div class="flex-1">
                <div class="flex items-center gap-4 mb-3">
                  <h3 class="text-xl sm:text-2xl font-black text-[#1a2e1a]">{industry.title}</h3>
                  <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E]">// 0{index + 1}</span>
                </div>
                <p class="text-[#5D6D7E] leading-relaxed max-w-2xl">{industry.description}</p>
              </div>

              <!-- Arrow -->
              <div class="hidden sm:flex items-center justify-center w-10 h-10 border-2 border-[#D5E8D4] group-hover:border-[#52C17A] group-hover:bg-[#52C17A] group-hover:text-white text-[#5D6D7E] transition-all duration-300 flex-shrink-0 self-center">
                <Icon name="arrow-right" size={16} />
              </div>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SECTION 3: CTA ==================== -->
<section class="relative bg-[#1a2e1a] py-24 lg:py-32 overflow-hidden">
  <!-- Subtle grid background -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(#52C17A 1px, transparent 1px), linear-gradient(90deg, #52C17A 1px, transparent 1px); background-size: 60px 60px;"></div>

  <div class="relative max-w-[1400px] mx-auto px-6 lg:px-16 text-center">
    <!-- Monospace label -->
    <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] mb-8" data-sa="fade-up">
      // GET STARTED
    </p>

    <!-- Heading -->
    <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-[-0.03em] text-white mb-6" data-sa="fade-up" data-sa-delay="100">
      Let's Build Something <span class="text-[#52C17A]">Together</span>
    </h2>

    <!-- Accent line -->
    <div class="w-16 h-[2px] bg-[#52C17A] mx-auto mb-8" data-sa="fade-up" data-sa-delay="150"></div>

    <!-- Description -->
    <p class="text-lg text-white/70 max-w-2xl mx-auto font-light leading-relaxed mb-12" data-sa="fade-up" data-sa-delay="200">
      Discover how our industry-specific expertise can transform your operations and drive measurable results.
    </p>

    <!-- CTA Button -->
    <a
      href={getLocalizedPath('/contact', lang)}
      class="inline-flex items-center gap-3 px-10 py-4 bg-[#52C17A] text-white font-mono text-xs uppercase tracking-[0.15em] hover:bg-[#3D9E5F] transition-all duration-300"
      data-sa="fade-up"
      data-sa-delay="250"
    >
      Get in Touch
      <Icon name="arrow-right" size={14} />
    </a>
  </div>
</section>

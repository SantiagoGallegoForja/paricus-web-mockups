---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const title = 'Customer Service';
const icon = 'headphones';
const description = 'Deliver exceptional customer experiences with our dedicated bilingual support teams trained in your brand voice and processes.';

const features = [
  { name: '24/7 Multichannel Support', description: 'Round-the-clock assistance across phone, email, chat, and social media channels.' },
  { name: 'Bilingual English/Spanish Teams', description: 'Native-level agents fluent in both languages for seamless communication.' },
  { name: 'Custom CRM Integration', description: 'Deep integration with your existing tools and workflows for unified operations.' },
  { name: 'Quality Assurance Programs', description: 'Continuous monitoring and coaching to maintain the highest service standards.' },
  { name: 'Scalable Team Models', description: 'Flexible staffing that grows or contracts with your business demands.' },
];

const benefits = [
  { stat: '40%', label: 'Cost Reduction' },
  { stat: '95%', label: 'Customer Satisfaction' },
  { stat: '24/7', label: 'Coverage' },
  { stat: '100%', label: 'Seamless Integration' },
];

const useCases = [
  { title: 'E-commerce Support', description: 'Handle order inquiries, returns, and product questions with speed and empathy across all your sales channels.' },
  { title: 'Healthcare Patient Services', description: 'Manage appointment scheduling, insurance verification, and patient follow-ups with HIPAA-compliant processes.' },
  { title: 'SaaS Technical Assistance', description: 'Provide expert onboarding support, troubleshooting, and account management for your software users.' },
];
---

<!-- V4 — Premium Corporate: ServiceDetail -->
<section class="d4-service-detail">

  <!-- HEADER -->
  <div class="bg-[#1a2e1a] pt-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-24 lg:py-32">
      <a
        href={getLocalizedPath('/services', lang)}
        class="inline-flex items-center gap-2 text-white/60 font-mono text-[11px] uppercase tracking-[0.2em] hover:text-[#52C17A] transition-colors mb-12"
        data-sa="fade-up"
      >
        <span>&larr;</span> Back to Services
      </a>
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] block mb-8" data-sa="fade-up" data-sa-delay="80ms">// SERVICE DETAIL</span>
      <div class="flex items-center gap-6 mb-8" data-sa="fade-up" data-sa-delay="160ms">
        <div class="w-16 h-16 border-2 border-[#52C17A] flex items-center justify-center flex-shrink-0">
          <Icon name={icon} class="w-8 h-8 text-[#52C17A]" />
        </div>
        <h1 class="font-black text-4xl md:text-5xl lg:text-7xl uppercase tracking-[-0.04em] leading-[0.9] text-white">
          {title}
        </h1>
      </div>
      <div class="w-16 h-[3px] bg-[#52C17A] mb-8" data-sa="fade-up" data-sa-delay="240ms"></div>
      <p class="text-white/70 text-lg lg:text-xl max-w-2xl leading-relaxed font-light" data-sa="fade-up" data-sa-delay="320ms">
        {description}
      </p>
    </div>
  </div>

  <!-- CAPABILITIES — Split: Text Left, Image Right -->
  <div class="bg-white py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <div class="flex flex-col lg:flex-row gap-16 lg:gap-24">

        <!-- Text Side -->
        <div class="w-full lg:w-1/2">
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] block mb-10" data-sa="fade-up">// CAPABILITIES</span>
          <div class="space-y-0">
            {features.map((feature, i) => (
              <div
                class="d4-feature-row flex items-start gap-5 py-6 border-b border-[#D5E8D4]"
                data-sa="fade-up"
                data-sa-delay={`${i * 80}ms`}
              >
                <span class="font-mono text-3xl font-black text-[#D5E8D4] select-none w-12 flex-shrink-0 leading-none pt-1">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="flex-1">
                  <h3 class="text-lg font-bold tracking-tight text-[#2C3E50] mb-1">{feature.name}</h3>
                  <p class="text-[#5D6D7E] text-sm leading-relaxed">{feature.description}</p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Image Side -->
        <div class="w-full lg:w-1/2 flex items-center" data-sa="slide-left" data-sa-delay="200ms">
          <img
            src="https://images.unsplash.com/photo-1504868584819-f8e8b4b6d7e3?w=700&h=500&fit=crop"
            alt="Customer service operations"
            class="w-full h-[400px] lg:h-[520px] object-cover"
            loading="lazy"
          />
        </div>

      </div>
    </div>
  </div>

  <!-- KEY BENEFITS — Stats Row -->
  <div class="bg-[#FAFAF8] py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] block mb-12" data-sa="fade-up">// KEY BENEFITS</span>
      <div class="grid grid-cols-2 lg:grid-cols-4 border-t border-b border-[#D5E8D4]">
        {benefits.map((benefit, i) => (
          <div
            class={`d4-benefit-cell py-10 px-6 lg:px-8 ${i > 0 ? 'border-l border-[#D5E8D4]' : ''}`}
            data-sa="fade-up"
            data-sa-delay={`${i * 80}ms`}
          >
            <div class="text-4xl lg:text-5xl font-black text-[#1a2e1a] mb-3">{benefit.stat}</div>
            <div class="w-8 h-[2px] bg-[#52C17A] mb-3"></div>
            <div class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E]">{benefit.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- USE CASES -->
  <div class="bg-white py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] block mb-12" data-sa="fade-up">// USE CASES</span>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-0">
        {useCases.map((uc, i) => (
          <div
            class={`d4-usecase-card p-8 lg:p-10 border-t-[3px] border-t-[#52C17A] bg-white ${i > 0 ? 'md:border-l border-[#D5E8D4]' : ''}`}
            data-sa="fade-up"
            data-sa-delay={`${i * 100}ms`}
          >
            <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] block mb-4">// CASE {String(i + 1).padStart(2, '0')}</span>
            <h3 class="text-xl lg:text-2xl font-black uppercase tracking-tight text-[#2C3E50] mb-4">
              {uc.title}
            </h3>
            <p class="text-[#5D6D7E] leading-relaxed">{uc.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- CTA -->
  <div class="bg-[#1a2e1a] py-24 lg:py-32">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 text-center" data-sa="scale-in">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] block mb-6">// GET STARTED</span>
      <h2 class="font-black text-3xl md:text-4xl lg:text-5xl uppercase tracking-[-0.04em] leading-[0.9] text-white mb-6">
        Ready to Transform<br/>Your Customer Experience?
      </h2>
      <p class="text-white/60 text-lg max-w-xl mx-auto font-light leading-relaxed mb-10">
        Let us build a dedicated support team tailored to your brand and customers.
      </p>
      <a
        href={getLocalizedPath('/contact', lang)}
        class="inline-flex items-center gap-3 px-10 py-5 bg-[#52C17A] text-white font-bold uppercase tracking-widest text-sm hover:bg-[#3D9E5F] transition-colors"
      >
        Contact Us <span>&rarr;</span>
      </a>
    </div>
  </div>

</section>

<style>
  .d4-feature-row {
    transition: all 0.3s ease;
  }
  .d4-feature-row:hover {
    background: #1a2e1a;
    padding-left: 1.5rem;
    padding-right: 1.5rem;
  }
  .d4-feature-row:hover span {
    color: #52C17A;
  }
  .d4-feature-row:hover h3 {
    color: #ffffff;
  }
  .d4-feature-row:hover p {
    color: #94a3b8;
  }

  .d4-benefit-cell {
    transition: all 0.3s ease;
  }
  .d4-benefit-cell:hover {
    background: #1a2e1a;
  }
  .d4-benefit-cell:hover > div:first-child {
    color: #ffffff;
  }
  .d4-benefit-cell:hover .font-mono {
    color: #94a3b8;
  }

  .d4-usecase-card {
    transition: all 0.3s ease;
  }
  .d4-usecase-card:hover {
    background: #FAFAF8;
    transform: translateY(-2px);
  }
</style>

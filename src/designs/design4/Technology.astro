---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const certifications = [
  { title: 'ISO 27001', description: 'Information Security Management' },
  { title: 'ISO 9001', description: 'Quality Management Systems' },
  { title: 'HIPAA', description: 'Healthcare Data Protection' },
  { title: 'SOC 2 Type II', description: 'Service Organization Controls' },
];
const techStack = [
  {
    icon: 'shield',
    title: 'Enterprise Security',
    description: 'Multi-layer security protocols with end-to-end encryption, intrusion detection systems, and continuous threat monitoring to safeguard your data.',
  },
  {
    icon: 'zap',
    title: 'AI-Powered Tools',
    description: 'Smart automation enhancing agent productivity with real-time suggestions, sentiment analysis, and intelligent routing for faster resolutions.',
  },
  {
    icon: 'database',
    title: 'Real-time Analytics',
    description: 'Live dashboards and performance insights that provide actionable intelligence, enabling data-driven decisions and continuous optimization.',
  },
  {
    icon: 'cloud',
    title: 'Cloud Infrastructure',
    description: 'Scalable, redundant cloud architecture with multi-region deployment ensuring 99.9% uptime and seamless disaster recovery.',
  },
];
---

<!-- ============================================================
     DESIGN V4 — PREMIUM CORPORATE / TECHNOLOGY PAGE
     Sharp corners, monospace labels, split-screen layouts,
     structured corporate feel with V2 color palette
     ============================================================ -->

<!-- ==================== SECTION 1: HERO (Split-Screen) ==================== -->
<section class="relative bg-[#FAFAF8] py-28 lg:py-0 overflow-hidden">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center lg:min-h-[90vh] py-12 lg:py-24">

      <!-- Left: Text content -->
      <div data-sa="slide-right">
        <!-- Monospace label -->
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-8">
          // TECHNOLOGY
        </p>

        <!-- Heading -->
        <h1 class="text-4xl sm:text-5xl lg:text-5xl xl:text-6xl font-black leading-[0.95] tracking-[-0.03em] text-[#1a2e1a] mb-6" data-sa="fade-up" data-sa-delay="100">
          Technology & <span class="text-[#52C17A]">Compliance</span>
        </h1>

        <!-- Accent line -->
        <div class="w-16 h-[2px] bg-[#52C17A] mb-8" data-sa="fade-up" data-sa-delay="150"></div>

        <!-- Description -->
        <p class="text-lg text-[#2C3E50] leading-relaxed max-w-xl" data-sa="fade-up" data-sa-delay="200">
          Enterprise-grade technology and security standards that power exceptional business operations.
        </p>
      </div>

      <!-- Right: Image with offset border -->
      <div class="relative" data-sa="slide-left">
        <div class="relative">
          <!-- Offset green border -->
          <div class="absolute -bottom-4 -right-4 w-full h-full border-2 border-[#52C17A]"></div>
          <!-- Image -->
          <img
            src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?w=600&h=500&fit=crop"
            alt="Technology and compliance"
            class="relative w-full h-[500px] object-cover z-10"
            loading="eager"
          />
        </div>

        <!-- Floating stat card -->
        <div class="absolute -bottom-8 -left-6 bg-white border-2 border-[#D5E8D4] p-5 z-20 shadow-lg" data-sa="fade-up" data-sa-delay="300">
          <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-1">// Uptime SLA</p>
          <p class="text-3xl font-black text-[#1a2e1a]">99.9%</p>
          <p class="text-sm text-[#5D6D7E]">Uptime SLA</p>
        </div>
      </div>

    </div>
  </div>
</section>

<!-- ==================== SECTION 2: CERTIFICATIONS ==================== -->
<section class="relative bg-white py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <!-- Section header -->
    <div class="text-center mb-20" data-sa="fade-up">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-6">
        // CERTIFICATIONS
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-[-0.03em] text-[#1a2e1a]">
        Industry-Leading <span class="text-[#52C17A]">Standards</span>
      </h2>
    </div>

    <!-- Certification cards -->
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
      {certifications.map((cert, index) => (
        <div
          class="border-2 border-[#D5E8D4] p-8 text-center hover:border-[#52C17A] hover:-translate-y-1 transition-all duration-300 group"
          data-sa="fade-up"
          data-sa-delay={String(index * 100)}
        >
          <!-- Large certification title -->
          <div class="mb-4">
            <p class="text-2xl sm:text-3xl font-black text-[#1a2e1a] group-hover:text-[#52C17A] transition-colors duration-300">{cert.title}</p>
          </div>
          <!-- Accent line -->
          <div class="w-10 h-[2px] bg-[#52C17A] mx-auto mb-4"></div>
          <!-- Description -->
          <p class="text-sm text-[#5D6D7E] leading-relaxed">{cert.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SECTION 3: TECHNOLOGY STACK ==================== -->
<section class="relative bg-[#FAFAF8] py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <!-- Section header -->
    <div class="text-center mb-20" data-sa="fade-up">
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-6">
        // CAPABILITIES
      </p>
      <h2 class="text-3xl sm:text-4xl lg:text-5xl font-black tracking-[-0.03em] text-[#1a2e1a] mb-6">
        Technology <span class="text-[#52C17A]">Stack</span>
      </h2>
      <p class="text-lg text-[#5D6D7E] max-w-2xl mx-auto font-light leading-relaxed">
        Cutting-edge tools and platforms that drive operational excellence.
      </p>
    </div>

    <!-- Tech stack grid (2x2) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
      {techStack.map((tech, index) => (
        <div
          class="bg-white border-l-[3px] border-[#52C17A] p-8 lg:p-10 hover:-translate-y-1 transition-all duration-300 group"
          data-sa="fade-up"
          data-sa-delay={String(index * 100)}
        >
          <div class="flex items-start gap-6">
            <!-- Icon -->
            <div class="w-14 h-14 flex items-center justify-center bg-[#1a2e1a] text-[#52C17A] flex-shrink-0 group-hover:bg-[#52C17A] group-hover:text-white transition-all duration-300">
              <Icon name={tech.icon} size={24} />
            </div>

            <!-- Text -->
            <div class="flex-1">
              <h3 class="text-xl font-black text-[#1a2e1a] mb-3">{tech.title}</h3>
              <p class="text-[#5D6D7E] leading-relaxed text-sm">{tech.description}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SECTION 4: SECURITY (Image + Text Split) ==================== -->
<section class="relative bg-white py-24 lg:py-32">
  <div class="max-w-[1400px] mx-auto px-6 lg:px-16">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">

      <!-- Left: Image -->
      <div class="relative" data-sa="slide-right">
        <img
          src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=500&h=400&fit=crop"
          alt="Data security and compliance"
          class="w-full h-[400px] object-cover"
          loading="lazy"
        />
      </div>

      <!-- Right: Text content -->
      <div data-sa="slide-left">
        <!-- Monospace label -->
        <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-6">
          // SECURITY
        </p>

        <!-- Heading -->
        <h2 class="text-3xl sm:text-4xl font-black tracking-[-0.03em] text-[#1a2e1a] mb-6">
          Your Data, Our <span class="text-[#52C17A]">Priority</span>
        </h2>

        <!-- Accent line -->
        <div class="w-16 h-[2px] bg-[#52C17A] mb-8"></div>

        <!-- Description -->
        <p class="text-lg text-[#5D6D7E] leading-relaxed mb-10">
          We maintain the highest standards of data security and compliance, ensuring your sensitive information is protected with enterprise-grade protocols and regular third-party audits.
        </p>

        <!-- CTA Button -->
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center gap-3 px-8 py-4 bg-[#1a2e1a] text-white font-mono text-xs uppercase tracking-[0.15em] hover:bg-[#52C17A] transition-all duration-300"
        >
          Request Security Whitepaper
          <Icon name="arrow-right" size={14} />
        </a>
      </div>

    </div>
  </div>
</section>

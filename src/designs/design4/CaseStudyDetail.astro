---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';
import { placeholderImages } from '../../data/placeholder-images';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

const caseStudy = {
  title: 'Healthcare Provider Reduces Response Time by 60%',
  industry: 'Healthcare',
  client: 'Regional Healthcare Network',
  challenge: "A major regional healthcare network was struggling with patient support response times averaging 12 minutes, leading to declining patient satisfaction scores and increased complaint escalations. Their in-house team couldn't scale during peak hours and lacked bilingual capabilities for their growing Hispanic patient base.",
  solution: 'Paricus deployed a dedicated 45-person bilingual support team with HIPAA certification and healthcare-specific training. We implemented an AI-assisted triage system to route calls efficiently and established 24/7 coverage with specialized healthcare protocols.',
  results: [
    { icon: 'clock', value: '60%', label: 'Faster Response Time', detail: 'From 12min to under 5min' },
    { icon: 'star', value: '95%', label: 'Patient Satisfaction', detail: 'Up from 72%' },
    { icon: 'trending-up', value: '40%', label: 'Cost Reduction', detail: 'vs previous in-house operation' },
  ],
  testimonial: {
    quote: 'Paricus transformed our patient support operations. The bilingual team and healthcare expertise made an immediate impact on our satisfaction scores.',
    author: 'Dr. Sarah Mitchell',
    role: 'VP of Patient Experience',
  },
};
---

<!-- ============================================================
     SECTION 1: HEADER
     ============================================================ -->
<section class="bg-[#1a2e1a] py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <a
      href={getLocalizedPath('/case-studies', lang)}
      class="inline-flex items-center font-mono text-[10px] uppercase tracking-[0.2em] text-gray-400 hover:text-[#52C17A] transition-colors mb-10"
      data-sa="fade-up"
    >
      &larr; Back to Case Studies
    </a>

    <div class="max-w-4xl" data-sa="fade-up" data-sa-delay="100ms">
      <span class="inline-block font-mono text-[10px] uppercase tracking-[0.2em] text-[#1a2e1a] bg-[#52C17A] px-3 py-1 mb-6">
        {caseStudy.industry}
      </span>
      <h1 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        {caseStudy.title}
      </h1>
      <p class="font-mono text-[10px] uppercase tracking-[0.2em] text-gray-400">
        Client: {caseStudy.client}
      </p>
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 2: KEY METRICS BANNER
     ============================================================ -->
<section class="bg-[#FAFAF8] py-20 md:py-24">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-10 block text-center" data-sa="fade-up">
      // KEY METRICS
    </span>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {caseStudy.results.map((result, index) => (
        <div
          class="text-center p-8 bg-white border border-[#D5E8D4]"
          data-sa="scale-in"
          data-sa-delay={`${index * 150}ms`}
        >
          <div class="flex justify-center mb-4">
            <Icon name={result.icon} class="w-8 h-8 text-[#52C17A]" />
          </div>
          <span class="block text-4xl md:text-5xl font-bold text-[#1a2e1a] mb-2">
            {result.value}
          </span>
          <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-[#2C3E50] mb-2">
            {result.label}
          </span>
          <span class="block text-sm text-[#5D6D7E]">
            {result.detail}
          </span>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 3: CHALLENGE + SOLUTION (SPLIT)
     ============================================================ -->
<section class="bg-white py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 mb-16">
      <!-- Challenge -->
      <div data-sa="slide-left">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-4 block">
          // CHALLENGE
        </span>
        <h2 class="text-2xl md:text-3xl font-bold text-[#2C3E50] mb-6">
          The Challenge
        </h2>
        <p class="text-[#5D6D7E] leading-relaxed text-lg">
          {caseStudy.challenge}
        </p>
      </div>

      <!-- Solution -->
      <div data-sa="slide-right">
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-4 block">
          // SOLUTION
        </span>
        <h2 class="text-2xl md:text-3xl font-bold text-[#2C3E50] mb-6">
          Our Solution
        </h2>
        <p class="text-[#5D6D7E] leading-relaxed text-lg">
          {caseStudy.solution}
        </p>
      </div>
    </div>

    <!-- Image -->
    <div data-sa="fade-up" data-sa-delay="200ms">
      <img
        src={placeholderImages.caseStudy[0].url}
        alt="Case study implementation"
        class="w-full h-[400px] object-cover"
        loading="lazy"
      />
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 4: TESTIMONIAL
     ============================================================ -->
<section class="bg-[#FAFAF8] py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12">
    <div class="max-w-4xl mx-auto border-l-4 border-[#52C17A] pl-8 md:pl-12" data-sa="fade-up">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-6 block">
        // TESTIMONIAL
      </span>
      <blockquote class="text-2xl md:text-3xl font-light text-[#2C3E50] leading-relaxed mb-8">
        &ldquo;{caseStudy.testimonial.quote}&rdquo;
      </blockquote>
      <div>
        <span class="block text-[#2C3E50] font-bold">
          {caseStudy.testimonial.author}
        </span>
        <span class="block font-mono text-[10px] uppercase tracking-[0.2em] text-[#5D6D7E]">
          {caseStudy.testimonial.role}
        </span>
      </div>
    </div>
  </div>
</section>

<!-- ============================================================
     SECTION 5: CTA
     ============================================================ -->
<section class="bg-[#1a2e1a] py-24 md:py-32">
  <div class="max-w-[1400px] mx-auto px-6 md:px-12 text-center">
    <div data-sa="fade-up">
      <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold text-white mb-6">
        Let's build your success story.
      </h2>
      <a
        href={getLocalizedPath('/contact', lang)}
        class="inline-block bg-[#52C17A] text-[#1a2e1a] font-mono text-[10px] uppercase tracking-[0.2em] px-10 py-4 hover:bg-[#3da862] transition-colors"
      >
        Start a Conversation
      </a>
    </div>
  </div>
</section>

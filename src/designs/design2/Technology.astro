---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const heading = 'Technology & Compliance';
const description = 'Enterprise-grade technology and security standards that power exceptional business operations.';
const certifications = [
  { name: 'ISO 27001', description: 'Information Security Management' },
  { name: 'ISO 9001', description: 'Quality Management Systems' },
  { name: 'HIPAA', description: 'Healthcare Data Protection' },
  { name: 'SOC 2 Type II', description: 'Service Organization Controls' },
];
const technologies = [
  { icon: 'shield', name: 'Enterprise Security', description: 'Multi-layer security protocols protecting your data at every touchpoint with continuous monitoring.' },
  { icon: 'zap', name: 'AI-Powered Tools', description: 'Smart automation enhancing agent productivity and customer satisfaction through intelligent routing.' },
  { icon: 'database', name: 'Real-time Analytics', description: 'Live dashboards and performance insights for data-driven decisions across all operations.' },
  { icon: 'cloud', name: 'Cloud Infrastructure', description: 'Scalable, redundant cloud architecture ensuring 99.9% uptime and seamless global access.' },
];
const securityTitle = 'Your Data, Our Priority';
const securityDescription = 'We maintain the highest standards of data security and compliance, ensuring your sensitive information is protected with enterprise-grade protocols and regular third-party audits.';
---

<!-- V2 — Editorial Enterprise — Technology -->
<div class="tv2">

  <!-- ==================== HERO ==================== -->
  <section class="tv2-hero">
    <div class="tv2-hero__grid sa-parallax" data-sa="fade-in"></div>
    <!-- Decorative elements -->
    <div class="tv2-hero__deco-circle"></div>
    <div class="tv2-hero__deco-dots"></div>

    <div class="tv2-hero__container">
      <div class="tv2-hero__text" data-sa="slide-right">
        <span class="tv2-mono-label">// TECHNOLOGY</span>
        <h1 class="tv2-hero__title" data-sa="fade-up">
          Technology &<br />
          <span class="tv2-hero__title-accent">Compliance</span>
        </h1>
        <div class="tv2-accent-line"></div>
        <p class="tv2-hero__desc">{description}</p>
      </div>

      <div class="tv2-hero__visual" data-sa="slide-left">
        <img
          src="https://images.unsplash.com/photo-1573164713714-d95e436ab8d6?w=600&h=500&fit=crop"
          alt="Modern technology workspace"
          loading="eager"
          data-sa="fade-in"
          class="tv2-hero__img"
        />
        <!-- Floating stat card -->
        <div class="tv2-hero__stat-card">
          <span class="tv2-hero__stat-value">99.9%</span>
          <span class="tv2-hero__stat-label">Uptime SLA</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== CERTIFICATIONS ==================== -->
  <section class="tv2-certs">
    <div class="tv2-certs__container">
      <div class="tv2-certs__header">
        <span class="tv2-mono-label">// CERTIFICATIONS</span>
        <h2 class="tv2-certs__title" data-sa="fade-up">Industry-Leading Standards</h2>
      </div>

      <div class="tv2-certs__grid">
        {certifications.map((cert, i) => (
          <div class="tv2-cert sa-hover-lift" data-sa="fade-up" data-sa-delay={`${i * 80}`}>
            <div class="tv2-cert__number">{String(i + 1).padStart(2, '0')}</div>
            <h3 class="tv2-cert__name">{cert.name}</h3>
            <p class="tv2-cert__desc">{cert.description}</p>
            <div class="tv2-cert__bar"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== TECH STACK ==================== -->
  <section class="tv2-stack">
    <div class="tv2-stack__deco-gradient"></div>
    <div class="tv2-stack__deco-line"></div>

    <div class="tv2-stack__container">
      <div class="tv2-stack__header">
        <span class="tv2-mono-label">// CAPABILITIES</span>
        <h2 class="tv2-stack__title" data-sa="fade-up">Technology Stack</h2>
        <p class="tv2-stack__subtitle" data-sa="fade-up" data-sa-delay="100">Cutting-edge tools and platforms that drive operational excellence.</p>
      </div>

      <div class="tv2-stack__grid">
        {technologies.map((tech, i) => (
          <div class="tv2-tech-card" data-sa="fade-up" data-sa-delay={`${i * 100}`}>
            <div class="tv2-tech-card__icon">
              <Icon name={tech.icon} size={24} />
            </div>
            <h3 class="tv2-tech-card__name">{tech.name}</h3>
            <p class="tv2-tech-card__desc">{tech.description}</p>
            <div class="tv2-tech-card__hover-line"></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== SECURITY SECTION (CTA) ==================== -->
  <section class="tv2-security" data-sa="scale-in">
    <div class="tv2-security__grid-bg"></div>
    <div class="tv2-security__container">
      <div class="tv2-security__content" data-sa="slide-right">
        <span class="tv2-mono-label tv2-mono-label--light">// SECURITY</span>
        <div class="tv2-accent-line tv2-accent-line--light"></div>
        <h2 class="tv2-security__title" data-sa="fade-up">{securityTitle}</h2>
        <p class="tv2-security__desc">{securityDescription}</p>
        <a href={getLocalizedPath('/contact', lang)} class="tv2-security__btn">
          Request Security Whitepaper
          <Icon name="arrow-right" size={14} />
        </a>
      </div>
      <div class="tv2-security__visual" data-sa="slide-left">
        <img
          src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=500&h=400&fit=crop"
          alt="Cybersecurity and data protection"
          loading="lazy"
          data-sa="fade-in"
          class="tv2-security__img"
        />
      </div>
    </div>
  </section>

</div>

<style>
  /* ===== SHARED ===== */
  .tv2-mono-label {
    display: block;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.72rem;
    font-weight: 600;
    color: #52C17A;
    letter-spacing: 0.15em;
    margin-bottom: 1rem;
  }
  .tv2-mono-label--light { color: #52C17A; }
  .tv2-accent-line {
    width: 50px;
    height: 2px;
    background: #52C17A;
    margin-bottom: 1.5rem;
  }
  .tv2-accent-line--light { background: #52C17A; }

  /* ===== HERO ===== */
  .tv2-hero {
    position: relative;
    padding: 10rem 2rem 6rem;
    background: #FAFAF8;
    overflow: hidden;
  }
  .tv2-hero__grid {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26,46,26,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26,46,26,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .tv2-hero__deco-circle {
    position: absolute;
    right: 5%;
    top: 15%;
    width: 400px;
    height: 400px;
    border: 1px solid rgba(82, 193, 122, 0.06);
    border-radius: 50%;
    pointer-events: none;
  }
  .tv2-hero__deco-dots {
    position: absolute;
    left: 3%;
    bottom: 10%;
    width: 120px;
    height: 120px;
    background-image: radial-gradient(circle, #D5E8D4 1px, transparent 1px);
    background-size: 16px 16px;
    opacity: 0.5;
    pointer-events: none;
  }
  .tv2-hero__container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .tv2-hero__title {
    font-size: clamp(2.8rem, 5vw, 4rem);
    font-weight: 900;
    color: #1a2e1a;
    line-height: 1.05;
    margin: 0 0 1.5rem;
    text-transform: uppercase;
    letter-spacing: -0.02em;
  }
  .tv2-hero__title-accent {
    color: #52C17A;
  }
  .tv2-hero__desc {
    font-size: 1.05rem;
    color: #5D6D7E;
    line-height: 1.75;
    margin: 0;
    max-width: 480px;
  }
  .tv2-hero__visual {
    position: relative;
  }
  .tv2-hero__img {
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .tv2-hero__stat-card {
    position: absolute;
    bottom: -20px;
    left: -20px;
    background: #fff;
    border: 2px solid #1a2e1a;
    padding: 1.2rem 1.8rem;
    z-index: 2;
  }
  .tv2-hero__stat-value {
    display: block;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 2rem;
    font-weight: 800;
    color: #1a2e1a;
    letter-spacing: -0.02em;
    line-height: 1;
  }
  .tv2-hero__stat-label {
    display: block;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.68rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #5D6D7E;
    margin-top: 0.3rem;
  }

  /* ===== CERTIFICATIONS ===== */
  .tv2-certs {
    padding: 6rem 2rem;
    background: #fff;
    border-top: 1px solid #eef0f2;
  }
  .tv2-certs__container {
    max-width: 1200px;
    margin: 0 auto;
  }
  .tv2-certs__header {
    text-align: center;
    margin-bottom: 3.5rem;
  }
  .tv2-certs__header .tv2-mono-label {
    display: inline-block;
  }
  .tv2-certs__title {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 800;
    color: #1a2e1a;
    margin: 0;
    letter-spacing: -0.02em;
  }
  .tv2-certs__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0;
  }
  .tv2-cert {
    position: relative;
    padding: 2.5rem 2rem;
    border: 1px solid #eef0f2;
    margin-left: -1px;
    margin-top: -1px;
    background: #fff;
    transition: background 0.4s ease;
    cursor: default;
    overflow: hidden;
  }
  .tv2-cert:hover {
    background: #FAFAF8;
  }
  .tv2-cert__number {
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-size: 0.7rem;
    color: #D5E8D4;
    letter-spacing: 0.1em;
    margin-bottom: 1.2rem;
    display: block;
  }
  .tv2-cert__name {
    font-size: 1.1rem;
    font-weight: 700;
    color: #1a2e1a;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin: 0 0 0.5rem;
    transition: color 0.3s ease;
  }
  .tv2-cert:hover .tv2-cert__name {
    color: #52C17A;
  }
  .tv2-cert__desc {
    font-size: 0.85rem;
    color: #5D6D7E;
    margin: 0;
    line-height: 1.6;
  }
  .tv2-cert__bar {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: #52C17A;
    transition: width 0.5s ease;
  }
  .tv2-cert:hover .tv2-cert__bar {
    width: 100%;
  }

  /* ===== TECH STACK ===== */
  .tv2-stack {
    position: relative;
    padding: 7rem 2rem;
    background: #FAFAF8;
    overflow: hidden;
  }
  .tv2-stack__deco-gradient {
    position: absolute;
    top: -100px;
    right: -100px;
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, rgba(82,193,122,0.04) 0%, transparent 70%);
    pointer-events: none;
  }
  .tv2-stack__deco-line {
    position: absolute;
    left: 50%;
    top: 0;
    width: 1px;
    height: 80px;
    background: linear-gradient(to bottom, #D5E8D4, transparent);
    pointer-events: none;
  }
  .tv2-stack__container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }
  .tv2-stack__header {
    text-align: center;
    margin-bottom: 4rem;
  }
  .tv2-stack__header .tv2-mono-label {
    display: inline-block;
  }
  .tv2-stack__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 800;
    color: #1a2e1a;
    margin: 0 0 1rem;
    letter-spacing: -0.02em;
  }
  .tv2-stack__subtitle {
    font-size: 1.05rem;
    color: #5D6D7E;
    margin: 0;
    max-width: 520px;
    margin-left: auto;
    margin-right: auto;
    line-height: 1.6;
  }
  .tv2-stack__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }
  .tv2-tech-card {
    position: relative;
    padding: 2.5rem;
    background: #fff;
    border: 1px solid #eef0f2;
    transition: all 0.4s ease;
    overflow: hidden;
  }
  .tv2-tech-card:hover {
    border-color: #D5E8D4;
    box-shadow: 0 12px 40px rgba(26, 46, 26, 0.06);
    transform: translateY(-3px);
  }
  .tv2-tech-card__icon {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    border: 1px solid #D5E8D4;
    color: #1a2e1a;
    margin-bottom: 1.5rem;
    transition: all 0.4s ease;
  }
  .tv2-tech-card:hover .tv2-tech-card__icon {
    background: #52C17A;
    border-color: #52C17A;
    color: #fff;
  }
  .tv2-tech-card__name {
    font-size: 1.05rem;
    font-weight: 700;
    color: #1a2e1a;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0 0 0.8rem;
  }
  .tv2-tech-card__desc {
    font-size: 0.9rem;
    color: #5D6D7E;
    margin: 0;
    line-height: 1.7;
  }
  .tv2-tech-card__hover-line {
    position: absolute;
    bottom: 0;
    left: 0;
    height: 2px;
    width: 0;
    background: #52C17A;
    transition: width 0.5s ease;
  }
  .tv2-tech-card:hover .tv2-tech-card__hover-line {
    width: 100%;
  }

  /* ===== SECURITY ===== */
  .tv2-security {
    position: relative;
    padding: 7rem 2rem;
    background: #1a2e1a;
    overflow: hidden;
  }
  .tv2-security__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(255,255,255,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.03) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }
  .tv2-security__container {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
  }
  .tv2-security__title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    font-weight: 900;
    color: #fff;
    margin: 0 0 1.2rem;
    letter-spacing: -0.02em;
    line-height: 1.15;
    text-transform: uppercase;
  }
  .tv2-security__desc {
    font-size: 0.95rem;
    color: rgba(213, 232, 212, 0.8);
    line-height: 1.75;
    margin: 0 0 2.5rem;
  }
  .tv2-security__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    padding: 1rem 2.2rem;
    background: transparent;
    color: #fff;
    font-family: 'JetBrains Mono', 'Fira Code', monospace;
    font-weight: 600;
    font-size: 0.75rem;
    text-decoration: none;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    border: 1px solid rgba(255, 255, 255, 0.25);
    transition: all 0.3s ease;
  }
  .tv2-security__btn:hover {
    background: #52C17A;
    border-color: #52C17A;
    color: #1a2e1a;
  }
  .tv2-security__visual {
    position: relative;
  }
  .tv2-security__img {
    width: 100%;
    height: 380px;
    object-fit: cover;
    display: block;
    opacity: 0.85;
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .tv2-hero__container {
      grid-template-columns: 1fr;
      gap: 3rem;
    }
    .tv2-hero__visual { display: none; }
    .tv2-security__container {
      grid-template-columns: 1fr;
    }
    .tv2-security__visual { display: none; }
  }
  @media (max-width: 768px) {
    .tv2-certs__grid {
      grid-template-columns: 1fr 1fr;
    }
    .tv2-stack__grid {
      grid-template-columns: 1fr;
    }
    .tv2-hero__deco-circle { display: none; }
  }
  @media (max-width: 480px) {
    .tv2-certs__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const title = 'Senior Customer Service Representative';
const department = 'Operations';
const location = 'Bogotá, Colombia';
const type = 'Full-time';
const summary = "We're looking for an experienced customer service professional to join our growing team. You'll lead by example, handling complex customer interactions while mentoring junior team members.";
const responsibilities = [
  'Handle escalated customer inquiries across multiple channels',
  'Mentor and train new team members',
  'Maintain 95%+ customer satisfaction ratings',
  'Collaborate with QA team on service improvement',
  'Provide bilingual support in English and Spanish',
];
const requirements = [
  '3+ years in customer service or BPO environment',
  'Fluent in English and Spanish (written and verbal)',
  'Experience with CRM platforms (Salesforce, Zendesk)',
  'Strong problem-solving and de-escalation skills',
  'Availability for rotating shifts including weekends',
];
const benefits = [
  { icon: 'trending-up', text: 'Competitive salary + performance bonuses' },
  { icon: 'heart', text: 'Health insurance and wellness programs' },
  { icon: 'award', text: 'Career development and training opportunities' },
  { icon: 'monitor', text: 'Modern office in Bogotá with hybrid options' },
];
---

<!-- V2 — Editorial Enterprise: JobDetail -->
<section class="d2-job-detail bg-white">

  <!-- HERO -->
  <div class="relative overflow-hidden bg-white pt-32">
    <div class="d2-jd-grid-pattern"></div>
    <div class="max-w-7xl mx-auto px-6 py-24 lg:py-32 relative z-10">
      <a href={getLocalizedPath('/careers', lang)}
         class="inline-flex items-center gap-2 font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] mb-10 hover:text-[#1a2e1a] transition-colors"
         data-sa="fade-up">
        <span class="rotate-180"><Icon name="arrow-right" class="w-3 h-3" /></span>
        // BACK TO CAREERS
      </a>

      <div>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A]">// JOB OPENING</span>
        <h1 class="font-black tracking-[-0.04em] leading-[0.9] uppercase text-[#1a2e1a] text-4xl md:text-6xl lg:text-7xl mt-4 mb-6" data-sa="fade-up">
          SENIOR CUSTOMER<br/>SERVICE<br/>REPRESENTATIVE
        </h1>
        <div class="w-12 h-[2px] bg-[#52C17A] mb-8"></div>
      </div>

      <!-- Metadata row -->
      <div class="flex flex-wrap gap-8 border-t border-b border-[#1a2e1a]/10 py-5" data-sa="fade-up" data-sa-delay="100">
        <div class="flex items-center gap-2">
          <Icon name="briefcase" class="w-4 h-4 text-[#52C17A]" />
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#2C3E50]">{department}</span>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="map-pin" class="w-4 h-4 text-[#52C17A]" />
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#2C3E50]">{location}</span>
        </div>
        <div class="flex items-center gap-2">
          <Icon name="clock" class="w-4 h-4 text-[#52C17A]" />
          <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#2C3E50]">{type}</span>
        </div>
      </div>

      <!-- Summary -->
      <div class="mt-10 max-w-3xl" data-sa="fade-up" data-sa-delay="200">
        <p class="text-lg lg:text-xl text-[#5D6D7E] font-light leading-relaxed">{summary}</p>
      </div>
    </div>
  </div>

  <!-- RESPONSIBILITIES -->
  <div class="border-t border-[#1a2e1a]/10">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28">
      <div>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A]">// RESPONSIBILITIES</span>
        <div class="w-12 h-[2px] bg-[#52C17A] mt-3 mb-8"></div>
      </div>
      <div class="space-y-0">
        {responsibilities.map((item, i) => (
          <div class="d2-jd-list-item border-b border-[#1a2e1a]/10 py-7 flex items-start gap-6" data-sa="fade-up" data-sa-delay={`${i * 80}`}>
            <span class="font-mono text-[10px] tracking-[0.2em] text-[#52C17A] mt-1.5 flex-shrink-0 w-8">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-lg text-[#2C3E50] leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- REQUIREMENTS -->
  <div class="border-t border-[#1a2e1a]/10 bg-[#FAFAF8]">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28">
      <div>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A]">// REQUIREMENTS</span>
        <div class="w-12 h-[2px] bg-[#52C17A] mt-3 mb-8"></div>
      </div>
      <div class="space-y-0">
        {requirements.map((item, i) => (
          <div class="d2-jd-list-item border-b border-[#1a2e1a]/10 py-7 flex items-start gap-6" data-sa="fade-up" data-sa-delay={`${i * 80}`}>
            <span class="font-mono text-[10px] tracking-[0.2em] text-[#52C17A] mt-1.5 flex-shrink-0 w-8">
              {String(i + 1).padStart(2, '0')}
            </span>
            <span class="text-lg text-[#2C3E50] leading-relaxed">{item}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- BENEFITS -->
  <div class="border-t border-[#1a2e1a]/10">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28">
      <div>
        <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A]">// WHAT WE OFFER</span>
        <div class="w-12 h-[2px] bg-[#52C17A] mt-3 mb-10"></div>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-0">
        {benefits.map((b, i) => (
          <div class="d2-jd-benefit-card sa-hover-lift border border-[#1a2e1a]/10 p-8 flex items-start gap-5 group transition-colors duration-300 hover:bg-[#1a2e1a] hover:text-white cursor-default" data-sa="fade-up" data-sa-delay={`${i * 80}`}>
            <span class="flex-shrink-0 w-10 h-10 border border-[#52C17A] flex items-center justify-center group-hover:bg-[#52C17A] group-hover:border-[#52C17A] transition-colors duration-300">
              <Icon name={b.icon} class="w-5 h-5 text-[#52C17A] group-hover:text-white transition-colors duration-300" />
            </span>
            <span class="text-[#2C3E50] group-hover:text-white transition-colors duration-300 text-lg leading-relaxed">{b.text}</span>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- APPLY CTA -->
  <div class="border-t border-[#1a2e1a]/10" data-sa="scale-in">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28 text-center">
      <span class="font-mono text-[10px] uppercase tracking-[0.2em] text-[#52C17A] block mb-4">// APPLY NOW</span>
      <h2 class="font-bold tracking-[-0.03em] leading-[0.95] text-[#1a2e1a] text-3xl md:text-4xl lg:text-5xl mb-6" data-sa="fade-up">
        Ready to Join<br/>Our Team?
      </h2>
      <div class="w-12 h-[2px] bg-[#52C17A] mx-auto mb-8"></div>
      <p class="text-lg text-[#5D6D7E] font-light max-w-xl mx-auto mb-10">
        Take the next step in your career. Apply today and become part of a team that values growth, innovation, and excellence.
      </p>
      <a href={getLocalizedPath('/contact', lang)}
         class="d2-jd-apply-btn inline-flex items-center gap-3 px-10 py-4 font-bold text-lg uppercase tracking-wide">
        APPLY NOW
        <Icon name="arrow-right" class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>

<style>
  /* Grid pattern */
  .d2-jd-grid-pattern {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(26, 46, 26, 0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(26, 46, 26, 0.04) 1px, transparent 1px);
    background-size: 60px 60px;
    pointer-events: none;
  }

  /* List item hover */
  .d2-jd-list-item {
    transition: padding-left 0.3s ease, background-color 0.3s ease;
  }
  .d2-jd-list-item:hover {
    padding-left: 1rem;
    background-color: rgba(213, 232, 212, 0.15);
  }

  /* Apply button (sharp) */
  .d2-jd-apply-btn {
    background: #1a2e1a;
    color: white;
    transition: all 0.3s ease;
  }
  .d2-jd-apply-btn:hover {
    background: #52C17A;
    color: #1a2e1a;
  }
</style>

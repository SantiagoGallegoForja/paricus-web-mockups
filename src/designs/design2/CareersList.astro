---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const heading = 'Join Our Growing Team';
const description = 'Build your career with a company that values innovation, diversity, and professional growth.';
const benefits = [
  { icon: 'rocket', title: 'Career Growth', description: 'Clear advancement paths with mentorship and continuous learning opportunities.' },
  { icon: 'heart', title: 'Inclusive Culture', description: 'A diverse and welcoming workplace where every voice matters and ideas thrive.' },
  { icon: 'gift', title: 'Great Benefits', description: 'Competitive compensation, health coverage, and flexible work arrangements.' },
  { icon: 'book-open', title: 'Continuous Training', description: 'Access to industry certifications, workshops, and professional development programs.' },
];
const jobOpenings = [
  { title: 'Senior Customer Service Representative', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: true, slug: 'senior-customer-service', summary: 'Lead our customer service team and deliver exceptional multilingual support experiences.' },
  { title: 'Back Office Analyst', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'back-office-analyst', summary: 'Process and manage critical business documents with precision and efficiency.' },
  { title: 'Sales Development Representative', department: 'Sales', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'sales-development-rep', summary: 'Drive revenue growth through strategic outbound campaigns and lead qualification.' },
  { title: 'Technical Support Engineer', department: 'Technology', location: 'Bogota, Colombia', type: 'Full-time', featured: true, slug: 'technical-support-engineer', summary: 'Provide expert-level technical assistance for complex software and hardware issues.' },
  { title: 'Quality Assurance Specialist', department: 'Operations', location: 'Bogota, Colombia', type: 'Full-time', featured: false, slug: 'qa-specialist', summary: 'Monitor and improve service quality across all customer interaction channels.' },
];
---

<!-- V2 — Editorial Enterprise: Sharp corners, monospace labels, border grids, editorial typography -->
<section class="d2-careers-page bg-white">

  <!-- HERO -->
  <div class="d2-careers-hero relative overflow-hidden bg-white">
    <div class="d2c-grid-pattern"></div>
    <div class="max-w-7xl mx-auto px-6 py-28 lg:py-40 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 items-center">
        <!-- Left: Text -->
        <div data-sa="slide-right">
          <span class="d2c-mono-label">// CAREERS</span>
          <h1 class="d2c-editorial-title" data-sa="fade-up">
            JOIN OUR<br/>GROWING<br/>TEAM
          </h1>
          <div class="d2c-accent-line"></div>
          <p class="max-w-xl text-lg text-[#5D6D7E] font-light leading-relaxed mt-8">
            {description}
          </p>
          <div class="flex flex-wrap gap-4 mt-10">
            <a href="#positions" class="d2c-btn-sharp inline-flex items-center gap-3 px-8 py-4 font-semibold">
              VIEW POSITIONS <Icon name="arrow-down" class="w-4 h-4" />
            </a>
            <a href={getLocalizedPath('/about', lang)} class="d2c-btn-sharp-outline inline-flex items-center gap-3 px-8 py-4 font-semibold">
              ABOUT US
            </a>
          </div>
        </div>

        <!-- Right: Image with editorial styling -->
        <div class="hidden lg:block relative" data-sa="slide-left">
          <div class="d2c-hero-img-wrapper">
            <div class="d2c-hero-img-border"></div>
            <img
              src="https://images.unsplash.com/photo-1522071820081-009f0129c71c?w=600&h=500&fit=crop"
              alt="Team collaboration at Paricus"
              loading="eager"
              class="d2c-hero-img"
              data-sa="fade-in"
            />
            <!-- Floating card -->
            <div class="d2c-hero-float-card">
              <p class="font-mono text-[9px] uppercase tracking-[0.2em] text-[#5D6D7E] mb-1">// Team</p>
              <p class="text-2xl font-black text-[#1a2e1a] tracking-tight leading-none">100+</p>
              <p class="text-xs text-[#5D6D7E] mt-0.5">Professionals</p>
            </div>
          </div>
        </div>
      </div>
    </div>

    <!-- Benefits row -->
    <div class="max-w-7xl mx-auto px-6 pb-20 relative z-10">
      <div class="d2c-benefits-row">
        {benefits.map((b, i) => (
          <div class={`d2c-benefit-item ${i < benefits.length - 1 ? 'd2c-benefit-item--bordered' : ''}`} data-sa="fade-up" data-sa-delay={`${i * 100}`}>
            <div class="d2c-benefit-icon-box">
              <Icon name={b.icon} class="w-5 h-5 text-[#52C17A]" />
            </div>
            <div>
              <h3 class="font-bold text-[#1a2e1a] text-sm tracking-wide uppercase">{b.title}</h3>
              <p class="text-xs text-[#5D6D7E] mt-1 leading-relaxed max-w-[200px]">{b.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </div>

  <!-- JOB OPENINGS -->
  <div id="positions" class="max-w-7xl mx-auto px-6 py-16 lg:py-24">
    <div class="mb-14">
      <span class="d2c-mono-label">// OPEN POSITIONS</span>
      <h2 class="text-3xl lg:text-4xl font-bold text-[#1a2e1a] tracking-tight mt-3" data-sa="fade-up">Current Openings</h2>
    </div>

    <!-- Card-based listings -->
    <div class="d2c-jobs-list grid grid-cols-1 md:grid-cols-2 gap-6">
      {jobOpenings.map((job, i) => (
        <a href={getLocalizedPath('/careers/' + job.slug, lang)}
           class="d2c-job-card sa-hover-lift group border border-[#D5E8D4] p-8 lg:p-10 transition-all duration-300 hover:bg-[#1a2e1a] hover:border-[#1a2e1a]"
           data-sa="fade-up" data-sa-delay={`${i * 80}`}>
          <div class="flex items-center justify-between mb-4">
            <span class="font-mono text-xs uppercase tracking-wider text-[#5D6D7E] group-hover:text-[#52C17A] transition-colors">
              {job.department}
            </span>
            {job.featured && <span class="w-2.5 h-2.5 rounded-full bg-[#52C17A] inline-block"></span>}
          </div>

          <h3 class="text-xl lg:text-2xl font-bold text-[#1a2e1a] group-hover:text-white transition-colors leading-tight mb-3">
            {job.title}
          </h3>

          <p class="text-sm text-[#5D6D7E] group-hover:text-white/60 transition-colors leading-relaxed mb-6">
            {job.summary}
          </p>

          <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
              <span class="text-xs text-[#5D6D7E] group-hover:text-gray-400 transition-colors">
                {job.location}
              </span>
              <span class="text-xs text-[#5D6D7E] group-hover:text-gray-400 transition-colors">
                {job.type}
              </span>
            </div>
            <Icon name="arrow-right" class="w-5 h-5 text-[#D5E8D4] group-hover:text-[#52C17A] group-hover:translate-x-1 transition-all" />
          </div>
        </a>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="d2c-cta-section" data-sa="scale-in">
    <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28">
      <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-8">
        <div>
          <span class="d2c-mono-label d2c-mono-label--light">// GET IN TOUCH</span>
          <h3 class="text-3xl lg:text-4xl font-black text-white tracking-tight mt-3">
            Don't see<br/>your role?
          </h3>
          <p class="text-gray-400 mt-4 max-w-md font-light">We're always looking for exceptional talent. Reach out and let's explore possibilities together.</p>
        </div>
        <a href={getLocalizedPath('/contact', lang)} class="d2c-btn-sharp-light inline-flex items-center gap-3 px-10 py-4 font-semibold">
          CONTACT US <Icon name="arrow-right" class="w-4 h-4" />
        </a>
      </div>
    </div>
  </div>
</section>

<style>
  /* Grid pattern */
  .d2c-grid-pattern {
    position: absolute; inset: 0;
    background-image:
      linear-gradient(rgba(29,53,29,.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(29,53,29,.04) 1px, transparent 1px);
    background-size: 60px 60px;
  }

  /* Mono label */
  .d2c-mono-label {
    font-family: ui-monospace, SFMono-Regular, 'SF Mono', Menlo, monospace;
    font-size: 0.8rem; letter-spacing: 0.15em; color: #52C17A;
    font-weight: 600; text-transform: uppercase;
  }
  .d2c-mono-label--light { color: #52C17A; }

  /* Editorial title */
  .d2c-editorial-title {
    font-size: clamp(2.8rem, 7vw, 6rem);
    font-weight: 900; line-height: 0.95; letter-spacing: -0.03em;
    color: #1a2e1a; margin-top: 1rem;
  }

  /* Accent line */
  .d2c-accent-line {
    width: 80px; height: 4px; background: #52C17A; margin-top: 1.5rem;
  }

  /* Buttons */
  .d2c-btn-sharp {
    background: #1a2e1a; color: #fff; border: 2px solid #1a2e1a;
    letter-spacing: 0.08em; font-size: 0.85rem;
    transition: background .2s, color .2s;
  }
  .d2c-btn-sharp:hover { background: #52C17A; border-color: #52C17A; }
  .d2c-btn-sharp-outline {
    background: transparent; color: #1a2e1a; border: 2px solid #1a2e1a;
    letter-spacing: 0.08em; font-size: 0.85rem;
    transition: background .2s, color .2s;
  }
  .d2c-btn-sharp-outline:hover { background: #1a2e1a; color: #fff; }
  .d2c-btn-sharp-light {
    background: #52C17A; color: #1a2e1a; border: 2px solid #52C17A;
    letter-spacing: 0.08em; font-size: 0.85rem;
    transition: background .2s, color .2s, border-color .2s;
  }
  .d2c-btn-sharp-light:hover { background: transparent; color: #fff; border-color: #fff; }

  /* Benefits row */
  .d2c-benefits-row {
    display: flex; flex-wrap: wrap; gap: 0;
    border-top: 1px solid #D5E8D4; border-bottom: 1px solid #D5E8D4;
  }
  .d2c-benefit-item {
    flex: 1; min-width: 200px;
    display: flex; align-items: flex-start; gap: 12px;
    padding: 20px 24px;
  }
  .d2c-benefit-item--bordered {
    border-right: 1px solid #D5E8D4;
  }
  @media (max-width: 767px) {
    .d2c-benefit-item--bordered { border-right: none; border-bottom: 1px solid #D5E8D4; }
    .d2c-benefit-item { min-width: 100%; }
  }
  .d2c-benefit-icon-box {
    width: 36px; height: 36px; flex-shrink: 0;
    border: 1px solid #D5E8D4; display: flex; align-items: center; justify-content: center;
  }

  /* Job cards */
  .d2c-job-card {
    text-decoration: none;
    color: inherit;
  }

  /* Hero image */
  .d2c-hero-img-wrapper {
    position: relative;
    max-width: 500px;
    margin-left: auto;
  }
  .d2c-hero-img-border {
    position: absolute;
    top: -12px;
    right: -12px;
    width: 100%;
    height: 100%;
    border: 2px solid #52C17A;
    pointer-events: none;
  }
  .d2c-hero-img {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 420px;
    object-fit: cover;
    display: block;
  }
  .d2c-hero-float-card {
    position: absolute;
    bottom: -16px;
    left: -16px;
    z-index: 2;
    background: #fff;
    border: 2px solid #1a2e1a;
    padding: 1rem 1.4rem;
  }

  /* CTA section */
  .d2c-cta-section {
    background: #1a2e1a;
  }
</style>

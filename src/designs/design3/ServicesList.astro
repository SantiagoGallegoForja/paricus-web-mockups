---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';
import { placeholderImages } from '../../data/placeholder-images';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const ctaBg = placeholderImages.office[0];

const services = [
  {
    icon: 'headphones',
    title: 'Customer Service',
    description: 'Multilingual, omnichannel customer support that builds lasting relationships and drives satisfaction at every touchpoint.',
    slug: 'customer-service',
  },
  {
    icon: 'layers',
    title: 'Back Office Operations',
    description: 'Streamline administrative processes with accurate, efficient back-office support that keeps your business running smoothly.',
    slug: 'customer-service',
  },
  {
    icon: 'cpu',
    title: 'Technology Solutions',
    description: 'Modern technology infrastructure and automation tools that enhance productivity and enable data-driven decisions.',
    slug: 'customer-service',
  },
  {
    icon: 'shield',
    title: 'Quality Assurance',
    description: 'Rigorous quality frameworks and continuous monitoring to ensure consistent, high-standard service delivery.',
    slug: 'customer-service',
  },
];
---

<!-- V3 — High-Contrast Premium -->
<div data-design="3">

  <!-- ─── SECTION 1: HEADER (LIGHT) ─────────────────────────────────────── -->
  <section class="sl-header">
    <div class="sl-container">
      <div class="sl-header__inner">
        <span class="sl-label">What we do</span>
        <div class="sl-accent-line"></div>
        <h2 class="sl-heading" data-sa="fade-up">Our Services</h2>
        <p class="sl-subheading" data-sa="fade-up" data-sa-delay="100">
          Comprehensive BPO solutions designed to optimize your operations and accelerate growth.
        </p>
      </div>
    </div>
  </section>

  <!-- ─── SECTION 2: SERVICE CARDS (LIGHT ALT) ─────────────────────────── -->
  <section class="sl-cards-section">
    <div class="sl-container">
      <div class="sl-grid">
        {services.map((service, i) => (
          <a
            href={getLocalizedPath('/services/' + service.slug, lang)}
            class="sl-card"
            data-sa="fade-up"
            data-sa-delay={`${i * 80}`}
          >
            <div class="sl-card__icon-wrap">
              <Icon name={service.icon} class="sl-card__icon" />
            </div>
            <h3 class="sl-card__title">{service.title}</h3>
            <p class="sl-card__desc">{service.description}</p>
            <span class="sl-card__link">
              Learn more
              <Icon name="arrow-right" class="sl-card__link-arrow" />
            </span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ─── SECTION 3: CTA (DARK) ─────────────────────────────────────────── -->
  <section
    class="sl-cta"
    style={`--cta-bg: url('${ctaBg.url}')`}
    data-sa="scale-in"
  >
    <div class="sl-cta__overlay"></div>
    <div class="sl-container sl-cta__inner">
      <h3 class="sl-cta__heading">Ready to scale your operations?</h3>
      <p class="sl-cta__sub">Let's discuss how we can help your business grow.</p>
      <a href={getLocalizedPath('/contact', lang)} class="sl-cta__btn">
        Get Started
        <Icon name="arrow-right" class="sl-cta__btn-arrow" />
      </a>
    </div>
  </section>

</div>

<style>
  /* ── Shared ────────────────────────────────────────────────────────────── */
  .sl-container {
    max-width: 68rem;
    margin-inline: auto;
    padding-inline: 1.5rem;
  }

  /* ── Section 1 · Header ────────────────────────────────────────────────── */
  .sl-header {
    background: #fff;
    padding-top: 10rem;
    padding-bottom: 4rem;
  }

  .sl-header__inner {
    max-width: 42rem;
  }

  .sl-label {
    display: inline-block;
    font-family: ui-monospace, 'Cascadia Code', 'Fira Code', monospace;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #52C17A;
    margin-bottom: 1.25rem;
  }

  .sl-accent-line {
    width: 2.5rem;
    height: 3px;
    border-radius: 2px;
    background: #52C17A;
    margin-bottom: 1.5rem;
  }

  .sl-heading {
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #111115;
    margin-bottom: 1rem;
    line-height: 1.15;
  }

  .sl-subheading {
    font-size: 1.0625rem;
    line-height: 1.7;
    color: #5D6D7E;
    max-width: 36rem;
  }

  /* ── Section 2 · Service Cards ─────────────────────────────────────────── */
  .sl-cards-section {
    background: #FAFAF8;
    padding-top: 3rem;
    padding-bottom: 5rem;
  }

  .sl-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
  }

  @media (min-width: 768px) {
    .sl-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 1.5rem;
    }
  }

  .sl-card {
    display: block;
    background: #fff;
    border: 1px solid #E5E7EB;
    border-radius: 12px;
    padding: 1.75rem 2rem;
    text-decoration: none;
    transition: border-color 0.2s ease, box-shadow 0.2s ease, transform 0.2s ease;
  }

  .sl-card:hover {
    border-color: #52C17A;
    box-shadow: 0 8px 24px rgba(82, 193, 122, 0.08);
    transform: translateY(-2px);
  }

  .sl-card__icon-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.75rem;
    height: 2.75rem;
    border-radius: 10px;
    background: rgba(82, 193, 122, 0.08);
    margin-bottom: 1.25rem;
    color: #52C17A;
  }

  .sl-card__icon {
    width: 1.25rem;
    height: 1.25rem;
  }

  .sl-card__title {
    font-size: 1.0625rem;
    font-weight: 600;
    letter-spacing: -0.01em;
    color: #111115;
    margin-bottom: 0.5rem;
  }

  .sl-card__desc {
    font-size: 0.9rem;
    line-height: 1.65;
    color: #5D6D7E;
    margin-bottom: 1.25rem;
  }

  .sl-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-size: 0.875rem;
    font-weight: 500;
    color: #52C17A;
    transition: gap 0.2s ease;
  }

  .sl-card:hover .sl-card__link {
    gap: 0.625rem;
  }

  .sl-card__link-arrow {
    width: 0.875rem;
    height: 0.875rem;
  }

  /* ── Section 3 · CTA ────────────────────────────────────────────────────── */
  .sl-cta {
    position: relative;
    background-image: var(--cta-bg);
    background-size: cover;
    background-position: center;
    padding-top: 5rem;
    padding-bottom: 5rem;
  }

  .sl-cta__overlay {
    position: absolute;
    inset: 0;
    background: rgba(17, 17, 21, 0.82);
  }

  .sl-cta__inner {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1rem;
  }

  @media (min-width: 640px) {
    .sl-cta__inner {
      flex-direction: row;
      align-items: center;
      justify-content: space-between;
    }
  }

  .sl-cta__heading {
    font-size: 1.375rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .sl-cta__sub {
    font-size: 0.9375rem;
    color: rgba(255, 255, 255, 0.65);
  }

  .sl-cta__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.8125rem 1.75rem;
    border-radius: 8px;
    background: #52C17A;
    color: #fff;
    font-size: 0.9375rem;
    font-weight: 600;
    text-decoration: none;
    white-space: nowrap;
    flex-shrink: 0;
    transition: background 0.2s ease, transform 0.2s ease;
  }

  .sl-cta__btn:hover {
    background: #3dab66;
    transform: translateY(-1px);
  }

  .sl-cta__btn-arrow {
    width: 1rem;
    height: 1rem;
  }
</style>

---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const title = 'Customer Service';
const icon = 'headphones';
const description = 'Deliver exceptional customer experiences with our dedicated bilingual support teams trained in your brand voice and processes.';
const features = [
  { name: '24/7 Multichannel Support', description: 'Round-the-clock assistance across phone, email, chat, and social media channels.' },
  { name: 'Bilingual English/Spanish Teams', description: 'Native-level agents fluent in both languages for seamless communication.' },
  { name: 'Custom CRM Integration', description: 'Deep integration with your existing tools and workflows for unified operations.' },
  { name: 'Quality Assurance Programs', description: 'Continuous monitoring and coaching to maintain the highest service standards.' },
  { name: 'Scalable Team Models', description: 'Flexible staffing that grows or contracts with your business demands.' },
];
const benefits = [
  { stat: '40%', label: 'Cost Reduction' },
  { stat: '95%', label: 'Customer Satisfaction' },
  { stat: '24/7', label: 'Coverage' },
  { stat: '100%', label: 'Seamless Integration' },
];
const useCases = [
  { title: 'E-commerce Support', description: 'Handle order inquiries, returns, and product questions with speed and empathy across all your sales channels.' },
  { title: 'Healthcare Patient Services', description: 'Manage appointment scheduling, insurance verification, and patient follow-ups with HIPAA-compliant processes.' },
  { title: 'SaaS Technical Assistance', description: 'Provide expert onboarding support, troubleshooting, and account management for your software users.' },
];
---

<!-- V3 — High-Contrast Premium: ServiceDetail -->

<!-- HERO — DARK #111115 -->
<section class="sd3-hero">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32" style="padding-top: 10rem;">
    <a href={getLocalizedPath('/services', lang)}
       class="sd3-back-link inline-flex items-center gap-2 text-sm font-medium mb-10">
      <span class="rotate-180"><Icon name="arrow-right" class="w-4 h-4" /></span>
      Back to Services
    </a>

    <div class="flex flex-col items-start max-w-3xl">
      <div class="sd3-icon-container w-14 h-14 rounded-xl flex items-center justify-center mb-8" data-sa="fade-in">
        <Icon name={icon} class="w-7 h-7 sd3-icon" />
      </div>

      <h1 class="text-4xl md:text-5xl lg:text-6xl font-bold tracking-tight text-[#FAFAFA] leading-[1.1] mb-4" data-sa="fade-up">
        {title}
      </h1>
      <div class="sd3-accent-line mb-6"></div>
      <p class="text-lg text-[#A1A1AA] leading-relaxed max-w-2xl" data-sa="fade-up" data-sa-delay="100">
        {description}
      </p>
    </div>
  </div>
</section>

<!-- FEATURES — LIGHT #fff -->
<section class="sd3-features-section">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#111115] mb-4" data-sa="fade-up">
        What We Deliver
      </h2>
      <p class="text-[#5D6D7E] max-w-xl" data-sa="fade-up" data-sa-delay="100">
        Comprehensive capabilities designed to elevate every customer interaction.
      </p>
    </div>
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-4">
      {features.map((feature, i) => (
        <div class="sd3-feature-cell rounded-xl p-8"
             data-sa="fade-up"
             data-sa-delay={`${i * 100}`}>
          <div class="flex items-center gap-3 mb-4">
            <span class="w-1.5 h-1.5 rounded-full bg-[#52C17A] flex-shrink-0"></span>
            <h3 class="text-base font-semibold text-[#111115]">{feature.name}</h3>
          </div>
          <p class="text-sm text-[#5D6D7E] leading-relaxed">{feature.description}</p>
        </div>
      ))}
      <div class="sd3-feature-cell rounded-xl p-8 flex items-center justify-center"
           data-sa="fade-up"
           data-sa-delay={`${features.length * 100}`}>
        <div class="text-center">
          <div class="text-lg font-semibold text-[#111115] mb-1">And More</div>
          <p class="text-sm text-[#5D6D7E]">Custom solutions for your needs</p>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- BENEFITS — DARK #111115 -->
<section class="sd3-benefits-section">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32">
    <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#FAFAFA] mb-12" data-sa="fade-up">
      Key Benefits
    </h2>
    <div class="grid grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((benefit, i) => (
        <div class="sd3-benefit-card rounded-xl p-6 lg:p-8 text-center"
             data-sa="fade-up"
             data-sa-delay={`${i * 60}`}>
          <div class="text-3xl lg:text-4xl font-bold text-[#52C17A] mb-2">{benefit.stat}</div>
          <div class="text-sm text-[#A1A1AA] font-medium">{benefit.label}</div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- USE CASES — LIGHT #FAFAF8 -->
<section class="sd3-usecases-section">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32">
    <div class="mb-16">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#111115] mb-4" data-sa="fade-up">
        Use Cases
      </h2>
      <p class="text-[#5D6D7E] max-w-xl" data-sa="fade-up" data-sa-delay="100">
        See how our customer service solutions drive results across industries.
      </p>
    </div>
    <div class="grid md:grid-cols-3 gap-6">
      {useCases.map((uc, i) => (
        <div class="sd3-usecase-card rounded-xl p-8 sa-hover-lift"
             data-sa="fade-up"
             data-sa-delay={`${i * 80}`}>
          <div class="sd3-usecase-icon-container w-10 h-10 rounded-lg flex items-center justify-center mb-5">
            <Icon name="target" class="w-5 h-5 sd3-usecase-icon" />
          </div>
          <h3 class="text-lg font-semibold text-[#111115] mb-3">{uc.title}</h3>
          <p class="text-sm text-[#5D6D7E] leading-relaxed">{uc.description}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- CTA — DARK #111115 -->
<section class="sd3-cta-section">
  <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32">
    <div class="sd3-cta rounded-xl p-12 lg:p-16 text-center" data-sa="scale-in">
      <h2 class="text-3xl md:text-4xl font-bold tracking-tight text-[#FAFAFA] mb-4">
        Ready to Transform Your Customer Experience?
      </h2>
      <p class="text-[#A1A1AA] max-w-2xl mx-auto mb-10 text-lg">
        Let us build a dedicated support team tailored to your brand and customers.
      </p>
      <a href={getLocalizedPath('/contact', lang)}
         class="sd3-btn-primary inline-flex items-center gap-2 px-8 py-3.5 rounded-lg font-semibold text-base transition-all duration-200">
        Get Started <Icon name="arrow-right" class="w-4 h-4" />
      </a>
    </div>
  </div>
</section>

<style>
  /* === V3 High-Contrast Premium — ServiceDetail === */

  /* HERO — Dark */
  .sd3-hero {
    background: #111115;
    border-bottom: 1px solid #E5E7EB;
  }

  .sd3-back-link {
    color: #52C17A;
    transition: opacity 0.2s ease;
  }
  .sd3-back-link:hover {
    opacity: 0.8;
  }

  .sd3-icon-container {
    background: rgba(82, 193, 122, 0.1);
  }
  .sd3-icon {
    color: #52C17A;
  }

  .sd3-accent-line {
    width: 3rem;
    height: 3px;
    background: #52C17A;
    border-radius: 2px;
  }

  /* FEATURES — Light */
  .sd3-features-section {
    background: #fff;
  }

  .sd3-feature-cell {
    background: #FAFAF8;
    border: 1px solid #E5E7EB;
    transition: border-color 0.2s ease;
  }
  .sd3-feature-cell:hover {
    border-color: #52C17A;
  }

  /* BENEFITS — Dark */
  .sd3-benefits-section {
    background: #111115;
  }

  .sd3-benefit-card {
    background: #1a1a1f;
    border: 1px solid rgba(255, 255, 255, 0.06);
    transition: border-color 0.2s ease;
  }
  .sd3-benefit-card:hover {
    border-color: rgba(82, 193, 122, 0.3);
  }

  /* USE CASES — Light */
  .sd3-usecases-section {
    background: #FAFAF8;
  }

  .sd3-usecase-card {
    background: #fff;
    border: 1px solid #E5E7EB;
    transition: border-color 0.2s ease;
  }
  .sd3-usecase-card:hover {
    border-color: #52C17A;
  }

  .sd3-usecase-icon-container {
    background: rgba(82, 193, 122, 0.1);
  }
  .sd3-usecase-icon {
    color: #52C17A;
  }

  /* CTA — Dark */
  .sd3-cta-section {
    background: #111115;
  }

  .sd3-cta {
    background: #1a1a1f;
    border: 1px solid rgba(255, 255, 255, 0.06);
  }

  /* CTA button — Green */
  .sd3-btn-primary {
    background: #52C17A;
    color: #fff;
  }
  .sd3-btn-primary:hover {
    background: #3da863;
  }
</style>

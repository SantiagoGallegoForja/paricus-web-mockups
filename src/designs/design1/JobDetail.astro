---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';
interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const title = 'Senior Customer Service Representative';
const department = 'Operations';
const location = 'Bogotá, Colombia';
const type = 'Full-time';
const summary = "We're looking for an experienced customer service professional to join our growing team. You'll lead by example, handling complex customer interactions while mentoring junior team members.";
const responsibilities = [
  'Handle escalated customer inquiries across multiple channels',
  'Mentor and train new team members',
  'Maintain 95%+ customer satisfaction ratings',
  'Collaborate with QA team on service improvement',
  'Provide bilingual support in English and Spanish',
];
const requirements = [
  '3+ years in customer service or BPO environment',
  'Fluent in English and Spanish (written and verbal)',
  'Experience with CRM platforms (Salesforce, Zendesk)',
  'Strong problem-solving and de-escalation skills',
  'Availability for rotating shifts including weekends',
];
const benefits = [
  { icon: 'trending-up', text: 'Competitive salary + performance bonuses' },
  { icon: 'heart', text: 'Health insurance and wellness programs' },
  { icon: 'award', text: 'Career development and training opportunities' },
  { icon: 'monitor', text: 'Modern office in Bogotá with hybrid options' },
];
---

<!-- V1 — Modern Corporate: JobDetail -->
<section class="d1-job-detail">

  <!-- HERO -->
  <div class="d1-jd-hero relative overflow-hidden pt-32">
    <div class="d1-jd-orb d1-jd-orb--1"></div>
    <div class="d1-jd-orb d1-jd-orb--2"></div>
    <div class="max-w-[1200px] mx-auto px-6 py-24 lg:py-32 relative z-10">
      <a href={getLocalizedPath('/careers', lang)}
         class="inline-flex items-center gap-2 text-[#52C17A] font-semibold mb-8 hover:gap-3 transition-all">
        <span class="rotate-180"><Icon name="arrow-right" class="w-4 h-4" /></span>
        Back to Careers
      </a>
      <div>
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#2C3E50] leading-tight mb-6" data-sa="fade-up">
          {title}
        </h1>
        <div class="flex flex-wrap gap-3 mb-8" data-sa="fade-up" data-sa-delay="100">
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl bg-[#E8F5E9] text-[#3D9E5F] text-sm font-semibold">
            <Icon name="briefcase" class="w-4 h-4" />
            {department}
          </span>
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl bg-[#E8F5E9] text-[#3D9E5F] text-sm font-semibold">
            <Icon name="map-pin" class="w-4 h-4" />
            {location}
          </span>
          <span class="inline-flex items-center gap-2 px-4 py-2 rounded-2xl bg-[#E8F5E9] text-[#3D9E5F] text-sm font-semibold">
            <Icon name="clock" class="w-4 h-4" />
            {type}
          </span>
        </div>
      </div>
    </div>
  </div>

  <!-- SUMMARY CARD -->
  <div class="max-w-[1200px] mx-auto px-6 -mt-8 relative z-20">
    <div class="d1-jd-glass rounded-3xl p-8 lg:p-10" data-sa="fade-up">
      <h2 class="text-xl font-bold text-[#2C3E50] mb-3" data-sa="fade-up">About This Role</h2>
      <p class="text-lg text-[#5D6D7E] leading-relaxed">{summary}</p>
    </div>
  </div>

  <!-- CONTENT: 2-column -->
  <div class="max-w-[1200px] mx-auto px-6 py-16 lg:py-24">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-10">

      <!-- Left: Responsibilities & Requirements -->
      <div class="lg:col-span-2 space-y-12" data-sa="slide-right">

        <!-- Responsibilities -->
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold text-[#2C3E50] mb-6" data-sa="fade-up">Responsibilities</h2>
          <ul class="space-y-4">
            {responsibilities.map((item, i) => (
              <li class="flex items-start gap-4" data-sa="fade-up" data-sa-delay={`${i * 100}`}>
                <span class="flex-shrink-0 w-8 h-8 rounded-xl bg-[#E8F5E9] flex items-center justify-center mt-0.5">
                  <Icon name="check-circle" class="w-5 h-5 text-[#52C17A]" />
                </span>
                <span class="text-[#5D6D7E] text-lg leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>

        <!-- Requirements -->
        <div>
          <h2 class="text-2xl lg:text-3xl font-bold text-[#2C3E50] mb-6" data-sa="fade-up">Requirements</h2>
          <ul class="space-y-4">
            {requirements.map((item, i) => (
              <li class="flex items-start gap-4" data-sa="fade-up" data-sa-delay={`${i * 100}`}>
                <span class="flex-shrink-0 w-8 h-8 rounded-xl bg-[#E8F5E9] flex items-center justify-center mt-0.5">
                  <Icon name="star" class="w-5 h-5 text-[#52C17A]" />
                </span>
                <span class="text-[#5D6D7E] text-lg leading-relaxed">{item}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Right: Benefits sidebar -->
      <div class="lg:col-span-1" data-sa="slide-left">
        <div class="d1-jd-glass rounded-3xl p-8 sticky top-36">
          <h3 class="text-xl font-bold text-[#2C3E50] mb-6">What We Offer</h3>
          <div class="space-y-5">
            {benefits.map((b, i) => (
              <div class="flex items-start gap-4" data-sa="fade-up" data-sa-delay={`${i * 100}`}>
                <span class="flex-shrink-0 w-10 h-10 rounded-2xl bg-gradient-to-br from-[#52C17A] to-[#3D9E5F] flex items-center justify-center">
                  <Icon name={b.icon} class="w-5 h-5 text-white" />
                </span>
                <span class="text-[#5D6D7E] leading-relaxed">{b.text}</span>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- APPLY CTA -->
  <div class="max-w-[1200px] mx-auto px-6 pb-24 lg:pb-32">
    <div class="d1-jd-cta-card rounded-3xl p-10 lg:p-16 text-center" data-sa="scale-in">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-[#2C3E50] mb-4" data-sa="fade-up">Ready to Join Us?</h2>
      <p class="text-lg text-[#5D6D7E] mb-8 max-w-xl mx-auto">
        Take the next step in your career. Apply today and become part of a team that values growth, innovation, and excellence.
      </p>
      <a href={getLocalizedPath('/contact', lang)}
         class="d1-jd-apply-btn inline-flex items-center gap-3 px-10 py-4 rounded-full text-white font-bold text-lg">
        Apply Now
        <Icon name="arrow-right" class="w-5 h-5" />
      </a>
    </div>
  </div>
</section>

<style>
  /* Hero background */
  .d1-jd-hero {
    background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 40%, #FFF8E7 100%);
  }

  /* Floating orbs */
  .d1-jd-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0.4;
    pointer-events: none;
  }
  .d1-jd-orb--1 {
    width: 400px; height: 400px;
    background: radial-gradient(circle, #52C17A 0%, transparent 70%);
    top: -100px; right: -100px;
  }
  .d1-jd-orb--2 {
    width: 300px; height: 300px;
    background: radial-gradient(circle, #FFF8E7 0%, transparent 70%);
    bottom: -80px; left: -60px;
  }

  /* Glass card */
  .d1-jd-glass {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(82, 193, 122, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
  }

  /* CTA card */
  .d1-jd-cta-card {
    background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 50%, #FFF8E7 100%);
    border: 1px solid rgba(82, 193, 122, 0.15);
  }

  /* Apply button with glow */
  .d1-jd-apply-btn {
    background: linear-gradient(135deg, #52C17A, #3D9E5F);
    box-shadow: 0 4px 20px rgba(82, 193, 122, 0.4);
    transition: all 0.3s ease;
  }
  .d1-jd-apply-btn:hover {
    box-shadow: 0 8px 40px rgba(82, 193, 122, 0.55);
    transform: translateY(-2px);
  }
</style>

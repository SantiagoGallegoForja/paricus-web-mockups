---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const heading = 'Industries We Serve';
const description = 'Specialized expertise across diverse sectors, delivering tailored outsourcing solutions that understand your unique challenges.';
const industries = [
  { icon: 'heart', title: 'Healthcare', description: 'Supporting patient care with compassionate, HIPAA-compliant support services that maintain the highest standards of data security.' },
  { icon: 'package', title: 'E-Commerce', description: 'Scaling your online business with seamless customer experiences across every channel and touchpoint.' },
  { icon: 'cpu', title: 'Technology', description: 'Technical support that speaks your customers\' language, from troubleshooting to advanced product guidance.' },
  { icon: 'landmark', title: 'Finance', description: 'Secure, compliant support for financial services with rigorous attention to regulatory requirements.' },
  { icon: 'shopping-bag', title: 'Travel & Hospitality', description: 'Creating memorable experiences from first contact, with multilingual support that delights guests worldwide.' },
];
---

<!-- ============================================================
     DESIGN V1 — INDUSTRIES (Modern Corporate)
     Rounded corners, glass-morphism, gradient backgrounds
     ============================================================ -->

<!-- ==================== SECTION 1: PAGE HERO ==================== -->
<section
  class="relative overflow-hidden py-32 lg:py-40"
  style="clip-path: polygon(0 0, 100% 0, 100% 92%, 0 100%); background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 40%, #E8F5E9 100%);"
>
  <!-- Animated gradient background layer -->
  <div class="absolute inset-0 d1-gradient-shift opacity-20" data-sa="fade-in"></div>

  <!-- Floating decorative orbs -->
  <div class="absolute top-[10%] left-[5%] w-72 h-72 rounded-full d1-float opacity-20" style="background: radial-gradient(circle, #52C17A, transparent 70%);"></div>
  <div class="absolute bottom-[15%] right-[8%] w-96 h-96 rounded-full d1-float opacity-15" style="background: radial-gradient(circle, #4DB6AC, transparent 70%); animation-delay: 2s;"></div>
  <div class="absolute top-[40%] right-[30%] w-48 h-48 rounded-full d1-float opacity-10" style="background: radial-gradient(circle, #3D9E5F, transparent 70%); animation-delay: 4s;"></div>

  <div class="relative z-10 max-w-5xl mx-auto px-6 lg:px-16 text-center">
    <div data-sa="fade-up">
      <span class="inline-block px-5 py-2 rounded-full text-sm font-semibold tracking-wide mb-6" style="background: rgba(82,193,122,0.15); color: #3D9E5F;">
        Our Expertise
      </span>
    </div>

    <h1 class="text-5xl lg:text-7xl font-extrabold tracking-tight mb-8" data-sa="fade-up" data-sa-delay="120">
      <span style="color: #2C3E50;">Industries</span>
      <br />
      <span class="bg-clip-text text-transparent" style="background-image: linear-gradient(135deg, #3D9E5F, #3A9A94);">
        We Serve
      </span>
    </h1>

    <p class="text-lg lg:text-xl max-w-2xl mx-auto" data-sa="fade-up" data-sa-delay="240" style="color: #5D6D7E;">
      {description}
    </p>
  </div>
</section>

<!-- ==================== SECTION 2: INDUSTRIES CARDS ==================== -->
<section class="relative py-24 lg:py-32" style="background: #FAFAF8;">
  <!-- Subtle floating orbs in background -->
  <div class="absolute top-[20%] left-[2%] w-64 h-64 rounded-full d1-float opacity-5" style="background: radial-gradient(circle, #52C17A, transparent 70%); animation-delay: 1s;"></div>
  <div class="absolute bottom-[10%] right-[5%] w-80 h-80 rounded-full d1-float opacity-5" style="background: radial-gradient(circle, #4DB6AC, transparent 70%); animation-delay: 3s;"></div>

  <div class="relative z-10 max-w-7xl mx-auto px-6 lg:px-16">
    <!-- Top row: 2 large cards -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 mb-8">
      {industries.slice(0, 2).map((industry, i) => (
        <div
          class="group relative p-10 lg:p-12 rounded-3xl overflow-hidden d1-card-glass transition-all duration-500 hover:scale-[1.02] hover:shadow-2xl"
          data-sa="fade-up"
          data-sa-delay={`${i * 80}`}
        >
          <!-- Card gradient bg on hover -->
          <div class="absolute inset-0 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(135deg, rgba(82,193,122,0.08), rgba(77,182,172,0.08));"></div>

          <div class="relative z-10">
            <div class="w-16 h-16 rounded-2xl flex items-center justify-center mb-6 transition-all duration-500 group-hover:scale-110 group-hover:rotate-6" style="background: linear-gradient(135deg, #52C17A, #4DB6AC);">
              <Icon name={industry.icon} class="w-8 h-8 text-white" />
            </div>
            <h3 class="text-2xl lg:text-3xl font-bold mb-4" style="color: #2C3E50;">{industry.title}</h3>
            <p class="text-base lg:text-lg leading-relaxed" style="color: #5D6D7E;">{industry.description}</p>
          </div>
        </div>
      ))}
    </div>

    <!-- Bottom row: 3 cards, same width as top row -->
    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      {industries.slice(2).map((industry, i) => (
        <div
          class="group relative p-8 lg:p-10 rounded-2xl overflow-hidden d1-card-glass transition-all duration-500 hover:scale-[1.03] hover:shadow-xl"
          data-sa="fade-up"
          data-sa-delay={`${(i + 2) * 80}`}
        >
          <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="background: linear-gradient(135deg, rgba(82,193,122,0.08), rgba(77,182,172,0.08));"></div>

          <div class="relative z-10">
            <div class="w-14 h-14 rounded-xl flex items-center justify-center mb-5 transition-all duration-500 group-hover:scale-110 group-hover:rotate-6" style="background: linear-gradient(135deg, #52C17A, #3D9E5F);">
              <Icon name={industry.icon} class="w-7 h-7 text-white" />
            </div>
            <h3 class="text-xl lg:text-2xl font-bold mb-3" style="color: #2C3E50;">{industry.title}</h3>
            <p class="text-sm lg:text-base leading-relaxed" style="color: #5D6D7E;">{industry.description}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- ==================== SECTION 3: CTA ==================== -->
<section class="relative py-24 lg:py-32 overflow-hidden" style="background: linear-gradient(135deg, #52C17A, #3D9E5F, #4DB6AC);">
  <!-- Floating decorative circles -->
  <div class="absolute top-[10%] left-[10%] w-40 h-40 rounded-full border-2 border-white/20 d1-float"></div>
  <div class="absolute bottom-[15%] right-[12%] w-56 h-56 rounded-full border-2 border-white/10 d1-float" style="animation-delay: 2.5s;"></div>
  <div class="absolute top-[50%] left-[60%] w-24 h-24 rounded-full bg-white/5 d1-float" style="animation-delay: 1.5s;"></div>

  <div class="relative z-10 max-w-3xl mx-auto px-6 text-center" data-sa="scale-in">
    <h2 class="text-3xl lg:text-5xl font-extrabold text-white mb-6 tracking-tight" data-sa="fade-up">
      Ready to Transform Your Industry?
    </h2>
    <p class="text-lg text-white/80 mb-10 max-w-xl mx-auto">
      Let us show you how tailored outsourcing solutions can drive growth and efficiency in your sector.
    </p>
    <a
      href={getLocalizedPath('/contact', lang)}
      class="inline-flex items-center gap-3 px-10 py-4 rounded-2xl text-lg font-bold transition-all duration-300 hover:scale-105 hover:shadow-2xl"
      style="background: white; color: #3D9E5F;"
    >
      Get in Touch
      <Icon name="arrow-right" class="w-5 h-5" />
    </a>
  </div>
</section>

<style>
  /* Float animation */
  @keyframes d1-float {
    0%, 100% { transform: translateY(0px) rotate(0deg); }
    33% { transform: translateY(-20px) rotate(2deg); }
    66% { transform: translateY(10px) rotate(-1deg); }
  }
  .d1-float {
    animation: d1-float 8s ease-in-out infinite;
  }

  /* Gradient shift */
  @keyframes d1-gradient-shift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }
  .d1-gradient-shift {
    background: linear-gradient(270deg, #d4f0dc, #cce8e5, #f0f7f0, #d4f0dc);
    background-size: 400% 400%;
    animation: d1-gradient-shift 12s ease infinite;
  }

  /* Glass-morphism card */
  .d1-card-glass {
    background: rgba(255, 255, 255, 0.7);
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(82, 193, 122, 0.15);
    box-shadow: 0 8px 32px rgba(0, 0, 0, 0.06);
  }
</style>

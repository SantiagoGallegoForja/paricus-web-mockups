---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const heading = 'Technology & Compliance';
const description = 'Enterprise-grade technology and security standards that power exceptional business operations.';
const certifications = [
  { name: 'ISO 27001', description: 'Information Security Management' },
  { name: 'ISO 9001', description: 'Quality Management Systems' },
  { name: 'HIPAA', description: 'Healthcare Data Protection' },
  { name: 'SOC 2 Type II', description: 'Service Organization Controls' },
];
const technologies = [
  { icon: 'shield', name: 'Enterprise Security', description: 'Multi-layer security protocols protecting your data at every touchpoint.' },
  { icon: 'zap', name: 'AI-Powered Tools', description: 'Smart automation enhancing agent productivity and customer satisfaction.' },
  { icon: 'database', name: 'Real-time Analytics', description: 'Live dashboards and performance insights for data-driven decisions.' },
  { icon: 'cloud', name: 'Cloud Infrastructure', description: 'Scalable, redundant cloud architecture ensuring 99.9% uptime.' },
];
const securityTitle = 'Your Data, Our Priority';
const securityDescription = 'We maintain the highest standards of data security and compliance, ensuring your sensitive information is protected with enterprise-grade protocols and regular third-party audits.';
---

<!-- V1 — Modern Corporate -->
<section class="tech-v1">

  <!-- HERO — Two columns with image -->
  <div class="tech-v1__hero">
    <div class="tech-v1__hero-bg sa-parallax" data-sa="fade-in"></div>
    <!-- Decorative dots pattern -->
    <div class="tech-v1__dots tech-v1__dots--left"></div>
    <div class="tech-v1__dots tech-v1__dots--right"></div>

    <div class="tech-v1__hero-inner">
      <div class="tech-v1__hero-text" data-sa="slide-right">
        <span class="tech-v1__hero-badge">Technology & Compliance</span>
        <h1 class="tech-v1__hero-title" data-sa="fade-up">{heading}</h1>
        <p class="tech-v1__hero-desc">{description}</p>
        <!-- Cert badges inline -->
        <div class="tech-v1__cert-strip">
          {certifications.map((cert) => (
            <div class="tech-v1__cert-badge">
              <Icon name="shield-check" class="w-4 h-4" />
              <span>{cert.name}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="tech-v1__hero-visual" data-sa="slide-left">
        <img
          src="https://images.unsplash.com/photo-1518770660439-4636190af475?w=600&h=700&fit=crop"
          alt="Technology and circuits"
          loading="lazy"
          class="tech-v1__hero-img"
          data-sa="fade-in"
        />
        <!-- Floating card on image -->
        <div class="tech-v1__hero-float">
          <div class="tech-v1__hero-float-icon">
            <Icon name="shield" class="w-6 h-6 text-white" />
          </div>
          <div>
            <div class="tech-v1__hero-float-value">99.9%</div>
            <div class="tech-v1__hero-float-label">Uptime SLA</div>
          </div>
        </div>
      </div>
    </div>
    <div class="tech-v1__hero-clip"></div>
  </div>

  <!-- TECH STACK — Cards grid with background decoration -->
  <div class="tech-v1__stack">
    <!-- Background decoration -->
    <div class="tech-v1__stack-orb tech-v1__stack-orb--1"></div>
    <div class="tech-v1__stack-orb tech-v1__stack-orb--2"></div>

    <div class="tech-v1__stack-header">
      <div class="tech-v1__accent-line"></div>
      <h2 class="tech-v1__section-title" data-sa="fade-up">Our Technology Stack</h2>
      <p class="tech-v1__section-subtitle">Enterprise-grade tools and infrastructure powering your operations.</p>
    </div>

    <div class="tech-v1__stack-grid">
      {technologies.map((tech, i) => (
        <div class="tech-v1__stack-card" data-sa="fade-up" data-sa-delay={`${i * 80}`}>
          <div class="tech-v1__stack-card-icon">
            <Icon name={tech.icon} size={28} />
          </div>
          <h3 class="tech-v1__stack-card-name">{tech.name}</h3>
          <p class="tech-v1__stack-card-desc">{tech.description}</p>
          <div class="tech-v1__stack-card-num">{String(i + 1).padStart(2, '0')}</div>
        </div>
      ))}
    </div>
  </div>

  <!-- CERTIFICATIONS — Full-width image + overlay cards -->
  <div class="tech-v1__certs-section">
    <div class="tech-v1__certs-inner">
      <div class="tech-v1__certs-content" data-sa="slide-right">
        <div class="tech-v1__accent-line"></div>
        <h2 class="tech-v1__section-title" style="color: #fff;" data-sa="fade-up">Certifications & Standards</h2>
        <p class="tech-v1__certs-desc">We maintain the highest levels of compliance and security across every engagement.</p>
        <div class="tech-v1__certs-list">
          {certifications.map((cert, i) => (
            <div class="tech-v1__certs-item" data-sa="fade-up" data-sa-delay={`${i * 100}`}>
              <div class="tech-v1__certs-check">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
                  <polyline points="20 6 9 17 4 12"></polyline>
                </svg>
              </div>
              <div>
                <div class="tech-v1__certs-name">{cert.name}</div>
                <div class="tech-v1__certs-label">{cert.description}</div>
              </div>
            </div>
          ))}
        </div>
      </div>
      <div class="tech-v1__certs-img-col" data-sa="slide-left">
        <img
          src="https://images.unsplash.com/photo-1550751827-4bd374c3f58b?w=600&h=500&fit=crop"
          alt="Digital security"
          loading="lazy"
          class="tech-v1__certs-img"
          data-sa="fade-in"
        />
      </div>
    </div>
  </div>

  <!-- SECURITY CTA -->
  <div class="tech-v1__cta" data-sa="scale-in">
    <div class="tech-v1__cta-circle tech-v1__cta-circle--1"></div>
    <div class="tech-v1__cta-circle tech-v1__cta-circle--2"></div>
    <div class="tech-v1__cta-inner">
      <div class="tech-v1__cta-shield">
        <Icon name="shield" size={48} />
      </div>
      <h2 class="tech-v1__cta-title" data-sa="fade-up">{securityTitle}</h2>
      <p class="tech-v1__cta-desc">{securityDescription}</p>
      <a href={getLocalizedPath('/contact', lang)} class="tech-v1__cta-btn">Get Started</a>
    </div>
  </div>
</section>

<style>
  /* ===== HERO ===== */
  .tech-v1__hero {
    position: relative;
    padding: 8rem 2rem 12rem;
    overflow: hidden;
  }
  .tech-v1__hero-bg {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 40%, #D5E8D4 100%);
    z-index: 0;
  }
  .tech-v1__dots {
    position: absolute; z-index: 0;
    width: 200px; height: 200px;
    background-image: radial-gradient(circle, rgba(82,193,122,0.15) 1.5px, transparent 1.5px);
    background-size: 16px 16px;
  }
  .tech-v1__dots--left { top: 15%; left: 3%; }
  .tech-v1__dots--right { bottom: 20%; right: 3%; }
  .tech-v1__hero-clip {
    position: absolute; bottom: -2px; left: 0; right: 0;
    height: 120px; background: #FAFAF8;
    clip-path: polygon(0 60%, 100% 0, 100% 100%, 0 100%);
    z-index: 3;
  }
  .tech-v1__hero-inner {
    position: relative; z-index: 2;
    max-width: 1200px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
  }
  .tech-v1__hero-badge {
    display: inline-block;
    padding: 0.4rem 1.2rem;
    background: rgba(82,193,122,0.12);
    border-radius: 999px;
    font-size: 0.8rem; font-weight: 600;
    color: #3D9E5F;
    letter-spacing: 0.06em; text-transform: uppercase;
    margin-bottom: 1.5rem;
  }
  .tech-v1__hero-title {
    font-size: clamp(2.4rem, 5vw, 3.6rem);
    font-weight: 800; color: #2C3E50;
    line-height: 1.1; margin: 0 0 1.2rem;
  }
  .tech-v1__hero-desc {
    font-size: 1.1rem; color: #5D6D7E;
    line-height: 1.7; margin: 0 0 2rem; max-width: 480px;
  }
  .tech-v1__cert-strip {
    display: flex; flex-wrap: wrap; gap: 0.6rem;
  }
  .tech-v1__cert-badge {
    display: inline-flex; align-items: center; gap: 6px;
    padding: 0.4rem 0.9rem; border-radius: 999px;
    background: #fff; border: 1px solid rgba(82,193,122,0.2);
    font-size: 0.78rem; font-weight: 600; color: #3D9E5F;
    box-shadow: 0 2px 8px rgba(0,0,0,0.04);
  }
  .tech-v1__hero-visual {
    position: relative;
  }
  .tech-v1__hero-img {
    width: 100%; height: 480px;
    object-fit: cover; border-radius: 24px;
    box-shadow: 0 24px 60px rgba(44,62,80,0.12);
  }
  .tech-v1__hero-float {
    position: absolute; bottom: -20px; left: -20px;
    display: flex; align-items: center; gap: 12px;
    padding: 14px 20px; border-radius: 16px;
    background: rgba(255,255,255,0.92); backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.7);
    box-shadow: 0 12px 40px rgba(44,62,80,0.1);
  }
  .tech-v1__hero-float-icon {
    width: 44px; height: 44px; border-radius: 12px;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #52C17A, #4DB6AC);
  }
  .tech-v1__hero-float-value {
    font-size: 1.4rem; font-weight: 800; color: #2C3E50;
  }
  .tech-v1__hero-float-label {
    font-size: 0.75rem; color: #5D6D7E;
  }

  /* ===== SECTION SHARED ===== */
  .tech-v1__section-title {
    font-size: clamp(1.8rem, 3.5vw, 2.4rem);
    font-weight: 800; color: #2C3E50; margin: 0 0 0.5rem;
  }
  .tech-v1__section-subtitle {
    font-size: 1.05rem; color: #5D6D7E; margin: 0; line-height: 1.6;
  }
  .tech-v1__accent-line {
    width: 40px; height: 4px; border-radius: 4px;
    background: linear-gradient(90deg, #52C17A, #4DB6AC);
    margin-bottom: 1rem;
  }

  /* ===== TECH STACK ===== */
  .tech-v1__stack {
    position: relative;
    background: #FAFAF8;
    padding: 6rem 2rem;
    overflow: hidden;
  }
  .tech-v1__stack-orb {
    position: absolute; border-radius: 50%;
    filter: blur(80px); opacity: 0.15; pointer-events: none;
  }
  .tech-v1__stack-orb--1 {
    width: 400px; height: 400px; background: #52C17A;
    top: -100px; right: -100px;
  }
  .tech-v1__stack-orb--2 {
    width: 300px; height: 300px; background: #4DB6AC;
    bottom: -80px; left: -80px;
  }
  .tech-v1__stack-header {
    position: relative; z-index: 1;
    max-width: 600px; margin: 0 auto 3.5rem; text-align: center;
  }
  .tech-v1__stack-header .tech-v1__accent-line { margin: 0 auto 1rem; }
  .tech-v1__stack-grid {
    position: relative; z-index: 1;
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: repeat(4, 1fr); gap: 1.5rem;
  }
  .tech-v1__stack-card {
    position: relative;
    background: rgba(255,255,255,0.8);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(82,193,122,0.12);
    border-radius: 20px; padding: 2rem 1.5rem;
    transition: transform 0.4s ease, box-shadow 0.4s ease, border-color 0.4s ease;
    overflow: hidden;
  }
  .tech-v1__stack-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 48px rgba(82,193,122,0.15);
    border-color: #52C17A;
  }
  .tech-v1__stack-card-icon {
    width: 56px; height: 56px; border-radius: 16px;
    display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #52C17A, #4DB6AC);
    color: #fff; margin-bottom: 1.2rem;
    transition: transform 0.4s ease;
  }
  .tech-v1__stack-card:hover .tech-v1__stack-card-icon {
    transform: rotate(8deg) scale(1.08);
  }
  .tech-v1__stack-card-name {
    font-size: 1.1rem; font-weight: 700;
    color: #2C3E50; margin: 0 0 0.5rem;
  }
  .tech-v1__stack-card-desc {
    font-size: 0.88rem; color: #5D6D7E;
    line-height: 1.6; margin: 0;
  }
  .tech-v1__stack-card-num {
    position: absolute; top: 12px; right: 16px;
    font-size: 2.5rem; font-weight: 900;
    color: rgba(82,193,122,0.07); line-height: 1;
    pointer-events: none;
  }

  /* ===== CERTIFICATIONS ===== */
  .tech-v1__certs-section {
    background: #2C3E50;
    padding: 5rem 2rem;
    overflow: hidden;
  }
  .tech-v1__certs-inner {
    max-width: 1100px; margin: 0 auto;
    display: grid; grid-template-columns: 1fr 1fr;
    gap: 4rem; align-items: center;
  }
  .tech-v1__certs-content .tech-v1__accent-line {
    background: linear-gradient(90deg, #52C17A, #4DB6AC);
  }
  .tech-v1__certs-desc {
    font-size: 1.05rem; color: rgba(255,255,255,0.7);
    line-height: 1.7; margin: 0 0 2rem; max-width: 440px;
  }
  .tech-v1__certs-list {
    display: flex; flex-direction: column; gap: 1rem;
  }
  .tech-v1__certs-item {
    display: flex; align-items: center; gap: 14px;
    padding: 12px 16px; border-radius: 12px;
    background: rgba(255,255,255,0.06);
    border: 1px solid rgba(255,255,255,0.08);
    transition: background 0.3s ease, border-color 0.3s ease;
  }
  .tech-v1__certs-item:hover {
    background: rgba(82,193,122,0.12);
    border-color: rgba(82,193,122,0.3);
  }
  .tech-v1__certs-check {
    width: 32px; height: 32px; flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
    border-radius: 8px;
    background: rgba(82,193,122,0.2); color: #52C17A;
  }
  .tech-v1__certs-name {
    font-size: 0.95rem; font-weight: 700; color: #fff;
  }
  .tech-v1__certs-label {
    font-size: 0.8rem; color: rgba(255,255,255,0.5);
  }
  .tech-v1__certs-img {
    width: 100%; height: 380px;
    object-fit: cover; border-radius: 20px;
    box-shadow: 0 16px 48px rgba(0,0,0,0.25);
    opacity: 0.9;
  }

  /* ===== CTA ===== */
  .tech-v1__cta {
    position: relative;
    background: linear-gradient(135deg, #52C17A 0%, #3D9E5F 50%, #4DB6AC 100%);
    padding: 5rem 2rem; text-align: center; overflow: hidden;
  }
  .tech-v1__cta-circle {
    position: absolute; border-radius: 50%;
    background: rgba(255,255,255,0.07); pointer-events: none;
  }
  .tech-v1__cta-circle--1 { width: 300px; height: 300px; top: -80px; left: -60px; animation: techV1Float 8s ease-in-out infinite; }
  .tech-v1__cta-circle--2 { width: 200px; height: 200px; bottom: -40px; right: 10%; animation: techV1Float 6s ease-in-out infinite 1s; }
  .tech-v1__cta-inner { position: relative; z-index: 1; max-width: 640px; margin: 0 auto; }
  .tech-v1__cta-shield {
    width: 80px; height: 80px;
    display: flex; align-items: center; justify-content: center;
    background: rgba(255,255,255,0.15); border-radius: 50%;
    color: #fff; margin: 0 auto 1.5rem; backdrop-filter: blur(6px);
  }
  .tech-v1__cta-title {
    font-size: clamp(1.8rem, 4vw, 2.6rem);
    font-weight: 800; color: #fff; margin: 0 0 1rem;
  }
  .tech-v1__cta-desc {
    font-size: 1.05rem; color: rgba(255,255,255,0.9);
    line-height: 1.7; margin: 0 0 2rem;
  }
  .tech-v1__cta-btn {
    display: inline-block; padding: 0.9rem 2.4rem;
    background: #fff; color: #3D9E5F;
    font-weight: 700; font-size: 1rem;
    border-radius: 999px; text-decoration: none;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  .tech-v1__cta-btn:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .tech-v1__hero-inner { grid-template-columns: 1fr; }
    .tech-v1__hero-visual { display: none; }
    .tech-v1__stack-grid { grid-template-columns: repeat(2, 1fr); }
    .tech-v1__certs-inner { grid-template-columns: 1fr; }
    .tech-v1__certs-img-col { display: none; }
  }
  @media (max-width: 640px) {
    .tech-v1__stack-grid { grid-template-columns: 1fr; }
    .tech-v1__cert-strip { flex-direction: column; }
  }

  /* ===== ANIMATIONS ===== */
  @keyframes techV1Float {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-20px) scale(1.05); }
  }
</style>

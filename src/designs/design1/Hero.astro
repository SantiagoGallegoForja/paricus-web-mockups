---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

// Hardcoded content - no Strapi dependency
const badge = 'Your Trusted BPO Partner';
const title = 'Transform Your Operations with';
const titleHighlight = 'Friendly';
const titleEnd = 'Outsourcing';
const description = 'Paricus helps global companies streamline operations, improve efficiency, and scale with confidence through nearshore BPO solutions from Colombia.';
const primaryButtonText = 'Explore Services';
const secondaryButtonText = 'Get in Touch';
const stats = [
  { value: '100+', label: 'Team Members' },
  { value: '15+', label: 'Years Experience' },
  { value: '98%', label: 'Satisfaction Rate' },
];
const services = [
  { icon: 'headphones', title: 'Customer Service', shortDescription: 'Multilingual customer support that builds lasting relationships and drives satisfaction across every channel.', slug: 'customer-service' },
  { icon: 'file-text', title: 'Back Office Operations', shortDescription: 'Streamline your administrative processes with accurate, efficient back-office support that keeps your business running smoothly.', slug: 'back-office' },
  { icon: 'calculator', title: 'Sales & Lead Generation', shortDescription: 'Accelerate your revenue pipeline with skilled sales teams and proven lead generation strategies.', slug: 'sales-lead-generation' },
  { icon: 'wrench', title: 'Technical Support', shortDescription: 'Expert technical assistance that resolves issues quickly and keeps your customers productive.', slug: 'technical-support' },
];
const industries = [
  { icon: 'heart', title: 'Healthcare', description: 'HIPAA-compliant support services' },
  { icon: 'package', title: 'E-Commerce', description: 'Seamless customer experiences' },
  { icon: 'cpu', title: 'Technology', description: 'Technical support excellence' },
  { icon: 'landmark', title: 'Finance', description: 'Secure financial services support' },
  { icon: 'shopping-bag', title: 'Travel & Hospitality', description: 'Memorable guest experiences' },
];
---

<!-- ============================================================
     DESIGN V1 — HERO
     ============================================================ -->

  <!-- ==================== SECTION 1: HERO ==================== -->
  <section
    class="relative min-h-screen flex items-center overflow-hidden"
    role="banner"
    aria-label="Hero section"
    style="clip-path: polygon(0 0, 100% 0, 100% 92%, 0 100%);"
  >
    <!-- Animated gradient background -->
    <div
      class="absolute inset-0 animate-gradient sa-parallax"
      style="background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 25%, #FFF8E7 50%, #E8F5E9 75%, #FAFAF8 100%); background-size: 200% 200%;"
      aria-hidden="true"
      data-sa="fade-in"
    ></div>

    <!-- Mesh-like moving patterns -->
    <div class="absolute inset-0 overflow-hidden" aria-hidden="true">
      <div
        class="absolute -top-40 -right-40 w-[700px] h-[700px] rounded-full animate-float opacity-20"
        style="background: radial-gradient(circle, #52C17A 0%, transparent 70%);"
      ></div>
      <div
        class="absolute -bottom-60 -left-40 w-[600px] h-[600px] rounded-full animate-float-delayed opacity-15"
        style="background: radial-gradient(circle, #4DB6AC 0%, transparent 70%);"
      ></div>
      <div
        class="absolute top-1/3 right-1/4 w-[400px] h-[400px] rounded-full animate-float opacity-10"
        style="background: radial-gradient(circle, #52C17A 0%, transparent 60%); animation-duration: 8s;"
      ></div>
    </div>

    <!-- Decorative floating circles -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[15%] left-[10%] w-3 h-3 bg-[#52C17A] rounded-full animate-float opacity-40"></div>
      <div class="absolute top-[25%] right-[15%] w-4 h-4 bg-[#4DB6AC] rounded-full animate-float-delayed opacity-30"></div>
      <div class="absolute bottom-[30%] left-[20%] w-2 h-2 bg-[#3D9E5F] rounded-full animate-float opacity-35" style="animation-duration: 7s;"></div>
      <div class="absolute top-[60%] right-[25%] w-5 h-5 bg-[#52C17A]/20 rounded-full animate-float-delayed opacity-50" style="animation-duration: 9s;"></div>
      <div class="absolute top-[10%] left-[50%] w-2.5 h-2.5 bg-[#4DB6AC] rounded-full animate-float opacity-25" style="animation-duration: 5s;"></div>
      <div class="absolute bottom-[20%] right-[10%] w-3.5 h-3.5 bg-[#52C17A] rounded-full animate-float opacity-20" style="animation-duration: 10s;"></div>
    </div>

    <!-- Content -->
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10 py-32 lg:py-44 w-full">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-20 items-center">

        <!-- Left: Text -->
        <div>
          <!-- Glass-morphism badge with pulse -->
          <div class="animate-slide-up inline-flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-white/50 backdrop-blur-md border border-white/60 shadow-lg shadow-[#52C17A]/5 mb-10">
            <span class="relative flex h-2.5 w-2.5">
              <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-[#52C17A] opacity-75"></span>
              <span class="relative inline-flex rounded-full h-2.5 w-2.5 bg-[#52C17A]"></span>
            </span>
            <span class="text-sm font-semibold text-[#2C3E50] tracking-wide">{badge}</span>
          </div>

          <!-- Title with gradient highlight -->
          <h1 class="animate-slide-up-1 text-5xl sm:text-6xl lg:text-6xl xl:text-7xl font-extrabold text-[#2C3E50] leading-[1.05] mb-8 tracking-tight" data-sa="fade-up">
            {title}{' '}
            <span
              class="text-transparent bg-clip-text"
              style="background-image: linear-gradient(135deg, #52C17A 0%, #3D9E5F 50%, #4DB6AC 100%);"
            >
              {titleHighlight}
            </span>{' '}
            {titleEnd}
          </h1>

          <!-- Description -->
          <p class="animate-slide-up-2 text-lg lg:text-xl text-[#5D6D7E] leading-relaxed mb-10 max-w-xl">
            {description}
          </p>

          <!-- CTAs -->
          <div class="animate-slide-up-3 flex flex-col sm:flex-row gap-5 mb-14" data-sa="scale-in">
            <a
              href={getLocalizedPath('/services', lang)}
              class="group inline-flex items-center justify-center px-10 py-5 rounded-2xl text-white text-base font-semibold shadow-xl shadow-[#52C17A]/30 hover:shadow-2xl hover:shadow-[#52C17A]/50 hover:scale-[1.03] transition-all duration-300"
              style="background: linear-gradient(135deg, #52C17A 0%, #3D9E5F 100%);"
            >
              {primaryButtonText}
              <Icon name="arrow-right" class="ml-2.5 w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" size={20} aria-hidden="true" />
            </a>
            <a
              href={getLocalizedPath('/contact', lang)}
              class="group inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-white/70 backdrop-blur-sm border-2 border-[#D5E8D4] text-[#2C3E50] text-base font-semibold hover:bg-white hover:border-[#52C17A] hover:shadow-xl hover:scale-[1.03] transition-all duration-300"
            >
              {secondaryButtonText}
              <Icon name="arrow-up-right" class="ml-2 w-5 h-5 opacity-0 -translate-x-2 group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300" size={20} aria-hidden="true" />
            </a>
          </div>

          <!-- Stats -->
          <div class="animate-slide-up-4 flex flex-wrap gap-6">
            {stats.map((stat: { value: string; label: string }, index: number) => (
              <div class="flex-1 min-w-[120px] max-w-[180px] px-5 py-4 rounded-2xl bg-white/50 backdrop-blur-md border border-white/60 shadow-lg shadow-black/5" data-sa="fade-up" data-sa-delay={`${index * 60}`}>
                <div class="text-2xl lg:text-3xl font-extrabold text-transparent bg-clip-text" style="background-image: linear-gradient(135deg, #52C17A, #3D9E5F);">
                  {stat.value}
                </div>
                <div class="text-xs text-[#5D6D7E] font-medium mt-1">{stat.label}</div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Image with floating card -->
        <div class="relative animate-slide-up-2 hidden lg:block" data-sa="slide-left">
          <img
            src="https://images.unsplash.com/photo-1600880292203-757bb62b4baf?w=700&h=800&fit=crop"
            alt="Business team meeting"
            loading="lazy"
            class="w-full h-[520px] object-cover rounded-3xl shadow-2xl"
            data-sa="fade-in"
          />
          <!-- Floating glass card -->
          <div class="absolute -bottom-8 -left-10 px-7 py-6 rounded-2xl bg-white/85 backdrop-blur-xl border border-white/70 shadow-2xl shadow-black/10 max-w-[280px]" style="animation: float 6s ease-in-out infinite;">
            <div class="flex items-center gap-4 mb-3">
              <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, #52C17A, #4DB6AC);">
                <Icon name="trending-up" class="w-6 h-6 text-white" />
              </div>
              <div>
                <div class="text-2xl font-extrabold text-[#2C3E50]">98%</div>
                <div class="text-xs text-[#5D6D7E] font-medium">Client Satisfaction</div>
              </div>
            </div>
            <div class="w-full h-1.5 rounded-full bg-[#E8F5E9]">
              <div class="h-full rounded-full" style="width: 98%; background: linear-gradient(90deg, #52C17A, #4DB6AC);"></div>
            </div>
          </div>
          <!-- Small floating badge top-right -->
          <div class="absolute -top-5 -right-5 px-5 py-3 rounded-xl bg-white/90 backdrop-blur-lg border border-white/60 shadow-xl" style="animation: float 6s ease-in-out infinite 3s;">
            <div class="flex items-center gap-2.5">
              <div class="w-8 h-8 rounded-lg flex items-center justify-center bg-[#E8F5E9]">
                <Icon name="globe" class="w-4 h-4 text-[#52C17A]" />
              </div>
              <div>
                <div class="text-sm font-bold text-[#2C3E50]">15+ Years</div>
                <div class="text-[10px] text-[#5D6D7E]">Experience</div>
              </div>
            </div>
          </div>
        </div>

      </div>
    </div>
  </section>


  <!-- ==================== SECTION 2: SERVICES PREVIEW ==================== -->
  <section class="relative py-24 lg:py-32 bg-[#FAFAF8]" aria-labelledby="services-heading-v1">
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12">

      <!-- Section header -->
      <div class="mb-16 lg:mb-20">
        <div class="w-12 h-1 rounded-full bg-gradient-to-r from-[#52C17A] to-[#4DB6AC] mb-6"></div>
        <h2 id="services-heading-v1" class="text-3xl lg:text-5xl font-extrabold text-[#2C3E50] mb-4 tracking-tight" data-sa="fade-up">
          Our Services
        </h2>
        <p class="text-lg text-[#5D6D7E] max-w-2xl">
          Comprehensive outsourcing solutions tailored to elevate your business operations.
        </p>
      </div>

      <!-- Asymmetric 2x2 grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
        {services.slice(0, 4).map((service: { icon?: string; title: string; shortDescription?: string; slug?: string }, index: number) => (
          <a
            href={getLocalizedPath(`/services/${service.slug || '#'}`, lang)}
            class:list={[
              'd1-service-card group relative flex flex-col p-8 lg:p-10 rounded-3xl transition-all duration-500 overflow-hidden',
              index === 0 ? 'lg:row-span-2 lg:justify-center' : '',
            ]}
            data-sa="fade-up"
            data-sa-delay={`${index * 80}`}
          >
            <div class="relative z-10">
              <!-- Icon in gradient circle -->
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-6 group-hover:rotate-6 transition-transform duration-500" style="background: linear-gradient(135deg, #E8F5E9, #D5E8D4);">
                <Icon name={service.icon || 'briefcase'} class="w-7 h-7 text-[#52C17A]" size={28} aria-hidden="true" />
              </div>

              <!-- Title -->
              <h3 class="text-xl lg:text-2xl font-bold text-[#2C3E50] mb-3 group-hover:text-[#3D9E5F] transition-colors duration-300">
                {service.title}
              </h3>

              <!-- Description -->
              <p class:list={[
                'text-[#5D6D7E] leading-relaxed mb-6',
                index === 0 ? 'text-base lg:text-lg' : 'text-sm lg:text-base',
              ]}>
                {service.shortDescription || ''}
              </p>

              <!-- Hover arrow -->
              <div class="flex items-center text-[#52C17A] font-semibold text-sm opacity-0 translate-x-[-8px] group-hover:opacity-100 group-hover:translate-x-0 transition-all duration-300">
                <span>Learn more</span>
                <Icon name="arrow-right" class="ml-1.5 w-4 h-4 group-hover:translate-x-1 transition-transform duration-300" size={16} aria-hidden="true" />
              </div>
            </div>
          </a>
        ))}
      </div>

      <!-- View All Services link -->
      <div class="mt-14 text-center" data-sa="scale-in">
        <a
          href={getLocalizedPath('/services', lang)}
          class="group inline-flex items-center gap-2 text-[#52C17A] font-semibold text-lg hover:text-[#3D9E5F] transition-colors duration-300"
        >
          View All Services
          <Icon name="arrow-right" class="w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" size={20} aria-hidden="true" />
        </a>
      </div>

    </div>
  </section>


  <!-- ==================== SECTION 3: WHY CHOOSE US ==================== -->
  <section
    class="relative py-24 lg:py-32 overflow-hidden"
    style="clip-path: polygon(0 4%, 100% 0, 100% 96%, 0 100%); background: linear-gradient(180deg, #E8F5E9 0%, #F0FAF2 50%, #E8F5E9 100%);"
    aria-labelledby="why-us-heading-v1"
  >
    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 py-8 lg:py-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-start">

        <!-- Left side: big text -->
        <div class="lg:sticky lg:top-32" data-sa="slide-right">
          <div class="w-12 h-1 rounded-full bg-gradient-to-r from-[#52C17A] to-[#4DB6AC] mb-6"></div>
          <h2 id="why-us-heading-v1" class="text-3xl lg:text-5xl font-extrabold text-[#2C3E50] leading-tight mb-6 tracking-tight" data-sa="fade-up">
            Why Leading Brands Choose Paricus
          </h2>
          <p class="text-lg text-[#5D6D7E] leading-relaxed max-w-lg">
            We combine deep industry expertise with cutting-edge technology to deliver outsourcing solutions that drive measurable results and lasting partnerships.
          </p>
        </div>

        <!-- Right side: value cards -->
        <div class="flex flex-col gap-5">
          {[
            { icon: 'shield-check', title: 'Unmatched Quality', desc: 'Rigorous quality assurance processes ensure consistently excellent service delivery across all touchpoints.' },
            { icon: 'globe', title: 'Global Reach', desc: 'Multilingual teams operating across time zones to provide seamless 24/7 coverage for your customers.' },
            { icon: 'trending-up', title: 'Scalable Solutions', desc: 'Flexible infrastructure that grows with your business, from startups to enterprise-level operations.' },
            { icon: 'zap', title: 'Tech-Forward', desc: 'AI-powered tools and automation integrated into every workflow for maximum efficiency and insight.' },
          ].map((item, index) => (
            <div
              class="group relative p-7 lg:p-8 rounded-2xl bg-white/80 backdrop-blur-sm border border-[#D5E8D4]/50 shadow-sm hover:bg-[#52C17A] hover:border-[#52C17A] hover:shadow-xl hover:-translate-y-1 transition-all duration-500 cursor-default"
              data-sa="fade-up"
              data-sa-delay={`${index * 100}`}
            >
              <div class="flex items-start gap-5">
                <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center bg-[#E8F5E9] group-hover:bg-white/20 transition-colors duration-500">
                  <Icon name={item.icon} class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors duration-500" size={24} aria-hidden="true" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-[#2C3E50] group-hover:text-white mb-2 transition-colors duration-500">
                    {item.title}
                  </h3>
                  <p class="text-sm text-[#5D6D7E] group-hover:text-white/85 leading-relaxed transition-colors duration-500">
                    {item.desc}
                  </p>
                </div>
              </div>
            </div>
          ))}
        </div>

      </div>
    </div>
  </section>


  <!-- ==================== SECTION 4: INDUSTRIES ==================== -->
  <section class="relative py-24 lg:py-32 overflow-hidden" style="background-color: #2C3E50 !important;" aria-labelledby="industries-heading-v1">

    <!-- Decorative gradient orbs -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-0 right-0 w-[500px] h-[500px] rounded-full opacity-10" style="background: radial-gradient(circle, #52C17A, transparent 70%);"></div>
      <div class="absolute bottom-0 left-0 w-[400px] h-[400px] rounded-full opacity-8" style="background: radial-gradient(circle, #4DB6AC, transparent 70%);"></div>
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[300px] rounded-full opacity-5" style="background: radial-gradient(ellipse, #52C17A, transparent 70%);"></div>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10">

      <!-- Section header -->
      <div class="text-center mb-16 lg:mb-20">
        <div class="w-12 h-1 rounded-full bg-gradient-to-r from-[#52C17A] to-[#4DB6AC] mb-6 mx-auto"></div>
        <h2 id="industries-heading-v1" class="text-3xl lg:text-5xl font-extrabold text-white mb-4 tracking-tight" data-sa="fade-up">
          Industries We Serve
        </h2>
        <p class="text-lg text-white/60 max-w-2xl mx-auto">
          Specialized expertise across the sectors that matter most.
        </p>
      </div>

      <!-- Industries grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-5">
        {industries.slice(0, 5).map((industry: { icon?: string; title: string; description?: string }, index: number) => (
          <div
            class="group relative flex flex-col items-center text-center p-8 rounded-2xl bg-white/[0.05] border border-white/10 backdrop-blur-sm hover:bg-white/[0.12] hover:border-[#52C17A]/50 hover:scale-105 hover:shadow-xl hover:shadow-[#52C17A]/10 transition-all duration-500 cursor-default"
            data-sa="fade-up"
            data-sa-delay={`${index * 80}`}
          >
            <!-- Glow effect on hover -->
            <div class="absolute inset-0 rounded-2xl opacity-0 group-hover:opacity-100 transition-opacity duration-500" style="box-shadow: inset 0 0 30px rgba(82, 193, 122, 0.08);"></div>

            <div class="relative z-10 flex flex-col items-center">
              <div class="w-14 h-14 rounded-2xl flex items-center justify-center mb-5 bg-white/10 group-hover:bg-[#52C17A]/20 transition-colors duration-500">
                <Icon name={industry.icon || 'briefcase'} class="w-7 h-7 text-[#52C17A] group-hover:text-[#52C17A]" size={28} aria-hidden="true" />
              </div>
              <h3 class="text-base font-bold text-white mb-2">{industry.title}</h3>
              <p class="text-sm text-white/50 group-hover:text-white/70 leading-relaxed transition-colors duration-300">
                {industry.description || ''}
              </p>
            </div>
          </div>
        ))}
      </div>

    </div>
  </section>


  <!-- ==================== SECTION 5: CTA BANNER ==================== -->
  <section class="relative py-24 lg:py-32 overflow-hidden" aria-labelledby="cta-heading-v1">

    <!-- Gradient background -->
    <div
      class="absolute inset-0 animate-gradient"
      style="background: linear-gradient(135deg, #52C17A 0%, #3D9E5F 40%, #4DB6AC 70%, #52C17A 100%); background-size: 200% 200%;"
      aria-hidden="true"
    ></div>

    <!-- Decorative floating elements -->
    <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[10%] left-[5%] w-32 h-32 rounded-full bg-white/10 animate-float"></div>
      <div class="absolute bottom-[15%] right-[8%] w-24 h-24 rounded-full bg-white/10 animate-float-delayed"></div>
      <div class="absolute top-[50%] right-[20%] w-16 h-16 rounded-full bg-white/5 animate-float" style="animation-duration: 8s;"></div>
      <div class="absolute bottom-[30%] left-[15%] w-20 h-20 rounded-full bg-white/5 animate-float-delayed" style="animation-duration: 7s;"></div>
    </div>

    <div class="max-w-[1400px] mx-auto px-6 lg:px-12 relative z-10 text-center">
      <div class="max-w-3xl mx-auto">
        <h2 id="cta-heading-v1" class="text-3xl lg:text-5xl xl:text-6xl font-extrabold text-white leading-tight mb-6 tracking-tight" data-sa="fade-up">
          Ready to Transform Your Operations?
        </h2>
        <p class="text-lg lg:text-xl text-white/80 leading-relaxed mb-12 max-w-2xl mx-auto">
          Partner with Paricus and unlock the full potential of your business with world-class outsourcing solutions.
        </p>
        <div class="flex flex-col sm:flex-row gap-5 justify-center" data-sa="scale-in">
          <a
            href={getLocalizedPath('/contact', lang)}
            class="group inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-white text-[#3D9E5F] text-base font-bold shadow-xl shadow-black/10 hover:shadow-2xl hover:scale-[1.03] transition-all duration-300"
          >
            Get Started Today
            <Icon name="arrow-right" class="ml-2.5 w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" size={20} aria-hidden="true" />
          </a>
          <a
            href={getLocalizedPath('/services', lang)}
            class="group inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-white/15 backdrop-blur-sm border-2 border-white/30 text-white text-base font-semibold hover:bg-white/25 hover:border-white/50 hover:scale-[1.03] transition-all duration-300"
          >
            Explore Services
          </a>
        </div>
      </div>
    </div>
  </section>


<!-- ==================== STYLES ==================== -->
<style>
  @keyframes float {
    0%, 100% { transform: translateY(0px); }
    50% { transform: translateY(-20px); }
  }

  @keyframes slideUp {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  @keyframes gradientShift {
    0% { background-position: 0% 50%; }
    50% { background-position: 100% 50%; }
    100% { background-position: 0% 50%; }
  }

  .animate-float {
    animation: float 6s ease-in-out infinite;
  }

  .animate-float-delayed {
    animation: float 6s ease-in-out infinite 2s;
  }

  .animate-slide-up {
    animation: slideUp 0.8s ease-out forwards;
  }

  .animate-slide-up-1 {
    animation: slideUp 0.8s ease-out 0.1s forwards;
    opacity: 0;
  }

  .animate-slide-up-2 {
    animation: slideUp 0.8s ease-out 0.2s forwards;
    opacity: 0;
  }

  .animate-slide-up-3 {
    animation: slideUp 0.8s ease-out 0.3s forwards;
    opacity: 0;
  }

  .animate-slide-up-4 {
    animation: slideUp 0.8s ease-out 0.4s forwards;
    opacity: 0;
  }

  .animate-gradient {
    background-size: 200% 200%;
    animation: gradientShift 8s ease infinite;
  }

  /* Service cards: white with shadow → green fills from bottom on hover */
  .d1-service-card {
    background: #fff;
    border: 1px solid rgba(213, 232, 212, 0.6);
    box-shadow: 0 4px 24px rgba(44, 62, 80, 0.07);
    position: relative;
  }
  .d1-service-card::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;

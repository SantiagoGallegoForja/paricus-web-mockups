---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const title = 'Customer Service';
const icon = 'headphones';
const description = 'Deliver exceptional customer experiences with our dedicated bilingual support teams trained in your brand voice and processes.';
const features = [
  { name: '24/7 Multichannel Support', description: 'Round-the-clock assistance across phone, email, chat, and social media channels.' },
  { name: 'Bilingual English/Spanish Teams', description: 'Native-level agents fluent in both languages for seamless communication.' },
  { name: 'Custom CRM Integration', description: 'Deep integration with your existing tools and workflows for unified operations.' },
  { name: 'Quality Assurance Programs', description: 'Continuous monitoring and coaching to maintain the highest service standards.' },
  { name: 'Scalable Team Models', description: 'Flexible staffing that grows or contracts with your business demands.' },
];
const benefits = [
  { stat: '40%', label: 'Cost Reduction' },
  { stat: '95%', label: 'Customer Satisfaction' },
  { stat: '24/7', label: 'Coverage' },
  { stat: '100%', label: 'Seamless Integration' },
];
const useCases = [
  { title: 'E-commerce Support', description: 'Handle order inquiries, returns, and product questions with speed and empathy across all your sales channels.' },
  { title: 'Healthcare Patient Services', description: 'Manage appointment scheduling, insurance verification, and patient follow-ups with HIPAA-compliant processes.' },
  { title: 'SaaS Technical Assistance', description: 'Provide expert onboarding support, troubleshooting, and account management for your software users.' },
];
---

<!-- V1 — Modern Corporate: ServiceDetail -->
<section class="d1-service-detail">

  <!-- HERO -->
  <div class="d1-sd-hero relative overflow-hidden pt-32" data-sa="fade-in">
    <div class="d1-sd-orb d1-sd-orb--1"></div>
    <div class="d1-sd-orb d1-sd-orb--2"></div>
    <div class="d1-sd-orb d1-sd-orb--3"></div>
    <div class="max-w-[1400px] mx-auto px-6 py-24 lg:py-32 relative z-10">
      <a href={getLocalizedPath('/services', lang)}
         class="inline-flex items-center gap-2 text-[#52C17A] font-semibold mb-8 hover:gap-3 transition-all">
        <span class="rotate-180"><Icon name="arrow-right" class="w-4 h-4" /></span>
        Back to Services
      </a>
      <div class="flex flex-col lg:flex-row items-center gap-10 lg:gap-16">
        <div class="d1-sd-icon-circle flex-shrink-0" data-sa="fade-in">
          <Icon name={icon} class="w-12 h-12 text-white" />
        </div>
        <div class="text-center lg:text-left">
          <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#2C3E50] leading-tight mb-4" data-sa="fade-up">
            {title}
          </h1>
          <p class="max-w-2xl text-lg md:text-xl text-[#5D6D7E] leading-relaxed">
            {description}
          </p>
        </div>
      </div>
    </div>
  </div>

  <!-- FEATURES + BENEFITS 2-column -->
  <div class="max-w-[1400px] mx-auto px-6 py-24 lg:py-32">
    <div class="flex flex-col lg:flex-row gap-12 lg:gap-16">

      <!-- Features left -->
      <div class="flex-1" data-sa="slide-right">
        <h2 class="text-2xl md:text-3xl font-bold text-[#2C3E50] mb-10" data-sa="fade-up">
          What We <span class="d1-sd-gradient-text">Deliver</span>
        </h2>
        <div class="space-y-6">
          {features.map((feature, i) => (
            <div class="d1-sd-feature-card group rounded-2xl p-6"
                 data-sa="fade-up" data-sa-delay={`${i * 100}`}>
              <div class="flex items-start gap-4">
                <div class="d1-sd-check-circle flex-shrink-0 mt-1">
                  <Icon name="check-circle" class="w-5 h-5 text-[#52C17A]" />
                </div>
                <div>
                  <h3 class="text-lg font-bold text-[#2C3E50] mb-1">{feature.name}</h3>
                  <p class="text-[#5D6D7E] text-sm leading-relaxed">{feature.description}</p>
                </div>
              </div>
            </div>
          ))}
        </div>
      </div>

      <!-- Benefits sidebar right -->
      <div class="lg:w-[380px] flex-shrink-0" data-sa="slide-left">
        <h2 class="text-2xl md:text-3xl font-bold text-[#2C3E50] mb-10" data-sa="fade-up">
          Key <span class="d1-sd-gradient-text">Benefits</span>
        </h2>
        <div class="space-y-5">
          {benefits.map((benefit, i) => (
            <div class="d1-sd-benefit-card rounded-3xl p-6 sa-hover-lift"
                 data-sa="fade-up" data-sa-delay={`${i * 60}`}>
              <div class="text-3xl font-extrabold d1-sd-gradient-text mb-1">{benefit.stat}</div>
              <div class="text-[#5D6D7E] font-medium text-sm">{benefit.label}</div>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>

  <!-- USE CASES -->
  <div class="max-w-[1400px] mx-auto px-6 py-24 lg:py-32">
    <h2 class="text-2xl md:text-3xl font-bold text-[#2C3E50] mb-4 text-center" data-sa="fade-up">
      Use <span class="d1-sd-gradient-text">Cases</span>
    </h2>
    <p class="text-[#5D6D7E] text-center max-w-2xl mx-auto mb-12">
      See how our customer service solutions drive results across industries.
    </p>
    <div class="grid md:grid-cols-3 gap-8">
      {useCases.map((uc, i) => (
        <div class="d1-sd-usecase-card rounded-3xl p-8 sa-hover-lift"
             data-sa="fade-up" data-sa-delay={`${i * 80}`}>
          <div class="d1-sd-usecase-icon mb-5">
            <Icon name="target" class="w-6 h-6 text-[#52C17A]" />
          </div>
          <h3 class="text-xl font-bold text-[#2C3E50] mb-3">{uc.title}</h3>
          <p class="text-[#5D6D7E] text-sm leading-relaxed">{uc.description}</p>
        </div>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="max-w-[1400px] mx-auto px-6 py-24 lg:py-32">
    <div class="d1-sd-cta rounded-3xl p-12 lg:p-16 text-center" data-sa="scale-in">
      <h2 class="text-3xl md:text-4xl font-extrabold text-white mb-4" data-sa="fade-up">
        Ready to Transform Your Customer Experience?
      </h2>
      <p class="text-white/80 max-w-2xl mx-auto mb-8 text-lg">
        Let us build a dedicated support team tailored to your brand and customers.
      </p>
      <a href={getLocalizedPath('/contact', lang)}
         class="d1-sd-cta-btn inline-flex items-center gap-2 px-8 py-4 rounded-2xl text-white font-bold text-lg">
        Get Started <Icon name="arrow-right" class="w-5 h-5" />
      </a>
    </div>
  </div>

</section>

<style>
  /* === V1 Modern Corporate — ServiceDetail === */

  .d1-service-detail {
    background: linear-gradient(180deg, #E8F5E9 0%, #FAFAF8 30%, #FFF8E7 100%);
    min-height: 100vh;
  }

  /* Hero orbs */
  .d1-sd-orb {
    position: absolute;
    border-radius: 50%;
    filter: blur(80px);
    opacity: 0.4;
    pointer-events: none;
  }
  .d1-sd-orb--1 {
    width: 500px; height: 500px;
    background: #52C17A;
    top: -150px; left: -100px;
    animation: d1SdFloat 12s ease-in-out infinite;
  }
  .d1-sd-orb--2 {
    width: 400px; height: 400px;
    background: #4DB6AC;
    top: 50px; right: -120px;
    animation: d1SdFloat 15s ease-in-out infinite reverse;
  }
  .d1-sd-orb--3 {
    width: 300px; height: 300px;
    background: #E8F5E9;
    bottom: -80px; left: 40%;
    animation: d1SdFloat 10s ease-in-out infinite;
  }

  @keyframes d1SdFloat {
    0%, 100% { transform: translateY(0) scale(1); }
    50% { transform: translateY(-30px) scale(1.05); }
  }

  /* Icon circle */
  .d1-sd-icon-circle {
    width: 100px; height: 100px;
    background: linear-gradient(135deg, #52C17A, #3D9E5F);
    border-radius: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 10px 40px rgba(82, 193, 122, 0.3);
  }

  /* Gradient text */
  .d1-sd-gradient-text {
    background: linear-gradient(135deg, #52C17A, #3D9E5F);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  /* Feature cards */
  .d1-sd-feature-card {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(82, 193, 122, 0.1);
    transition: all 0.3s ease;
  }
  .d1-sd-feature-card:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(82, 193, 122, 0.3);
    transform: translateX(4px);
    box-shadow: 0 8px 30px rgba(82, 193, 122, 0.1);
  }

  /* Benefit cards */
  .d1-sd-benefit-card {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(82, 193, 122, 0.15);
    transition: all 0.3s ease;
  }
  .d1-sd-benefit-card:hover {
    background: rgba(255, 255, 255, 0.8);
    box-shadow: 0 8px 30px rgba(82, 193, 122, 0.15);
    transform: translateY(-2px);
  }

  /* Use case cards */
  .d1-sd-usecase-card {
    background: rgba(255, 255, 255, 0.5);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(82, 193, 122, 0.1);
    transition: all 0.3s ease;
  }
  .d1-sd-usecase-card:hover {
    background: rgba(255, 255, 255, 0.8);
    border-color: rgba(82, 193, 122, 0.3);
    transform: translateY(-4px);
    box-shadow: 0 12px 40px rgba(82, 193, 122, 0.12);
  }
  .d1-sd-usecase-icon {
    width: 48px; height: 48px;
    background: #E8F5E9;
    border-radius: 1rem;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* CTA */
  .d1-sd-cta {
    background: linear-gradient(135deg, #52C17A, #3D9E5F);
    position: relative;
    overflow: hidden;
  }
  .d1-sd-cta::before {
    content: '';
    position: absolute;
    inset: 0;
    background: radial-gradient(circle at 30% 50%, rgba(255,255,255,0.15), transparent 60%);
    pointer-events: none;
  }
  .d1-sd-cta-btn {
    background: rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.3);
    transition: all 0.3s ease;
  }
  .d1-sd-cta-btn:hover {
    background: rgba(255, 255, 255, 0.3);
    box-shadow: 0 8px 30px rgba(255, 255, 255, 0.2);
    transform: translateY(-2px);
  }
</style>

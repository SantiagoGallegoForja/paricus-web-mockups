---
import { getLocalizedPath } from '../../i18n/utils';
import Icon from '../../components/common/Icon.astro';

interface Props { lang?: string; }
const { lang = 'en' } = Astro.props;

const heading = 'Services That Elevate Your Business';
const description = 'Comprehensive BPO solutions designed to optimize your operations and accelerate growth.';
const services = [
  { icon: 'headphones', title: 'Customer Service', shortDescription: 'Multilingual customer support that builds lasting relationships and drives satisfaction across every channel.', slug: 'customer-service', features: ['24/7 Multilingual Support', 'Omnichannel Management', 'Quality Assurance', 'Customer Retention Programs', 'Real-time Analytics'] },
  { icon: 'file-text', title: 'Back Office Operations', shortDescription: 'Streamline your administrative processes with accurate, efficient back-office support that keeps your business running smoothly.', slug: 'back-office', features: ['Data Entry & Processing', 'Document Management', 'Invoice Processing', 'Record Keeping', 'Compliance Monitoring'] },
  { icon: 'calculator', title: 'Sales & Lead Generation', shortDescription: 'Accelerate your revenue pipeline with skilled sales teams and proven lead generation strategies.', slug: 'sales-lead-generation', features: ['Outbound Campaigns', 'Lead Qualification', 'Appointment Setting', 'CRM Management', 'Performance Tracking'] },
  { icon: 'wrench', title: 'Technical Support', shortDescription: 'Expert technical assistance that resolves issues quickly and keeps your customers productive.', slug: 'technical-support', features: ['Tier 1-3 Support', 'Remote Troubleshooting', 'Knowledge Base Management', 'Escalation Handling', 'SLA Compliance'] },
];
---

<!-- V1 — Modern Corporate: Rounded corners, glass-morphism, gradients, floating elements -->
<section class="d1-services-page">

  <!-- HERO -->
  <div class="d1-hero relative overflow-hidden" data-sa="fade-in">
    <div class="d1-hero-orb d1-hero-orb--1"></div>
    <div class="d1-hero-orb d1-hero-orb--2"></div>
    <div class="d1-hero-orb d1-hero-orb--3"></div>
    <div class="max-w-6xl mx-auto px-6 py-28 lg:py-40 relative z-10 text-center">
      <h1 class="d1-hero-title text-4xl md:text-5xl lg:text-6xl font-extrabold text-[#2C3E50] leading-tight mb-6" data-sa="fade-up">
        Services That <span class="d1-gradient-text">Elevate</span> Your Business
      </h1>
      <p class="d1-hero-desc max-w-2xl mx-auto text-lg md:text-xl text-[#5D6D7E] leading-relaxed">
        {description}
      </p>
    </div>
    <div class="d1-hero-clip"></div>
  </div>

  <!-- SERVICES -->
  <div class="max-w-7xl mx-auto px-6 py-20 lg:py-28 -mt-16 relative z-20">

    <!-- Featured card (first service) -->
    <a href={getLocalizedPath('/services/' + services[0].slug, lang)}
       class="d1-card d1-card--featured group block rounded-3xl p-8 lg:p-12 mb-10"
       data-sa="fade-up" data-sa-delay="0">
      <div class="flex flex-col lg:flex-row items-center gap-8 lg:gap-14">
        <div class="d1-icon-circle d1-icon-circle--lg flex-shrink-0">
          <Icon name={services[0].icon} class="w-10 h-10 text-white" />
        </div>
        <div class="flex-1 text-center lg:text-left">
          <h2 class="text-2xl lg:text-3xl font-bold text-[#2C3E50] mb-3">{services[0].title}</h2>
          <p class="text-[#5D6D7E] mb-5 max-w-xl">{services[0].shortDescription}</p>
          <div class="flex flex-wrap gap-2 justify-center lg:justify-start mb-5">
            {services[0].features.slice(0, 3).map((f) => (
              <span class="d1-pill">{f}</span>
            ))}
          </div>
          <span class="d1-learn-more inline-flex items-center gap-2 text-[#52C17A] font-semibold group-hover:gap-3 transition-all">
            Learn more <span class="text-xl">&rarr;</span>
          </span>
        </div>
      </div>
    </a>

    <!-- Remaining 3 cards in a row -->
    <div class="grid md:grid-cols-3 gap-8">
      {services.slice(1).map((service, i) => (
        <a href={getLocalizedPath('/services/' + service.slug, lang)}
           class="d1-card group block rounded-3xl p-7"
           data-sa="fade-up" data-sa-delay={`${(i + 1) * 80}`}>
          <div class="d1-icon-circle mb-5">
            <Icon name={service.icon} class="w-7 h-7 text-white" />
          </div>
          <h3 class="text-xl font-bold text-[#2C3E50] mb-2">{service.title}</h3>
          <p class="text-[#5D6D7E] text-sm leading-relaxed mb-4">{service.shortDescription}</p>
          <div class="flex flex-wrap gap-2 mb-5">
            {service.features.slice(0, 3).map((f) => (
              <span class="d1-pill text-xs">{f}</span>
            ))}
          </div>
          <span class="d1-learn-more inline-flex items-center gap-2 text-[#52C17A] font-semibold text-sm group-hover:gap-3 transition-all">
            Learn more <span class="text-lg">&rarr;</span>
          </span>
        </a>
      ))}
    </div>
  </div>

  <!-- CTA -->
  <div class="d1-cta relative overflow-hidden py-24 lg:py-32" data-sa="scale-in">
    <div class="d1-cta-circle d1-cta-circle--1"></div>
    <div class="d1-cta-circle d1-cta-circle--2"></div>
    <div class="max-w-3xl mx-auto text-center relative z-10 px-6">
      <h2 class="text-3xl lg:text-4xl font-extrabold text-white mb-5" data-sa="fade-up">Ready to Optimize Your Operations?</h2>
      <p class="text-white/80 text-lg mb-8">Let us show you how our services can transform your business efficiency.</p>
      <a href={getLocalizedPath('/contact', lang)}
         class="d1-cta-btn inline-block px-10 py-4 rounded-full bg-white text-[#3D9E5F] font-bold text-lg shadow-lg hover:shadow-2xl hover:scale-105 transition-all duration-300">
        Get Started Today
      </a>
    </div>
  </div>
</section>

<style>
  /* Hero */
  .d1-hero {
    background: linear-gradient(135deg, #E8F5E9 0%, #FAFAF8 40%, #D5E8D4 100%);
    position: relative;
  }
  .d1-hero-clip {
    position: absolute; bottom: -2px; left: 0; right: 0; height: 80px;
    background: #FAFAF8;
    clip-path: polygon(0 60%, 100% 0, 100% 100%, 0 100%);
  }
  .d1-gradient-text {
    background: linear-gradient(135deg, #52C17A, #4DB6AC);
    -webkit-background-clip: text; -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .d1-hero-orb {
    position: absolute; border-radius: 50%; filter: blur(80px); opacity: .35;
    animation: d1Float 8s ease-in-out infinite;
  }
  .d1-hero-orb--1 { width: 320px; height: 320px; background: #52C17A; top: -60px; left: -80px; }
  .d1-hero-orb--2 { width: 240px; height: 240px; background: #4DB6AC; bottom: 20px; right: 5%; animation-delay: 2s; }
  .d1-hero-orb--3 { width: 180px; height: 180px; background: #D5E8D4; top: 30%; right: 20%; animation-delay: 4s; }

  /* Cards */
  .d1-card {
    background: rgba(255,255,255,.72);
    backdrop-filter: blur(16px); -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(82,193,122,.15);
    box-shadow: 0 4px 24px rgba(44,62,80,.06);
    transition: transform .35s ease, box-shadow .35s ease;
  }
  .d1-card:hover {
    transform: translateY(-6px);
    box-shadow: 0 16px 48px rgba(82,193,122,.15);
  }
  .d1-card:hover .d1-icon-circle { transform: rotate(8deg) scale(1.08); }
  .d1-card--featured { background: rgba(255,255,255,.85); border-color: rgba(82,193,122,.25); }

  /* Icon circles */
  .d1-icon-circle {
    width: 56px; height: 56px; border-radius: 50%; display: flex; align-items: center; justify-content: center;
    background: linear-gradient(135deg, #52C17A, #4DB6AC);
    transition: transform .4s ease;
  }
  .d1-icon-circle--lg { width: 80px; height: 80px; }

  /* Pills */
  .d1-pill {
    display: inline-block; padding: .25rem .75rem; border-radius: 9999px;
    background: #E8F5E9; color: #3D9E5F; font-size: .8rem; font-weight: 500;
    border: 1px solid rgba(82,193,122,.2);
  }

  /* CTA */
  .d1-cta {
    background: linear-gradient(135deg, #52C17A 0%, #3D9E5F 50%, #4DB6AC 100%);
  }
  .d1-cta-circle {
    position: absolute; border-radius: 50%; background: rgba(255,255,255,.08);
    animation: d1Float 10s ease-in-out infinite;
  }
  .d1-cta-circle--1 { width: 400px; height: 400px; top: -120px; right: -100px; }
  .d1-cta-circle--2 { width: 260px; height: 260px; bottom: -80px; left: -60px; animation-delay: 3s; }

  /* Decorative animations */
  @keyframes d1Float {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-20px); }
  }
</style>

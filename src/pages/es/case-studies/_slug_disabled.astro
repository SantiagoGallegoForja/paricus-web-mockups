---
import Layout from '../../../layouts/Layout.astro';
import AnimatedSection from '../../../components/common/AnimatedSection.astro';
import Icon from '../../../components/common/Icon.astro';
import { getLocalizedPath } from '../../../i18n/utils';
import { getCaseStudies, getCaseStudyBySlug, getStrapiImageUrl } from '../../../lib/strapi';
import D4CaseStudyDetail from '../../../designs/design4/CaseStudyDetail.astro';

export async function getStaticPaths() {
  const studies = await getCaseStudies('es');
  return studies.map((study) => ({
    params: { slug: study.slug },
  }));
}

const lang = 'es';
const { slug } = Astro.params;

// Fetch case study
const caseStudy = slug ? await getCaseStudyBySlug(slug, lang) : null;

// 404 if not found
if (!caseStudy) {
  return Astro.redirect('/es/404');
}

const metaTitle = `${caseStudy.title} - Caso de Éxito | Paricus`;
const metaDescription = caseStudy.challenge.slice(0, 160);
const hasBlocks = caseStudy.blocks && caseStudy.blocks.length > 0;
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  currentPath={`/es/case-studies/${slug}`}
>
  <article class="py-20 lg:py-32 bg-white pt-40">
    <div class="max-w-[1200px] mx-auto px-6 lg:px-12">
      <!-- Back link -->
      <AnimatedSection>
        <a
          href={getLocalizedPath('/case-studies', lang)}
          class="inline-flex items-center text-[#5D6D7E] hover:text-[#52C17A] transition-colors mb-8 group"
        >
          <Icon name="arrow-left" class="w-5 h-5 mr-2 group-hover:-translate-x-1 transition-transform" size={20} />
          Volver a Casos de Éxito
        </a>
      </AnimatedSection>

      <!-- Header -->
      <AnimatedSection class="mb-12">
        <span class="inline-block px-4 py-2 bg-[#E8F5E9] text-[#52C17A] text-sm font-semibold rounded-full mb-6">
          {caseStudy.industry}
        </span>
        <h1 class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
          {caseStudy.title}
        </h1>
      </AnimatedSection>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-12">
        <!-- Main content -->
        <div class="lg:col-span-2 space-y-10">
          <AnimatedSection>
            <div class="bg-[#FAFAF8] rounded-2xl p-8 border border-[#D5E8D4]">
              <h2 class="text-sm font-bold text-[#2C3E50] mb-4 uppercase tracking-wide flex items-center">
                <Icon name="alert-circle" class="w-5 h-5 mr-2 text-[#52C17A]" size={20} />
                El Desafío
              </h2>
              <p class="text-lg text-[#5D6D7E] leading-relaxed">
                {caseStudy.challenge}
              </p>
            </div>
          </AnimatedSection>

          <AnimatedSection>
            <div class="bg-[#FAFAF8] rounded-2xl p-8 border border-[#D5E8D4]">
              <h2 class="text-sm font-bold text-[#2C3E50] mb-4 uppercase tracking-wide flex items-center">
                <Icon name="lightbulb" class="w-5 h-5 mr-2 text-[#52C17A]" size={20} />
                Nuestra Solución
              </h2>
              <p class="text-lg text-[#5D6D7E] leading-relaxed">
                {caseStudy.solution}
              </p>
            </div>
          </AnimatedSection>

          <!-- Dynamic Content Blocks (optional) -->
          {hasBlocks && (
            <AnimatedSection>
              <div class="prose prose-lg max-w-none">
                {caseStudy.blocks!.map((block: any) => {
                  if (block.__component === 'shared.rich-text') {
                    return (
                      <div class="text-[#5D6D7E] leading-relaxed mb-6" set:html={block.body} />
                    );
                  }
                  if (block.__component === 'shared.quote') {
                    return (
                      <blockquote class="border-l-4 border-[#52C17A] pl-6 my-8 italic text-[#5D6D7E]">
                        <p class="text-xl">{block.body}</p>
                        {block.title && <cite class="text-sm font-semibold not-italic">- {block.title}</cite>}
                      </blockquote>
                    );
                  }
                  if (block.__component === 'shared.media') {
                    const mediaUrl = getStrapiImageUrl(block.file);
                    return mediaUrl && (
                      <figure class="my-8">
                        <img
                          src={mediaUrl}
                          alt={block.file?.alternativeText || ''}
                          class="w-full rounded-xl"
                          loading="lazy"
                        />
                      </figure>
                    );
                  }
                  if (block.__component === 'shared.slider' && block.files) {
                    return (
                      <div class="my-8 grid grid-cols-2 gap-4">
                        {block.files.map((file: any) => {
                          const fileUrl = getStrapiImageUrl(file);
                          return fileUrl && (
                            <img
                              src={fileUrl}
                              alt={file.alternativeText || ''}
                              class="w-full rounded-xl"
                              loading="lazy"
                            />
                          );
                        })}
                      </div>
                    );
                  }
                  return null;
                })}
              </div>
            </AnimatedSection>
          )}
        </div>

        <!-- Results sidebar -->
        <aside class="lg:col-span-1">
          <AnimatedSection>
            <div class="bg-gradient-to-br from-[#52C17A] to-[#3D9E5F] rounded-2xl p-8 text-white sticky top-32">
              <h2 class="text-sm font-bold mb-8 uppercase tracking-wide flex items-center">
                <Icon name="trophy" class="w-5 h-5 mr-2" size={20} />
                Resultados Logrados
              </h2>
              <div class="space-y-8">
                {caseStudy.results.map((result) => (
                  <div class="flex items-start gap-4">
                    <div class="w-14 h-14 rounded-xl bg-white/20 flex items-center justify-center flex-shrink-0">
                      <Icon name={result.icon} class="w-7 h-7 text-white" size={28} />
                    </div>
                    <div>
                      <div class="text-4xl font-bold mb-1">
                        {result.metric}
                      </div>
                      <div class="text-sm text-white/90 font-medium">
                        {result.label}
                      </div>
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </AnimatedSection>
        </aside>
      </div>

      <!-- CTA -->
      <AnimatedSection class="mt-16">
        <div class="bg-[#FAFAF8] rounded-2xl p-10 border border-[#D5E8D4] text-center">
          <h2 class="text-2xl font-bold text-[#2C3E50] mb-4">
            ¿Listo para lograr resultados similares?
          </h2>
          <p class="text-[#5D6D7E] mb-8 max-w-2xl mx-auto">
            Hablemos sobre cómo podemos ayudar a transformar las operaciones de tu negocio y entregar impacto medible.
          </p>
          <a
            href={getLocalizedPath('/contact', lang)}
            class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-[#52C17A] text-white text-base font-semibold hover:bg-[#3D9E5F] transition-colors shadow-lg shadow-[#52C17A]/30"
          >
            Contáctanos
            <Icon name="arrow-right" class="w-5 h-5 ml-2" size={20} />
          </a>
        </div>
      </AnimatedSection>
    </div>
  </article>
  <div data-design="4" style="display:none;"><D4CaseStudyDetail lang={lang} /></div>
</Layout>

<style>
  .prose h2 {
    font-size: 1.5rem;
    font-weight: 700;
    color: #2C3E50;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
  }
  .prose h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #2C3E50;
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }
  .prose p {
    color: #5D6D7E;
    line-height: 1.75;
    margin-bottom: 1rem;
  }
  .prose ul, .prose ol {
    color: #5D6D7E;
    margin-bottom: 1rem;
    padding-left: 1.5rem;
  }
  .prose li {
    margin-bottom: 0.5rem;
  }
  .prose a {
    color: #52C17A;
  }
  .prose a:hover {
    text-decoration: underline;
  }
  .prose strong {
    color: #2C3E50;
  }
  .prose img {
    border-radius: 0.75rem;
    margin-top: 1.5rem;
    margin-bottom: 1.5rem;
  }
</style>

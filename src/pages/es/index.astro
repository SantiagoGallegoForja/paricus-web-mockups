---
import Layout from '../../layouts/Layout.astro';
import Design1Hero from '../../designs/design1/Hero.astro';
import Design2Hero from '../../designs/design2/Hero.astro';
import Design3Hero from '../../designs/design3/Hero.astro';
import Design4Hero from '../../designs/design4/Hero.astro';
const lang = 'es';
---

<Layout
  title="Paricus - Tu Socio BPO de Confianza"
  description="Paricus ayuda a empresas globales a optimizar operaciones, mejorar eficiencia y escalar con confianza."
  lang={lang}
  currentPath="/es/"
>
  <!-- Design V1: Modern Improved -->
  <div data-design="1">
    <Design1Hero lang={lang} />
  </div>

  <!-- Design V2: Editorial Enterprise -->
  <div data-design="2" style="display:none;">
    <Design2Hero lang={lang} />
  </div>

  <!-- Design V3: Bold SaaS -->
  <div data-design="3" style="display:none;">
    <Design3Hero lang={lang} />
  </div>

  <!-- Design V4 -->
  <div data-design="4" style="display:none;">
    <Design4Hero lang={lang} />
  </div>
</Layout>

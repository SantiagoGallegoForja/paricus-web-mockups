---
import Layout from '../../layouts/Layout.astro';
import AnimatedSection from '../../components/common/AnimatedSection.astro';
import Icon from '../../components/common/Icon.astro';
import { t, getLocalizedPath } from '../../i18n/utils';

const lang = 'es';

const stats = [
  { icon: 'users', value: '100+', labelKey: 'about.stats.teamMembers' },
  { icon: 'globe', value: '2', labelKey: 'about.stats.countriesServed' },
  { icon: 'award', value: '15+', labelKey: 'about.stats.yearsExperience' },
  { icon: 'trending-up', value: '98%', labelKey: 'about.stats.clientSatisfaction' }
];

const leaders = [
  { name: 'Jorge E. Perea', initials: 'JP' },
  { name: 'Jay Jones', initials: 'JJ' }
];
---

<Layout title="Nosotros - Paricus" description="Paricus combina la calidez de la colaboracion con la confianza de la experiencia." lang={lang} currentPath="/es/about">
  <section class="py-20 lg:py-32 bg-white pt-40">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center mb-20">
        <AnimatedSection animation="slide-left">
          <h1 class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6">
            {t('about.heading', lang)} <span class="text-[#52C17A]">{t('about.headingHighlight', lang)}</span> {t('about.headingEnd', lang)}
          </h1>
          <p class="text-lg text-[#5D6D7E] mb-6">{t('about.description1', lang)}</p>
          <p class="text-lg text-[#5D6D7E] mb-8">{t('about.description2', lang)}</p>
          <a href={getLocalizedPath('/contact', lang)} class="inline-flex items-center justify-center px-8 py-4 rounded-xl bg-[#52C17A] text-white font-semibold hover:bg-[#3D9E5F] transition-colors shadow-lg shadow-[#52C17A]/30">
            {t('about.partnerWithUs', lang)}
          </a>
        </AnimatedSection>
        <AnimatedSection animation="slide-right" class="grid grid-cols-2 gap-6" tag="div">
          {stats.map((stat) => (
            <div class="group relative bg-[#E8F5E9] rounded-2xl p-8 border border-[#D5E8D4] overflow-hidden cursor-pointer transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:border-[#52C17A]">
              <div class="absolute inset-0 bg-gradient-to-br from-[#52C17A] to-[#3D9E5F] opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
              <div class="relative z-10">
                <Icon name={stat.icon} class="w-10 h-10 text-[#52C17A] mb-4 group-hover:text-white transition-all duration-500" size={40} />
                <div class="text-4xl font-bold text-[#2C3E50] mb-2 group-hover:text-white transition-colors">{stat.value}</div>
                <div class="text-sm text-[#5D6D7E] font-medium group-hover:text-white/90 transition-colors">{t(stat.labelKey, lang)}</div>
              </div>
            </div>
          ))}
        </AnimatedSection>
      </div>
      <AnimatedSection>
        <h2 class="text-3xl font-bold text-[#2C3E50] mb-10">{t('about.leadership', lang)}</h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
          {leaders.map((leader) => (
            <article class="group bg-white rounded-2xl p-8 border border-[#D5E8D4] cursor-pointer transition-all duration-500 hover:-translate-y-3 hover:shadow-xl hover:border-[#52C17A]">
              <div class="w-20 h-20 rounded-full bg-gradient-to-br from-[#52C17A] to-[#4DB6AC] flex items-center justify-center mb-6 group-hover:scale-110 transition-all duration-500">
                <span class="text-2xl font-bold text-white">{leader.initials}</span>
              </div>
              <h3 class="text-xl font-bold text-[#2C3E50] mb-2 group-hover:text-[#52C17A] transition-colors">{leader.name}</h3>
              <p class="text-sm text-[#5D6D7E]">{t('about.managingPartner', lang)}</p>
            </article>
          ))}
        </div>
      </AnimatedSection>
    </div>
  </section>
</Layout>

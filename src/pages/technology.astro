---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/common/AnimatedSection.astro';
import Icon from '../components/common/Icon.astro';
import { t, getLocalizedPath } from '../i18n/utils';
import { getTechnologyPage } from '../lib/strapi';

const lang = 'en';

// Fetch CMS content
const techData = await getTechnologyPage(lang);

// Fallback values
const defaultCertifications = [
  { id: 1, name: 'ISO 27001', description: 'Information Security Management' },
  { id: 2, name: 'ISO 9001', description: 'Quality Management Systems' },
  { id: 3, name: 'HIPAA', description: 'Healthcare Data Protection' },
  { id: 4, name: 'SOC 2 Type II', description: 'Service Organization Controls' }
];

const defaultTechnologies = [
  { id: 1, icon: 'shield', name: 'Enterprise Security', description: 'Multi-layer security protocols protecting your data' },
  { id: 2, icon: 'zap', name: 'AI-Powered Tools', description: 'Smart automation enhancing agent productivity' },
  { id: 3, icon: 'database', name: 'Real-time Analytics', description: 'Live dashboards and performance insights' },
  { id: 4, icon: 'cloud', name: 'Cloud Infrastructure', description: 'Scalable, redundant cloud architecture' }
];

// Use CMS data with fallbacks
const heading = techData?.heading || t('technology.heading', lang);
const description = techData?.description || t('technology.description', lang);
const certificationsTitle = techData?.certificationsTitle || t('technology.certificationsTitle', lang);
const certifications = techData?.certifications?.length ? techData.certifications : defaultCertifications;
const techStackTitle = techData?.techStackTitle || t('technology.techStackTitle', lang);
const technologies = techData?.technologies?.length ? techData.technologies : defaultTechnologies;
const securityTitle = techData?.securityTitle || t('technology.securityTitle', lang);
const securityDescription = techData?.securityDescription || t('technology.securityDescription', lang);
const ctaButtonText = techData?.ctaButtonText || t('technology.learnMore', lang);
const metaTitle = techData?.metaTitle || 'Technology - Paricus';
const metaDescription = techData?.metaDescription || 'Enterprise-grade technology and security standards that power exceptional business operations.';
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  currentPath="/technology"
>
  <section class="py-20 lg:py-32 bg-[#FAFAF8] pt-40" aria-labelledby="technology-heading">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <AnimatedSection class="text-center max-w-3xl mx-auto mb-16">
        <h1 id="technology-heading" class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
          {heading}
        </h1>
        <p class="text-lg text-[#5D6D7E] leading-relaxed">
          {description}
        </p>
      </AnimatedSection>

      <AnimatedSection animation="scale" class="grid grid-cols-1 lg:grid-cols-2 gap-12 mb-20" tag="div">
        <div>
          <h2 class="text-2xl font-bold text-[#2C3E50] mb-8 flex items-center">
            <Icon name="lock" class="w-6 h-6 text-[#52C17A] mr-3" size={24} aria-hidden="true" />
            {certificationsTitle}
          </h2>
          <div class="grid grid-cols-2 gap-4" role="list" aria-label="Certifications and compliance standards">
            {certifications.map((cert) => (
              <div
                class="group relative bg-white rounded-2xl p-6 border border-[#D5E8D4] overflow-hidden cursor-pointer transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-[#52C17A]/20 hover:border-[#52C17A]"
                role="listitem"
              >
                <!-- Animated background -->
                <div class="absolute inset-0 bg-gradient-to-br from-[#E8F5E9] to-white opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>

                <!-- Content -->
                <div class="relative z-10">
                  <div class="flex items-center mb-2">
                    <Icon name="check-circle-2" class="w-5 h-5 text-[#52C17A] mr-2 group-hover:scale-125 group-hover:rotate-12 transition-all duration-300" size={20} aria-hidden="true" />
                    <h3 class="text-lg font-bold text-[#2C3E50] group-hover:text-[#52C17A] transition-colors duration-300">
                      {cert.name}
                    </h3>
                  </div>
                  <p class="text-sm text-[#5D6D7E] group-hover:translate-x-1 transition-transform duration-300">
                    {cert.description}
                  </p>
                </div>
              </div>
            ))}
          </div>
        </div>

        <div>
          <h2 class="text-2xl font-bold text-[#2C3E50] mb-8 flex items-center">
            <Icon name="zap" class="w-6 h-6 text-[#52C17A] mr-3" size={24} aria-hidden="true" />
            {techStackTitle}
          </h2>
          <div class="space-y-4" role="list" aria-label="Technology capabilities">
            {technologies.map((tech) => (
              <div
                class="group relative bg-white rounded-2xl p-6 border border-[#D5E8D4] flex items-start gap-4 overflow-hidden cursor-pointer transition-all duration-500 hover:-translate-y-2 hover:shadow-xl hover:shadow-[#52C17A]/20 hover:border-[#52C17A]"
                role="listitem"
              >
                <!-- Animated background -->
                <div class="absolute inset-0 bg-gradient-to-r from-[#E8F5E9] to-white opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>

                <!-- Content -->
                <div class="relative z-10 flex items-start gap-4 w-full">
                  <div class="w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500" aria-hidden="true">
                    <Icon name={tech.icon} class="w-7 h-7 text-[#52C17A] group-hover:text-white transition-colors duration-300" size={28} />
                  </div>
                  <div class="group-hover:translate-x-2 transition-transform duration-300">
                    <h3 class="text-lg font-bold text-[#2C3E50] mb-1 group-hover:text-[#52C17A] transition-colors duration-300">
                      {tech.name}
                    </h3>
                    <p class="text-sm text-[#5D6D7E]">
                      {tech.description}
                    </p>
                  </div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </AnimatedSection>

      <AnimatedSection class="relative bg-gradient-to-br from-[#52C17A] to-[#3D9E5F] rounded-3xl p-10 lg:p-16 text-center text-white overflow-hidden group cursor-pointer hover:shadow-2xl hover:shadow-[#52C17A]/40 transition-all duration-500" tag="div">
        <!-- Animated decorative elements -->
        <div class="absolute top-0 right-0 w-64 h-64 bg-white/10 rounded-full blur-3xl group-hover:scale-150 transition-transform duration-1000" aria-hidden="true"></div>
        <div class="absolute bottom-0 left-0 w-48 h-48 bg-white/10 rounded-full blur-2xl group-hover:scale-150 transition-transform duration-1000" aria-hidden="true"></div>

        <!-- Content -->
        <div class="relative z-10">
          <Icon name="shield" class="w-16 h-16 mx-auto mb-6 opacity-90 group-hover:scale-110 group-hover:rotate-12 transition-all duration-500" size={64} aria-hidden="true" />
          <h2 class="text-3xl lg:text-4xl font-bold mb-4 group-hover:scale-105 transition-transform duration-300">
            {securityTitle}
          </h2>
          <p class="text-lg opacity-90 max-w-2xl mx-auto mb-8 leading-relaxed group-hover:translate-y-1 transition-transform duration-300">
            {securityDescription}
          </p>
          <a
            href={getLocalizedPath('/contact', lang)}
            class="inline-flex items-center justify-center px-8 py-4 rounded-2xl bg-white text-[#52C17A] text-base font-semibold hover:bg-[#FAFAF8] hover:scale-105 transition-all duration-300 shadow-lg"
            aria-label="Learn more about our security practices"
          >
            {ctaButtonText}
          </a>
        </div>
      </AnimatedSection>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import D1 from '../designs/design1/Technology.astro';
import D2 from '../designs/design2/Technology.astro';
import D3 from '../designs/design3/Technology.astro';
import D4 from '../designs/design4/Technology.astro';
const lang = 'en';
---

<Layout title="Technology - Paricus" description="Enterprise-grade technology and security standards that power exceptional business operations." lang={lang} currentPath="/technology">
  <div data-design="1"><D1 lang={lang} /></div>
  <div data-design="2" style="display:none;"><D2 lang={lang} /></div>
  <div data-design="3" style="display:none;"><D3 lang={lang} /></div>
  <div data-design="4" style="display:none;"><D4 lang={lang} /></div>
</Layout>

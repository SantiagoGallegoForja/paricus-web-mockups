---
import Layout from '../layouts/Layout.astro';
import D1 from '../designs/design1/BlogList.astro';
import D2 from '../designs/design2/BlogList.astro';
import D3 from '../designs/design3/BlogList.astro';
import D4 from '../designs/design4/BlogList.astro';
const lang = 'en';
---

<Layout title="Blog - Paricus" description="Stay informed with the latest trends and best practices in business process outsourcing." lang={lang} currentPath="/blog">
  <div data-design="1"><D1 lang={lang} /></div>
  <div data-design="2" style="display:none;"><D2 lang={lang} /></div>
  <div data-design="3" style="display:none;"><D3 lang={lang} /></div>
  <div data-design="4" style="display:none;"><D4 lang={lang} /></div>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/common/AnimatedSection.astro';
import Icon from '../components/common/Icon.astro';
import { t } from '../i18n/utils';
import { getFormConfig, getContactPage } from '../lib/strapi';

const lang = 'en';
const formConfig = await getFormConfig();
const contactPage = await getContactPage(lang);

// Defaults for when CMS is empty
const heading = contactPage?.heading || t('contact.heading', lang);
const description = contactPage?.description || t('contact.description', lang);
const formTitle = contactPage?.formTitle || t('contact.info.getInTouch', lang);
const phone = contactPage?.phone || '+1 (555) 123-4567';
const email = contactPage?.email || 'contact@paricus.com';
const location = contactPage?.location || t('contact.info.locationValue', lang);
const linkedinUrl = contactPage?.linkedinUrl || '#';
const instagramUrl = contactPage?.instagramUrl || '#';
const facebookUrl = contactPage?.facebookUrl || '#';
const businessHoursTitle = contactPage?.businessHoursTitle || 'Business Hours';
const businessHours = contactPage?.businessHours || [
  { id: 1, day: 'Monday - Friday', hours: '9:00 AM - 6:00 PM EST' },
  { id: 2, day: 'Saturday', hours: '10:00 AM - 4:00 PM EST' },
  { id: 3, day: 'Sunday', hours: 'Closed' }
];
const metaTitle = contactPage?.metaTitle || 'Contact Us - Paricus';
const metaDescription = contactPage?.metaDescription || 'Ready to transform your operations? Get in touch with our team.';
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  currentPath="/contact"
>
  <section class="py-20 lg:py-32 bg-white pt-40" aria-labelledby="contact-heading">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <AnimatedSection class="text-center max-w-3xl mx-auto mb-16">
        <h1 id="contact-heading" class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
          {heading}
        </h1>
        <p class="text-lg text-[#5D6D7E] leading-relaxed">
          {description}
        </p>
      </AnimatedSection>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12">
        <!-- Form Section -->
        <AnimatedSection animation="slide-left">
          <div class="bg-[#FAFAF8] rounded-3xl p-8 lg:p-10 border border-[#D5E8D4]">
            <h2 class="text-2xl font-bold text-[#2C3E50] mb-6">
              {formTitle}
            </h2>
            <form class="space-y-6" aria-label="Contact form">
              <!-- Hidden UTM fields -->
              <input type="hidden" name="utm_source" id="utm_source" />
              <input type="hidden" name="utm_medium" id="utm_medium" />
              <input type="hidden" name="utm_campaign" id="utm_campaign" />
              <input type="hidden" name="utm_term" id="utm_term" />
              <input type="hidden" name="utm_content" id="utm_content" />

              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="firstName" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    {t('contact.form.name', lang)}
                  </label>
                  <input
                    type="text"
                    id="firstName"
                    name="firstName"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                    placeholder="John"
                    required
                    aria-required="true"
                  />
                </div>
                <div>
                  <label for="lastName" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    Last Name
                  </label>
                  <input
                    type="text"
                    id="lastName"
                    name="lastName"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                    placeholder="Doe"
                    required
                    aria-required="true"
                  />
                </div>
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="email" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    {t('contact.form.email', lang)}
                  </label>
                  <input
                    type="email"
                    id="email"
                    name="email"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                    placeholder="john.doe@company.com"
                    required
                    aria-required="true"
                  />
                </div>
                <div>
                  <label for="phone" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    Phone
                  </label>
                  <input
                    type="tel"
                    id="phone"
                    name="phone"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                    placeholder="+1 (555) 123-4567"
                  />
                </div>
              </div>
              <div>
                <label for="company" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                  {t('contact.form.company', lang)}
                </label>
                <input
                  type="text"
                  id="company"
                  name="company"
                  class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                  placeholder="Your Company"
                />
              </div>
              <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
                <div>
                  <label for="industry" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    Industry
                  </label>
                  <select
                    id="industry"
                    name="industry"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                  >
                    <option value="">Select your industry</option>
                    {formConfig.industries.map((industry) => (
                      <option value={industry.value}>{industry.name_en}</option>
                    ))}
                    <option value="other">Other</option>
                  </select>
                </div>
                <div>
                  <label for="service" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                    Service of Interest
                  </label>
                  <select
                    id="service"
                    name="service"
                    class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all"
                  >
                    <option value="">Select a service</option>
                    {formConfig.services.map((service) => (
                      <option value={service.value}>{service.name_en}</option>
                    ))}
                    <option value="other">Other</option>
                  </select>
                </div>
              </div>
              <div>
                <label for="message" class="block text-sm font-semibold text-[#2C3E50] mb-2">
                  {t('contact.form.message', lang)}
                </label>
                <textarea
                  id="message"
                  name="message"
                  rows="4"
                  class="w-full px-4 py-3 rounded-xl border border-[#D5E8D4] bg-white focus:border-[#52C17A] focus:ring-2 focus:ring-[#52C17A] focus:ring-opacity-20 outline-none transition-all resize-none"
                  placeholder="Tell us about your needs..."
                  required
                  aria-required="true"
                ></textarea>
              </div>
              <button
                type="submit"
                class="w-full px-8 py-4 rounded-2xl bg-gradient-to-r from-[#52C17A] to-[#3D9E5F] text-white text-base font-semibold hover:shadow-2xl hover:shadow-[#52C17A]/50 hover:scale-105 transition-all duration-300"
                aria-label="Send your message"
              >
                {t('contact.form.send', lang)}
              </button>
            </form>

            <!-- UTM Capture Script -->
            <script>
              document.addEventListener('DOMContentLoaded', () => {
                const params = new URLSearchParams(window.location.search);
                const utmFields = ['utm_source', 'utm_medium', 'utm_campaign', 'utm_term', 'utm_content'];
                utmFields.forEach(field => {
                  const value = params.get(field);
                  const input = document.getElementById(field) as HTMLInputElement;
                  if (input && value) {
                    input.value = value;
                  }
                });
              });
            </script>
          </div>
        </AnimatedSection>

        <!-- Info Section -->
        <AnimatedSection animation="slide-right" class="space-y-8">
          <div>
            <h2 class="text-2xl font-bold text-[#2C3E50] mb-6">
              {t('contact.info.getInTouch', lang)}
            </h2>
            <address class="space-y-6 not-italic">
              <div class="group flex items-start gap-4 cursor-pointer transition-all duration-300 hover:translate-x-2">
                <div class="w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500" aria-hidden="true">
                  <Icon name="phone" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </div>
                <div>
                  <h3 class="text-sm font-bold text-[#2C3E50] mb-1 uppercase tracking-wide">
                    {t('contact.info.phone', lang)}
                  </h3>
                  <a href={`tel:${phone.replace(/\s/g, '')}`} class="text-base text-[#5D6D7E] hover:text-[#52C17A] transition-colors">
                    {phone}
                  </a>
                </div>
              </div>
              <div class="group flex items-start gap-4 cursor-pointer transition-all duration-300 hover:translate-x-2">
                <div class="w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500" aria-hidden="true">
                  <Icon name="mail" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </div>
                <div>
                  <h3 class="text-sm font-bold text-[#2C3E50] mb-1 uppercase tracking-wide">
                    {t('contact.info.email', lang)}
                  </h3>
                  <a href={`mailto:${email}`} class="text-base text-[#5D6D7E] hover:text-[#52C17A] transition-colors">
                    {email}
                  </a>
                </div>
              </div>
              <div class="group flex items-start gap-4 cursor-pointer transition-all duration-300 hover:translate-x-2">
                <div class="w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center flex-shrink-0 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500" aria-hidden="true">
                  <Icon name="map-pin" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </div>
                <div>
                  <h3 class="text-sm font-bold text-[#2C3E50] mb-1 uppercase tracking-wide">
                    {t('contact.info.location', lang)}
                  </h3>
                  <p class="text-base text-[#5D6D7E]">
                    {location}
                  </p>
                </div>
              </div>
            </address>
          </div>

          <div>
            <h2 class="text-2xl font-bold text-[#2C3E50] mb-6">
              {t('contact.info.followUs', lang)}
            </h2>
            <div class="flex gap-4" role="list" aria-label="Social media links">
              {linkedinUrl && linkedinUrl !== '#' && (
                <a
                  href={linkedinUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500"
                  aria-label="Follow us on LinkedIn"
                >
                  <Icon name="linkedin" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </a>
              )}
              {instagramUrl && instagramUrl !== '#' && (
                <a
                  href={instagramUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500"
                  aria-label="Follow us on Instagram"
                >
                  <Icon name="instagram" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </a>
              )}
              {facebookUrl && facebookUrl !== '#' && (
                <a
                  href={facebookUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500"
                  aria-label="Follow us on Facebook"
                >
                  <Icon name="facebook" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                </a>
              )}
              {(!linkedinUrl || linkedinUrl === '#') && (!instagramUrl || instagramUrl === '#') && (!facebookUrl || facebookUrl === '#') && (
                <>
                  <a href="#" class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500" aria-label="Follow us on LinkedIn">
                    <Icon name="linkedin" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                  </a>
                  <a href="#" class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500" aria-label="Follow us on Instagram">
                    <Icon name="instagram" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                  </a>
                  <a href="#" class="group w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center hover:scale-110 hover:rotate-6 hover:bg-gradient-to-br hover:from-[#52C17A] hover:to-[#3D9E5F] transition-all duration-500" aria-label="Follow us on Facebook">
                    <Icon name="facebook" class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors" size={24} />
                  </a>
                </>
              )}
            </div>
          </div>

          <div class="bg-[#FAFAF8] rounded-3xl p-8 border border-[#D5E8D4]">
            <h3 class="text-lg font-bold text-[#2C3E50] mb-4">
              {businessHoursTitle}
            </h3>
            <dl class="space-y-3 text-sm text-[#5D6D7E]">
              {businessHours.map((hour, index) => (
                <div class={`flex justify-between py-2 ${index < businessHours.length - 1 ? 'border-b border-[#D5E8D4]' : ''}`}>
                  <dt class="font-medium">{hour.day}</dt>
                  <dd>{hour.hours}</dd>
                </div>
              ))}
            </dl>
          </div>
        </AnimatedSection>
      </div>
    </div>
  </section>
</Layout>

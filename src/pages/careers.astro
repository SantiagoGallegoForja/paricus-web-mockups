---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/common/AnimatedSection.astro';
import Icon from '../components/common/Icon.astro';
import { t, getLocalizedPath } from '../i18n/utils';

const lang = 'en';

const benefits = [
  { icon: 'trending-up', titleKey: 'careers.benefits.growth.title', descriptionKey: 'careers.benefits.growth.description' },
  { icon: 'users', titleKey: 'careers.benefits.culture.title', descriptionKey: 'careers.benefits.culture.description' },
  { icon: 'heart', titleKey: 'careers.benefits.benefits.title', descriptionKey: 'careers.benefits.benefits.description' },
  { icon: 'briefcase', titleKey: 'careers.benefits.training.title', descriptionKey: 'careers.benefits.training.description' }
];
---

<Layout
  title="Careers - Paricus"
  description="Be part of a company that values growth, innovation, and work-life balance."
  lang={lang}
  currentPath="/careers"
>
  <section class="py-20 lg:py-32 bg-white pt-40" aria-labelledby="careers-heading">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <AnimatedSection animation="slide-left">
          <h1 id="careers-heading" class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
            {t('careers.heading', lang)}
          </h1>
          <p class="text-lg text-[#5D6D7E] leading-relaxed mb-8">
            {t('careers.description', lang)}
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a
              href={getLocalizedPath('/contact', lang)}
              class="inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-gradient-to-r from-[#52C17A] to-[#3D9E5F] text-white text-base font-semibold hover:shadow-2xl hover:shadow-[#52C17A]/50 hover:scale-105 transition-all duration-300 group"
              aria-label="View job openings"
            >
              {t('careers.viewAll', lang)}
              <Icon name="arrow-right" class="ml-2 w-5 h-5 group-hover:translate-x-2 transition-transform" size={20} aria-hidden="true" />
            </a>
            <a
              href={getLocalizedPath('/about', lang)}
              class="inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-white/80 backdrop-blur-sm border-2 border-[#D5E8D4] text-[#2C3E50] text-base font-semibold hover:bg-white hover:border-[#52C17A] hover:shadow-lg transition-all duration-300"
              aria-label="Learn more about our company"
            >
              {t('careers.whyJoin', lang)}
            </a>
          </div>
        </AnimatedSection>

        <AnimatedSection animation="slide-right" class="grid grid-cols-1 sm:grid-cols-2 gap-6" tag="div">
          {benefits.map((benefit, index) => (
            <article
              class="group relative bg-[#FAFAF8] rounded-2xl p-6 border border-[#D5E8D4] overflow-hidden cursor-pointer transition-all duration-500 hover:-translate-y-3 hover:shadow-xl hover:shadow-[#52C17A]/20 hover:border-[#52C17A]"
              style={`transition-delay: ${index * 100}ms`}
            >
              <!-- Animated background -->
              <div class="absolute inset-0 bg-gradient-to-br from-[#E8F5E9] to-white opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>

              <!-- Content -->
              <div class="relative z-10">
                <div class="w-14 h-14 rounded-2xl bg-[#E8F5E9] flex items-center justify-center mb-4 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500" aria-hidden="true">
                  <Icon name={benefit.icon} class="w-7 h-7 text-[#52C17A] group-hover:text-white transition-colors duration-300" size={28} />
                </div>
                <h2 class="text-lg font-bold text-[#2C3E50] mb-2 group-hover:text-[#52C17A] group-hover:translate-x-1 transition-all duration-300">
                  {t(benefit.titleKey, lang)}
                </h2>
                <p class="text-sm text-[#5D6D7E] group-hover:translate-x-1 transition-transform duration-300">
                  {t(benefit.descriptionKey, lang)}
                </p>
              </div>
            </article>
          ))}
        </AnimatedSection>
      </div>
    </div>
  </section>
</Layout>

---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/common/AnimatedSection.astro';
import Icon from '../components/common/Icon.astro';
import { t } from '../i18n/utils';
import { getIndustriesPage } from '../lib/strapi';

const lang = 'en';

// Fetch CMS content
const industriesData = await getIndustriesPage(lang);

// Fallback values if CMS is not configured
const defaultIndustries = [
  { id: 1, icon: 'heart', title: 'Healthcare', description: 'Supporting patient care with compassionate, HIPAA-compliant support services.' },
  { id: 2, icon: 'package', title: 'E-Commerce', description: 'Scaling your online business with seamless customer experiences.' },
  { id: 3, icon: 'cpu', title: 'Technology', description: 'Technical support that speaks your customers\' language.' },
  { id: 4, icon: 'landmark', title: 'Finance', description: 'Secure, compliant support for financial services.' },
  { id: 5, icon: 'shopping-bag', title: 'Travel & Hospitality', description: 'Creating memorable experiences from first contact.' }
];

// Use CMS data with fallbacks
const heading = industriesData?.heading || t('industries.heading', lang);
const description = industriesData?.description || t('industries.description', lang);
const industries = industriesData?.industries?.length ? industriesData.industries : defaultIndustries;
const metaTitle = industriesData?.metaTitle || 'Industries - Paricus';
const metaDescription = industriesData?.metaDescription || 'Specialized expertise across diverse sectors, delivering tailored solutions.';
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  currentPath="/industries"
>
  <section class="py-20 lg:py-32 bg-[#FAFAF8] pt-40" aria-labelledby="industries-heading">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <AnimatedSection class="text-center max-w-3xl mx-auto mb-16">
        <h1 id="industries-heading" class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
          {heading}
        </h1>
        <p class="text-lg text-[#5D6D7E] leading-relaxed">
          {description}
        </p>
      </AnimatedSection>

      <AnimatedSection animation="scale" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-6" tag="div">
        {industries.map((industry) => (
          <article
            class="group relative bg-white border border-[#D5E8D4] rounded-2xl p-8 overflow-hidden cursor-pointer transition-all duration-500 hover:-translate-y-3 hover:shadow-2xl hover:shadow-[#52C17A]/20 hover:border-[#52C17A] text-center"
          >
            <!-- Animated gradient background -->
            <div class="absolute inset-0 bg-gradient-to-br from-[#E8F5E9] to-white opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>

            <!-- Content -->
            <div class="relative z-10">
              <div class="w-16 h-16 mx-auto rounded-2xl bg-[#E8F5E9] flex items-center justify-center mb-6 group-hover:scale-110 group-hover:rotate-6 group-hover:bg-gradient-to-br group-hover:from-[#52C17A] group-hover:to-[#3D9E5F] transition-all duration-500 shadow-sm group-hover:shadow-lg group-hover:shadow-[#52C17A]/30" aria-hidden="true">
                <Icon name={industry.icon} class="w-8 h-8 text-[#52C17A] group-hover:text-white transition-all duration-500 group-hover:scale-110" size={32} />
              </div>
              <h2 class="text-xl font-bold text-[#2C3E50] mb-3 group-hover:text-[#52C17A] group-hover:scale-105 transition-all duration-300">
                {industry.title}
              </h2>
              <p class="text-sm text-[#5D6D7E] leading-relaxed group-hover:translate-y-1 transition-transform duration-300">
                {industry.description}
              </p>
            </div>

            <!-- Decorative corner -->
            <div class="absolute bottom-0 left-0 w-24 h-24 bg-gradient-to-tr from-[#52C17A]/10 to-transparent rounded-tr-full opacity-0 group-hover:opacity-100 transition-opacity duration-500" aria-hidden="true"></div>
          </article>
        ))}
      </AnimatedSection>
    </div>
  </section>
</Layout>

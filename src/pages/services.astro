---
import Layout from '../layouts/Layout.astro';
import D1 from '../designs/design1/ServicesList.astro';
import D2 from '../designs/design2/ServicesList.astro';
import D3 from '../designs/design3/ServicesList.astro';
import D4 from '../designs/design4/ServicesList.astro';
const lang = 'en';
---

<Layout title="Services - Paricus" description="Comprehensive BPO solutions designed to optimize your operations and accelerate growth." lang={lang} currentPath="/services">
  <div data-design="1"><D1 lang={lang} /></div>
  <div data-design="2" style="display:none;"><D2 lang={lang} /></div>
  <div data-design="3" style="display:none;"><D3 lang={lang} /></div>
  <div data-design="4" style="display:none;"><D4 lang={lang} /></div>
</Layout>

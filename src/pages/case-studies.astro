---
import Layout from '../layouts/Layout.astro';
import AnimatedSection from '../components/common/AnimatedSection.astro';
import Icon from '../components/common/Icon.astro';
import { t, getLocalizedPath } from '../i18n/utils';
import { getCaseStudies, getCaseStudiesPage } from '../lib/strapi';

const lang = 'en';

// Fetch CMS content
const [caseStudiesData, pageSettings] = await Promise.all([
  getCaseStudies(lang),
  getCaseStudiesPage(lang)
]);

// Fallback values if CMS is not configured
const defaultCaseStudies = [
  {
    id: 1,
    title: 'Transforming Healthcare Support',
    slug: 'healthcare-support',
    industry: 'Healthcare',
    challenge: 'A leading healthcare provider struggled with patient support during high-demand periods.',
    solution: 'We deployed a dedicated bilingual team with HIPAA certification and healthcare expertise.',
    results: [
      { id: 1, icon: 'trending-up', metric: '40%', label: 'Efficiency Increase' },
      { id: 2, icon: 'clock', metric: '30%', label: 'Faster Response' },
      { id: 3, icon: 'users', metric: '95%', label: 'Patient Satisfaction' }
    ]
  },
  {
    id: 2,
    title: 'E-Commerce Growth Partner',
    slug: 'ecommerce-growth',
    industry: 'E-Commerce',
    challenge: 'A fast-growing online retailer needed to scale support while maintaining quality.',
    solution: 'We implemented a flexible support model with seamless peak-season scaling.',
    results: [
      { id: 1, icon: 'trending-up', metric: '3x', label: 'Volume Handled' },
      { id: 2, icon: 'clock', metric: '50%', label: 'Cost Reduction' },
      { id: 3, icon: 'users', metric: '98%', label: 'Order Accuracy' }
    ]
  },
  {
    id: 3,
    title: 'Tech Support Excellence',
    slug: 'tech-support',
    industry: 'Technology',
    challenge: 'A SaaS company faced challenges with technical support quality and response times.',
    solution: 'We established a specialized technical support team with product expertise.',
    results: [
      { id: 1, icon: 'trending-up', metric: '60%', label: 'First Call Resolution' },
      { id: 2, icon: 'clock', metric: '45%', label: 'Reduced Wait Time' },
      { id: 3, icon: 'users', metric: '92%', label: 'CSAT Score' }
    ]
  }
];

// Use CMS data with fallbacks
const caseStudies = caseStudiesData.length ? caseStudiesData : defaultCaseStudies;
const heading = pageSettings?.heading || t('caseStudies.heading', lang);
const description = pageSettings?.description || t('caseStudies.description', lang);
const challengeLabel = pageSettings?.challengeLabel || t('caseStudies.challenge', lang);
const solutionLabel = pageSettings?.solutionLabel || t('caseStudies.solution', lang);
const resultsLabel = pageSettings?.resultsLabel || t('caseStudies.results', lang);
const ctaText = pageSettings?.ctaText || t('caseStudies.viewFullCase', lang);
const metaTitle = pageSettings?.metaTitle || 'Case Studies - Paricus';
const metaDescription = pageSettings?.metaDescription || 'Real success stories demonstrating our commitment to delivering measurable impact.';
---

<Layout
  title={metaTitle}
  description={metaDescription}
  lang={lang}
  currentPath="/case-studies"
>
  <section class="py-20 lg:py-32 bg-white pt-40" aria-labelledby="case-studies-heading">
    <div class="max-w-[1600px] mx-auto px-6 lg:px-12">
      <AnimatedSection class="max-w-3xl mb-16">
        <h1 id="case-studies-heading" class="text-4xl lg:text-5xl font-bold text-[#2C3E50] mb-6 leading-tight">
          {heading}
        </h1>
        <p class="text-lg text-[#5D6D7E] leading-relaxed">
          {description}
        </p>
      </AnimatedSection>

      <AnimatedSection class="space-y-8">
        {caseStudies.map((study) => (
          <article
            class="group relative bg-[#FAFAF8] rounded-2xl border border-[#D5E8D4] overflow-hidden hover:border-[#52C17A] hover:shadow-2xl hover:shadow-[#52C17A]/10 transition-all duration-500 cursor-pointer"
          >
            <div class="p-8 lg:p-10">
              <div class="flex flex-col lg:flex-row lg:items-start lg:justify-between gap-8">
                <div class="flex-1">
                  <span class="inline-block px-4 py-2 bg-[#E8F5E9] text-[#52C17A] text-xs font-semibold rounded-full mb-4 group-hover:scale-105 group-hover:bg-[#52C17A] group-hover:text-white transition-all duration-300">
                    {study.industry}
                  </span>
                  <h2 class="text-2xl lg:text-3xl font-bold text-[#2C3E50] mb-6 group-hover:text-[#52C17A] group-hover:translate-x-2 transition-all duration-300">
                    {study.title}
                  </h2>

                  <div class="space-y-6 mb-8">
                    <div class="group-hover:translate-x-1 transition-transform duration-300">
                      <h3 class="text-sm font-bold text-[#2C3E50] mb-2 uppercase tracking-wide">
                        {challengeLabel}
                      </h3>
                      <p class="text-base text-[#5D6D7E] leading-relaxed">
                        {study.challenge}
                      </p>
                    </div>
                    <div class="group-hover:translate-x-1 transition-transform duration-300" style="transition-delay: 100ms">
                      <h3 class="text-sm font-bold text-[#2C3E50] mb-2 uppercase tracking-wide">
                        {solutionLabel}
                      </h3>
                      <p class="text-base text-[#5D6D7E] leading-relaxed">
                        {study.solution}
                      </p>
                    </div>
                  </div>

                  <a
                    href={getLocalizedPath('/contact', lang)}
                    class="inline-flex items-center text-[#52C17A] font-semibold text-sm group-hover:gap-3 transition-all duration-300"
                    aria-label={`View full case study: ${study.title}`}
                  >
                    {ctaText}
                    <Icon name="arrow-right" class="ml-1 w-5 h-5 group-hover:translate-x-2 transition-transform duration-300" size={20} aria-hidden="true" />
                  </a>
                </div>

                <aside class="lg:w-80 flex-shrink-0" aria-label="Case study results">
                  <div class="bg-white rounded-2xl p-6 border border-[#D5E8D4] group-hover:border-[#52C17A] group-hover:shadow-lg transition-all duration-500">
                    <h3 class="text-sm font-bold text-[#2C3E50] mb-6 uppercase tracking-wide">
                      {resultsLabel}
                    </h3>
                    <div class="space-y-6">
                      {study.results.map((result, idx) => (
                        <div
                          class="flex items-start gap-4 group-hover:translate-x-2 transition-transform duration-300"
                          style={`transition-delay: ${idx * 100}ms`}
                        >
                          <div class="w-12 h-12 rounded-xl bg-[#E8F5E9] flex items-center justify-center flex-shrink-0 group-hover:bg-[#52C17A] transition-colors duration-300" aria-hidden="true">
                            <Icon name={result.icon} class="w-6 h-6 text-[#52C17A] group-hover:text-white transition-colors duration-300" size={24} />
                          </div>
                          <div>
                            <div class="text-3xl font-bold text-[#52C17A] mb-1">
                              {result.metric}
                            </div>
                            <div class="text-sm text-[#5D6D7E] font-medium">
                              {result.label}
                            </div>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                </aside>
              </div>
            </div>
          </article>
        ))}
      </AnimatedSection>
    </div>
  </section>
</Layout>

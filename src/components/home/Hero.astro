---
import { t, getLocalizedPath } from '../../i18n/utils';
import Icon from '../common/Icon.astro';
import { getHomepage } from '../../lib/strapi';

interface Props {
  lang?: string;
}

const { lang = 'en' } = Astro.props;

// Fetch homepage content from Strapi
const homepage = await getHomepage(lang as 'en' | 'es');
const hero = homepage?.hero;

// Use Strapi content with fallback to i18n translations
const badge = hero?.badge || t('hero.badge', lang);
const title = hero?.title || t('hero.title', lang);
const titleHighlight = hero?.titleHighlight || t('hero.titleHighlight', lang);
const titleEnd = hero?.titleEnd || t('hero.titleEnd', lang);
const description = hero?.description || t('hero.description', lang);
const primaryButtonText = hero?.primaryButtonText || t('hero.exploreServices', lang);
const secondaryButtonText = hero?.secondaryButtonText || t('hero.getInTouch', lang);

// Stats with fallback
const defaultStats = [
  { value: '100+', label: t('hero.teamMembers', lang) },
  { value: '15+', label: t('hero.yearsExperience', lang) },
  { value: '98%', label: t('hero.satisfactionRate', lang) },
];
const stats = hero?.stats && hero.stats.length > 0 ? hero.stats : defaultStats;
---

<section
  class="relative pt-40 pb-24 lg:pt-48 lg:pb-40 overflow-hidden"
  role="banner"
  aria-label="Hero section"
>
  <!-- Animated gradient background -->
  <div class="absolute inset-0 bg-gradient-to-br from-[#E8F5E9] via-[#FAFAF8] to-[#FFF8E7]" aria-hidden="true"></div>

  <!-- Modern blob shapes -->
  <div class="absolute inset-0 opacity-30" aria-hidden="true">
    <div class="absolute top-0 right-0 w-[800px] h-[800px] bg-gradient-to-br from-[#52C17A] to-[#4DB6AC] rounded-full blur-3xl transform translate-x-1/2 -translate-y-1/2 animate-pulse"></div>
    <div class="absolute bottom-0 left-0 w-[600px] h-[600px] bg-gradient-to-tr from-[#4DB6AC] to-[#52C17A] rounded-full blur-3xl transform -translate-x-1/2 translate-y-1/2"></div>
  </div>

  <!-- Decorative elements -->
  <div class="absolute inset-0 opacity-10" aria-hidden="true">
    <div class="absolute top-1/4 left-1/4 w-2 h-2 bg-[#52C17A] rounded-full"></div>
    <div class="absolute top-1/3 right-1/3 w-3 h-3 bg-[#4DB6AC] rounded-full"></div>
    <div class="absolute bottom-1/4 right-1/4 w-2 h-2 bg-[#52C17A] rounded-full"></div>
  </div>

  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 relative z-10">
    <div class="max-w-5xl">
      <!-- Badge -->
      <div class="inline-flex items-center px-4 py-2 rounded-full bg-white/60 backdrop-blur-sm border border-[#D5E8D4] mb-8 animate-fade-in shadow-sm">
        <span class="w-2 h-2 bg-[#52C17A] rounded-full mr-2 animate-pulse"></span>
        <span class="text-sm font-medium text-[#2C3E50]">{badge}</span>
      </div>

      <h1 class="text-5xl lg:text-7xl xl:text-8xl font-bold text-[#2C3E50] leading-[1.1] mb-8 text-balance animate-fade-in">
        {title}{' '}
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#52C17A] to-[#3D9E5F]">
          {titleHighlight}
        </span>{' '}
        {titleEnd}
      </h1>

      <p class="text-xl lg:text-2xl text-[#5D6D7E] leading-relaxed mb-12 max-w-3xl">
        {description}
      </p>

      <div class="flex flex-col sm:flex-row gap-4">
        <a
          href={getLocalizedPath('/services', lang)}
          class="inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-gradient-to-r from-[#52C17A] to-[#3D9E5F] text-white text-base font-semibold hover:shadow-2xl hover:shadow-[#52C17A]/50 hover:scale-105 transition-all duration-300 group"
          aria-label="Explore our services"
        >
          {primaryButtonText}
          <Icon name="arrow-right" class="ml-2 w-5 h-5 group-hover:translate-x-2 transition-transform" size={20} aria-hidden="true" />
        </a>
        <a
          href={getLocalizedPath('/contact', lang)}
          class="inline-flex items-center justify-center px-10 py-5 rounded-2xl bg-white/80 backdrop-blur-sm border-2 border-[#D5E8D4] text-[#2C3E50] text-base font-semibold hover:bg-white hover:border-[#52C17A] hover:shadow-lg transition-all duration-300"
          aria-label="Get in touch with us"
        >
          {secondaryButtonText}
        </a>
      </div>

      <!-- Trust indicators -->
      <div class="mt-16 grid grid-cols-3 gap-8 max-w-2xl">
        {stats.map((stat, index) => (
          <div class={index > 0 ? "border-l border-[#D5E8D4] pl-8" : ""}>
            <div class="text-3xl lg:text-4xl font-bold text-[#52C17A] mb-2">{stat.value}</div>
            <div class="text-sm text-[#5D6D7E] font-medium">{stat.label}</div>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
